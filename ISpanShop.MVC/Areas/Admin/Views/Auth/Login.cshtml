@model ISpanShop.MVC.Models.Auth.AdminLoginVm
@{
    Layout = null;
    ViewData["Title"] = "後台登入 - ISpanShop";
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon-shop.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/sneat/assets/vendor/fonts/boxicons.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Public Sans', sans-serif;
        }

        /* ── 整體佈局 ── */
        .login-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ══════════ 左側品牌區 ══════════ */
        .brand-side {
            flex: 0 0 58%;
            background: linear-gradient(135deg, #151C25 0%, #0D1218 100%);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: clamp(1.25rem, 2.2vh, 2.5rem) clamp(1.5rem, 3.2vw, 3.5rem);
        }

        /* ── 背景網格線 ── */
        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 40px 40px;
            -webkit-mask-image: radial-gradient(circle at center, black 0%, transparent 80%);
            mask-image: radial-gradient(circle at center, black 0%, transparent 80%);
            z-index: 0;
        }

        /* ── 背景光暈 ── */
        .bg-glow {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,176,116,0.15) 0%, rgba(0,176,116,0) 60%);
            filter: blur(50px);
            z-index: 0;
        }

        .bg-glow-1 {
            width: 700px;
            height: 700px;
            top: -250px;
            left: -250px;
        }

        .bg-glow-2 {
            width: 500px;
            height: 500px;
            top: 20%;
            right: -100px;
            opacity: 0.4;
        }

        /* ── 響應式方塊尺寸變數 ── */
        :root {
            --cs: clamp(180px, 22vw, 440px);
            --cf: calc(var(--cs) * 0.5);
            --cfo: calc(var(--cs) * 0.25);
            --ctz: calc(var(--cs) * 0.25);
            --cc: calc(var(--cs) * 0.15);
            --cco: calc((var(--cs) - var(--cc)) / 2);
        }

        /* ── 3D 旋轉方塊場景 ── */
        .scene {
            position: absolute;
            right: clamp(1%, 3vw, 5%);
            top: 50%;
            transform: translateY(-50%);
            width: var(--cs);
            height: var(--cs);
            perspective: calc(var(--cs) * 3.75);
            z-index: 5;
            pointer-events: none;
        }

        .cube-wrapper {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            animation: rotateCube 20s linear infinite;
        }

        @@keyframes rotateCube {
            0% {
                transform: rotateX(-20deg) rotateY(0deg);
            }

            100% {
                transform: rotateX(-20deg) rotateY(360deg);
            }
        }

        .cube-face {
            position: absolute;
            width: var(--cf);
            height: var(--cf);
            top: var(--cfo);
            left: var(--cfo);
            background: rgba(0,176,116,0.03);
            border: 1px solid rgba(0,176,116,0.4);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            box-shadow: inset 0 0 30px rgba(0,176,116,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .face-front {
            transform: rotateY(0deg) translateZ(var(--ctz));
        }

        .face-back {
            transform: rotateY(180deg) translateZ(var(--ctz));
        }

        .face-right {
            transform: rotateY(90deg) translateZ(var(--ctz));
        }

        .face-left {
            transform: rotateY(-90deg) translateZ(var(--ctz));
        }

        .face-top {
            transform: rotateX(90deg) translateZ(var(--ctz));
            border-bottom: none;
            background: rgba(0,176,116,0.08);
        }

        .face-bottom {
            transform: rotateX(-90deg) translateZ(var(--ctz));
        }

        .cube-core {
            position: absolute;
            width: var(--cc);
            height: var(--cc);
            top: var(--cco);
            left: var(--cco);
            background: rgba(0,176,116,0.8);
            border-radius: 50%;
            box-shadow: 0 0 calc(var(--cc) * 0.85) calc(var(--cc) * 0.33) rgba(0,176,116,0.4);
            animation: pulseCore 3s ease-in-out infinite alternate;
            z-index: 1;
        }

        @@keyframes pulseCore {
            0% {
                transform: scale(0.8);
                opacity: 0.7;
            }

            100% {
                transform: scale(1.2);
                opacity: 1;
            }
        }

        /* ── 懸浮裝飾 Icon ── */
        .floating-element {
            position: absolute;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #00B074;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            z-index: 10;
            font-size: 1.3rem;
        }

        .float-1 {
            width: clamp(38px, 3.2vw, 56px);
            height: clamp(38px, 3.2vw, 56px);
            top: 10%;
            right: 14%;
            animation: floatAlt 5s ease-in-out infinite;
        }

        .float-2 {
            width: clamp(42px, 3.6vw, 62px);
            height: clamp(42px, 3.6vw, 62px);
            bottom: 20%;
            left: 52%;
            animation: floatAlt 7s ease-in-out infinite 1s;
        }

        .float-3 {
            width: clamp(34px, 2.8vw, 50px);
            height: clamp(34px, 2.8vw, 50px);
            top: 40%;
            right: -1%;
            animation: floatAlt 6s ease-in-out infinite 2s;
        }

        @@keyframes floatAlt {
            0% {
                transform: translateY(0px) rotate(0deg);
            }

            50% {
                transform: translateY(-15px) rotate(5deg);
            }

            100% {
                transform: translateY(0px) rotate(0deg);
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Logo */
        .brand-logo {
            display: flex;
            align-items: center;
            gap: .75rem;
            position: relative;
            z-index: 2;
            animation: fadeInUp .6s ease both;
        }

        .brand-logo-icon {
            width: clamp(32px, 2.8vw, 44px);
            height: clamp(32px, 2.8vw, 44px);
            border-radius: 10px;
            background: linear-gradient(135deg, #F59E0B, #FBBF24);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 14px rgba(245,158,11,.35);
        }

            .brand-logo-icon i {
                font-size: clamp(1.1rem, 1.4vw, 1.5rem);
                color: #fff;
            }

        .brand-logo-text {
            font-size: clamp(1rem, 1.2vw, 1.35rem);
            font-weight: 700;
            color: #fff;
            letter-spacing: -.5px;
        }

        .brand-logo-badge {
            font-size: clamp(.58rem, .55vw, .65rem);
            font-weight: 600;
            color: #00B074;
            background: rgba(0,176,116,.15);
            border: 1px solid rgba(0,176,116,.3);
            border-radius: 4px;
            padding: 1px 6px;
            margin-left: .25rem;
        }

        /* 品牌主內容 */
        .brand-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            z-index: 2;
            padding: clamp(.75rem, 1.5vh, 2rem) 0;
            max-width: 52%;
        }

        .brand-tagline {
            font-size: clamp(.7rem, .75vw, .9rem);
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #00B074;
            margin-bottom: clamp(.6rem, 1.1vh, 1.25rem);
            animation: fadeInUp .6s ease .2s both;
        }

        .brand-title {
            font-size: clamp(1.6rem, 2.8vw, 3rem);
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
            margin-bottom: clamp(.5rem, .9vh, 1rem);
            animation: fadeInUp .6s ease .35s both;
            white-space: nowrap;
        }

            .brand-title span {
                background: linear-gradient(90deg, #00B074, #34d399);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .brand-subtitle {
            color: #8da8c0;
            font-size: clamp(.78rem, .82vw, 1rem);
            line-height: 1.7;
            max-width: 100%;
            margin-bottom: clamp(1rem, 2.2vh, 2.5rem);
            animation: fadeInUp .6s ease .5s both;
        }

        /* 日期時間顯示 */
        .datetime-wrap {
            display: flex;
            align-items: center;
            gap: clamp(.7rem, 1vw, 1.25rem);
            margin-bottom: clamp(.8rem, 1.8vh, 2rem);
            animation: fadeInUp .6s ease .58s both;
            white-space: nowrap;
            flex-wrap: nowrap;
        }

        .datetime-time {
            font-size: clamp(1.2rem, 1.9vw, 2.2rem);
            font-weight: 600;
            color: rgba(255,255,255,0.45);
            letter-spacing: clamp(1px, .25vw, 3px);
            line-height: 1;
            font-variant-numeric: tabular-nums;
            flex-shrink: 0;
        }

            .datetime-time .colon {
                display: inline-block;
                opacity: 0.4;
            }

        .datetime-divider {
            width: 1px;
            height: clamp(24px, 3vh, 40px);
            background: rgba(255,255,255,0.15);
            flex-shrink: 0;
        }

        .datetime-date {
            display: flex;
            flex-direction: column;
            gap: .25rem;
            flex-shrink: 0;
        }

            .datetime-date .date-row {
                font-size: clamp(.72rem, .75vw, .9rem);
                color: #a9c1d8;
                font-weight: 500;
                letter-spacing: .5px;
            }

            .datetime-date .week-row {
                font-size: clamp(.65rem, .68vw, .8rem);
                color: #00B074;
                font-weight: 600;
                letter-spacing: 1px;
            }

        /* 功能特色列表 */
        .feature-list {
            display: flex;
            flex-direction: column;
            gap: clamp(.5rem, 1vh, .9rem);
            animation: fadeInUp .6s ease .65s both;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: clamp(.6rem, .8vw, .9rem);
        }

        .feature-icon {
            width: clamp(28px, 2.5vw, 38px);
            height: clamp(28px, 2.5vw, 38px);
            border-radius: 9px;
            background: rgba(0,176,116,.12);
            border: 1px solid rgba(0,176,116,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .feature-icon i {
                color: #00B074;
                font-size: clamp(.85rem, .9vw, 1.1rem);
            }

        .feature-text {
            font-size: clamp(.74rem, .78vw, .88rem);
            color: #a9c1d8;
            line-height: 1.5;
        }

            .feature-text strong {
                color: #d1e8f5;
                font-weight: 600;
            }

        /* 底部版權 */
        .brand-footer {
            position: relative;
            z-index: 2;
            color: #4a6a85;
            font-size: clamp(.68rem, .7vw, .78rem);
            animation: fadeInUp .6s ease .8s both;
        }

        /* ══════════ 右側表單區 ══════════ */
        .form-side {
            flex: 1;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            animation: slideInRight .55s ease .1s both;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 400px;
        }

        .form-header {
            margin-bottom: 2.25rem;
        }

            .form-header h2 {
                font-size: 1.75rem;
                font-weight: 700;
                color: #1e293b;
                margin: 0 0 .4rem;
            }

            .form-header p {
                color: #64748b;
                font-size: .93rem;
                margin: 0;
            }

        /* 錯誤訊息框 */
        .login-error-box {
            display: flex;
            align-items: flex-start;
            gap: .6rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: .85rem 1rem;
            margin-bottom: 1.5rem;
            color: #dc2626;
            font-size: .88rem;
            line-height: 1.5;
            animation: fadeInUp .3s ease both;
        }

            .login-error-box i {
                font-size: 1.1rem;
                flex-shrink: 0;
                margin-top: 1px;
            }

        /* 輸入框組 */
        .input-group-wrap {
            margin-bottom: 1.25rem;
        }

            .input-group-wrap label {
                display: block;
                font-size: .85rem;
                font-weight: 600;
                color: #374151;
                margin-bottom: .45rem;
            }

        .input-field-wrap {
            position: relative;
        }

            .input-field-wrap .input-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #9ca3af;
                font-size: 1.1rem;
                pointer-events: none;
                transition: color .25s;
            }

            .input-field-wrap input {
                width: 100%;
                padding: .72rem 1rem .72rem 2.8rem;
                border: 1.5px solid #e5e7eb;
                border-radius: 10px;
                font-size: .93rem;
                font-family: inherit;
                color: #1e293b;
                background: #f9fafb;
                transition: border-color .25s, box-shadow .25s, background .25s;
                outline: none;
            }

                .input-field-wrap input:focus {
                    border-color: #00B074;
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(0,176,116,.12);
                }

            .input-field-wrap:focus-within .input-icon {
                color: #00B074;
            }

        /* 密碼顯示/隱藏按鈕 */
        .pwd-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #9ca3af;
            font-size: 1.1rem;
            padding: 4px;
            display: flex;
            transition: color .2s;
        }

            .pwd-toggle:hover {
                color: #00B074;
            }

        /* 記住我 + 忘記密碼 */
        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.75rem;
        }

        .checkbox-wrap {
            display: flex;
            align-items: center;
            gap: .5rem;
            cursor: pointer;
        }

            .checkbox-wrap input[type="checkbox"] {
                width: 16px;
                height: 16px;
                accent-color: #00B074;
                cursor: pointer;
            }

            .checkbox-wrap span {
                font-size: .875rem;
                color: #4b5563;
                user-select: none;
            }

        .forgot-link {
            font-size: .875rem;
            color: #00B074;
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }

            .forgot-link:hover {
                color: #059669;
                text-decoration: underline;
            }

        /* 登入按鈕 */
        .btn-login {
            width: 100%;
            padding: .82rem 1.5rem;
            background: linear-gradient(135deg, #00B074, #059669);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: transform .2s ease, box-shadow .2s ease;
            box-shadow: 0 4px 14px rgba(0,176,116,.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            position: relative;
            overflow: hidden;
        }

            .btn-login:hover {
                transform: scale(1.02);
                box-shadow: 0 6px 20px rgba(0,176,116,.45);
            }

            .btn-login:active {
                transform: scale(0.99);
            }

            .btn-login:disabled {
                opacity: .75;
                cursor: not-allowed;
                transform: none;
            }

        /* Loading Spinner */
        .btn-spinner {
            display: none;
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
        }

        .btn-login.loading .btn-text {
            display: none;
        }

        .btn-login.loading .btn-spinner {
            display: block;
        }

        /* 快速填入測試帳號按鈕 */
        .btn-quick-fill {
            width: 100%;
            margin-top: .75rem;
            padding: .6rem 1rem;
            background: transparent;
            color: #9ca3af;
            border: 1.5px dashed #d1d5db;
            border-radius: 10px;
            font-size: .82rem;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            transition: border-color .2s, color .2s, background .2s;
        }

            .btn-quick-fill:hover {
                border-color: #00B074;
                color: #00B074;
                background: rgba(0,176,116,.04);
            }

            .btn-quick-fill i {
                font-size: .9rem;
            }

        /* 底部小字 */
        .form-footer {
            text-align: center;
            margin-top: 1.75rem;
            color: #9ca3af;
            font-size: .8rem;
        }

        /* ══════════ RWD ══════════ */
        @@media (max-width: 900px) {
            .brand-side {
                display: none;
            }

            .form-side {
                background: linear-gradient(160deg, #f0fdf8 0%, #ecfdf5 100%);
                animation: fadeInUp .5s ease both;
            }

            .login-form-wrap {
                max-width: 420px;
            }
        }

        @@media (max-width: 480px) {
            .form-side {
                padding: 2rem 1.25rem;
            }

            .form-header h2 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">

        <!-- ══ 左側品牌區 ══ -->
        <div class="brand-side">

            <!-- 背景層：網格 + 光暈 -->
            <div class="bg-grid"></div>
            <div class="bg-glow bg-glow-1"></div>
            <div class="bg-glow bg-glow-2"></div>

            <!-- 3D 旋轉方塊場景 -->
            <div class="scene">
                <!-- 懸浮裝飾 Icon -->
                <div class="floating-element float-1"><i class="bx bxs-shield-alt-2"></i></div>
                <div class="floating-element float-2"><i class="bx bx-group"></i></div>
                <div class="floating-element float-3"><i class="bx bx-server"></i></div>

                <!-- 旋轉的 3D 透視方塊 -->
                <div class="cube-wrapper">
                    <div class="cube-core"></div>
                    <div class="cube-face face-front">
                        <i class="bx bx-package" style="color:rgba(0,176,116,0.30);font-size:3.5rem;"></i>
                    </div>
                    <div class="cube-face face-back"></div>
                    <div class="cube-face face-right"></div>
                    <div class="cube-face face-left"></div>
                    <div class="cube-face face-top"></div>
                    <div class="cube-face face-bottom"></div>
                </div>
            </div>

            <!-- Logo -->
            <div class="brand-logo">
                <div class="brand-logo-icon">
                    <i class="bx bx-store-alt"></i>
                </div>
                <span class="brand-logo-text">ISpanShop</span>
                <span class="brand-logo-badge">Admin</span>
            </div>

            <!-- 主要內容 -->
            <div class="brand-content">
                <div class="brand-tagline">Management System</div>
                <h1 class="brand-title">
                    歡迎回來<br />
                    <span>後台管理中心</span>
                </h1>
                <p class="brand-subtitle">
                    安全、穩定的電商協作環境。請登入以存取您的工作區域，我們將依據您的角色權限提供對應的功能服務。
                </p>

                <!-- 日期時間 -->
                <div class="datetime-wrap">
                    <div class="datetime-time" id="dtTime">
                        <span id="dtH">00</span><span class="colon">:</span><span id="dtM">00</span><span class="colon">:</span><span id="dtS">00</span>
                    </div>
                    <div class="datetime-divider"></div>
                    <div class="datetime-date">
                        <div class="date-row" id="dtDate">2026 / 01 / 01</div>
                        <div class="week-row" id="dtWeek">星期一</div>
                    </div>
                </div>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-shield-quarter"></i></div>
                        <div class="feature-text">
                            <strong>安全存取</strong><br />嚴密的身份驗證與權限管控機制
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-server"></i></div>
                        <div class="feature-text">
                            <strong>穩定可靠</strong><br />高可用性架構，確保服務持續運行
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-tachometer"></i></div>
                        <div class="feature-text">
                            <strong>高效協作</strong><br />依角色授權，讓每位成員聚焦本職
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-lock-open-alt"></i></div>
                        <div class="feature-text">
                            <strong>隱私合規</strong><br />操作記錄全程留存，行為可追溯
                        </div>
                    </div>
                </div>
            </div>

            <!-- 版權 -->
            <div class="brand-footer">
                &copy; 2026 ISpanShop. All rights reserved.
            </div>
        </div>

        <!-- ══ 右側登入表單區（完全不動）══ -->
        <div class="form-side">
            <div class="login-form-wrap">
                <!-- 表頭 -->
                <div class="form-header">
                    <h2>登入後台</h2>
                    <p>請輸入您的帳號及密碼以繼續</p>
                </div>

                <!-- 錯誤訊息 -->
                @if (!ViewData.ModelState.IsValid)
                {
                    var errors = ViewData.ModelState.Values
                    .SelectMany(v => v.Errors)
                    .Select(e => e.ErrorMessage)
                    .ToList();
                    if (errors.Any())
                    {
                        <div class="login-error-box">
                            <i class="bx bx-error-circle"></i>
                            <div>@string.Join(" ", errors)</div>
                        </div>
                    }
                }

                <!-- 表單 -->
                <form asp-area="Admin" asp-controller="Auth" asp-action="Login" method="post" id="loginForm">
                    @Html.AntiForgeryToken()
                    @if (ViewData["ReturnUrl"] != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    }

                    <!-- 帳號 -->
                    <div class="input-group-wrap">
                        <label asp-for="Account">帳號</label>
                        <div class="input-field-wrap">
                            <i class="bx bx-user input-icon"></i>
                            <input asp-for="Account"
                                   type="text"
                                   placeholder="請輸入管理員帳號"
                                   autocomplete="username" />
                        </div>
                    </div>

                    <!-- 密碼 -->
                    <div class="input-group-wrap">
                        <label asp-for="Password">密碼</label>
                        <div class="input-field-wrap">
                            <i class="bx bx-lock-alt input-icon"></i>
                            <input asp-for="Password"
                                   id="passwordInput"
                                   type="password"
                                   placeholder="請輸入密碼"
                                   autocomplete="current-password" />
                            <button type="button" class="pwd-toggle" id="pwdToggleBtn" tabindex="-1" title="顯示/隱藏密碼">
                                <i class="bx bx-hide" id="pwdToggleIcon"></i>
                            </button>
                        </div>
                    </div>

                    <!-- 記住我 + 忘記密碼 -->
                    <div class="form-options">
                        <label class="checkbox-wrap">
                            <input asp-for="RememberMe" type="checkbox" />
                            <span>記住我</span>
                        </label>
                        <a href="#" class="forgot-link">忘記密碼？</a>
                    </div>

                    <!-- 登入按鈕 -->
                    <button type="submit" class="btn-login" id="loginBtn">
                        <span class="btn-text">
                            <i class="bx bx-log-in-circle"></i>
                            登入後台
                        </span>
                        <span class="btn-spinner"></span>
                    </button>

                    <!-- 快速填入測試帳號 -->
                    <button type="button" class="btn-quick-fill" id="quickFillBtn">
                        <i class="bx bx-fill"></i>
                        快速填入測試帳號
                    </button>
                </form>

                <div class="form-footer">
                    © 2026 ISpanShop 後台管理系統
                </div>
            </div>
        </div>
    </div>

    <script>
        // 即時時鐘
        (function () {
            var weeks = ['星期日','星期一','星期二','星期三','星期四','星期五','星期六'];
            function pad(n) { return String(n).padStart(2, '0'); }
            function tick() {
                var now  = new Date();
                var y    = now.getFullYear();
                var mo   = pad(now.getMonth() + 1);
                var d    = pad(now.getDate());
                document.getElementById('dtH').textContent    = pad(now.getHours());
                document.getElementById('dtM').textContent    = pad(now.getMinutes());
                document.getElementById('dtS').textContent    = pad(now.getSeconds());
                document.getElementById('dtDate').textContent = y + ' / ' + mo + ' / ' + d;
                document.getElementById('dtWeek').textContent = weeks[now.getDay()];
            }
            tick();
            setInterval(tick, 1000);
        })();


        (function () {
            var input = document.getElementById('passwordInput');
            var btn   = document.getElementById('pwdToggleBtn');
            var icon  = document.getElementById('pwdToggleIcon');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var isHidden = input.type === 'password';
                input.type = isHidden ? 'text' : 'password';
                icon.className = isHidden ? 'bx bx-show' : 'bx bx-hide';
            });
        })();

        // 快速填入測試帳號
        (function () {
            var btn = document.getElementById('quickFillBtn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                document.querySelector('input[name="Account"]').value = 'admin';
                document.getElementById('passwordInput').value = 'Admin@1234';
            });
        })();

        // 前端驗證 + Loading 狀態
        (function () {
            var form       = document.getElementById('loginForm');
            var loginBtn   = document.getElementById('loginBtn');
            var accountEl  = document.querySelector('input[name="Account"]');
            var passwordEl = document.getElementById('passwordInput');

            form.addEventListener('submit', function (e) {
                var account  = (accountEl.value  || '').trim();
                var password = (passwordEl.value || '').trim();

                var existingErr = document.querySelector('.login-error-box.js-err');
                if (existingErr) existingErr.remove();

                if (!account || !password) {
                    e.preventDefault();
                    var errBox = document.createElement('div');
                    errBox.className = 'login-error-box js-err';
                    errBox.innerHTML =
                        '<i class="bx bx-error-circle"></i>' +
                        '<div>' + (!account ? '請輸入帳號' : '請輸入密碼') + '</div>';
                    form.insertBefore(errBox, form.firstChild);
                    (!account ? accountEl : passwordEl).focus();
                    return;
                }

                loginBtn.classList.add('loading');
                loginBtn.disabled = true;
            });
        })();
    </script>
</body>
</html>
