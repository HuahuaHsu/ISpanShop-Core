@model ISpanShop.MVC.Models.Auth.AdminLoginVm
@{
    Layout = null;
    ViewData["Title"] = "後台登入 - ISpanShop";
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon-shop.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/sneat/assets/vendor/fonts/boxicons.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Public Sans', sans-serif;
        }

        /* ── 整體佈局 ── */
        .login-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ══════════ 左側品牌區 ══════════ */
        .brand-side {
            flex: 0 0 58%;
            background: linear-gradient(135deg, #151C25 0%, #0D1218 100%);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: clamp(1.25rem, 2.2vh, 2.5rem) clamp(1.5rem, 3.2vw, 3.5rem);
        }

        /* ── 背景網格線 ── */
        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 40px 40px;
            -webkit-mask-image: radial-gradient(circle at center, black 0%, transparent 80%);
            mask-image: radial-gradient(circle at center, black 0%, transparent 80%);
            z-index: 0;
        }

        /* ── 背景光暈 ── */
        .bg-glow {
            position: absolute;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,176,116,0.15) 0%, rgba(0,176,116,0) 60%);
            filter: blur(50px);
            z-index: 0;
        }

        .bg-glow-1 {
            width: 700px;
            height: 700px;
            top: -250px;
            left: -250px;
        }

        .bg-glow-2 {
            width: 500px;
            height: 500px;
            top: 20%;
            right: -100px;
            opacity: 0.4;
        }

        /* ══════════ 融合場景 CSS ══════════ */
        #ecomScene {
            position: absolute;
            inset: 0;
            z-index: 3;
            pointer-events: none;
            overflow: hidden;
        }

        /* ── 3D 旋轉方塊（響應式） ── */
        :root {
            --cs: 220px; /* JS 會在每幀覆寫，此為首幀備用值 */
            --cf: calc(var(--cs) * 0.5);
            --cfo: calc(var(--cs) * 0.25);
            --ctz: calc(var(--cs) * 0.25);
            --cc: calc(var(--cs) * 0.18);
            --cco: calc((var(--cs) - var(--cc)) / 2);
        }

        .cube-scene {
            position: absolute;
            width: var(--cs);
            height: var(--cs);
            perspective: calc(var(--cs) * 4);
            pointer-events: none;
            /* JS 會動態設定 left / top */
        }

        .cube-wrapper {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            animation: rotateCube 22s linear infinite;
        }

        @@keyframes rotateCube {
            0% {
                transform: rotateX(-18deg) rotateY(0deg);
            }

            100% {
                transform: rotateX(-18deg) rotateY(360deg);
            }
        }

        .cube-face {
            position: absolute;
            width: var(--cf);
            height: var(--cf);
            top: var(--cfo);
            left: var(--cfo);
            background: rgba(0,176,116,.04);
            border: 1px solid rgba(0,176,116,.38);
            backdrop-filter: blur(3px);
            -webkit-backdrop-filter: blur(3px);
            box-shadow: inset 0 0 20px rgba(0,176,116,.08);
        }

        .face-front {
            transform: rotateY(0deg) translateZ(var(--ctz));
        }

        .face-back {
            transform: rotateY(180deg) translateZ(var(--ctz));
        }

        .face-right {
            transform: rotateY(90deg) translateZ(var(--ctz));
        }

        .face-left {
            transform: rotateY(-90deg) translateZ(var(--ctz));
        }

        .face-top {
            transform: rotateX(90deg) translateZ(var(--ctz));
            background: rgba(0,176,116,.09);
        }

        .face-bottom {
            transform: rotateX(-90deg) translateZ(var(--ctz));
        }

        .cube-core-dot {
            position: absolute;
            width: var(--cc);
            height: var(--cc);
            top: var(--cco);
            left: var(--cco);
            background: rgba(0,176,116,.85);
            border-radius: 50%;
            box-shadow: 0 0 calc(var(--cc)*.9) calc(var(--cc)*.35) rgba(0,176,116,.45);
            animation: pulseCore 3s ease-in-out infinite alternate;
        }

        @@keyframes pulseCore {
            0% {
                transform: scale(.78);
                opacity: .7;
            }

            100% {
                transform: scale(1.22);
                opacity: 1;
            }
        }
        /* 底部發光平台 */
        .cube-platform {
            position: absolute;
            left: 50%;
            bottom: 0;
            transform: translate(-50%, 60%);
            width: clamp(60px,8vw,140px);
            height: clamp(8px,1.2vh,20px);
            background: radial-gradient(ellipse at center, rgba(0,201,116,.38) 0%, transparent 70%);
            filter: blur(5px);
        }

        /* 連線 */
        .conn-line {
            position: absolute;
            height: 1px;
            transform-origin: 0 50%;
            pointer-events: none;
        }

        /* 衛星卡片共用 */
        .orbit-card {
            position: absolute;
            transform: translate(-50%,-50%);
            background: rgba(10,22,34,.75);
            border-radius: clamp(10px,1vw,16px);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(0,176,116,.28);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.14), inset 1px 0 0 rgba(255,255,255,.07), 0 8px 28px rgba(0,0,0,.45);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: clamp(3px,.4vw,7px);
            transition: box-shadow .5s ease;
        }

            .orbit-card.flicker {
                box-shadow: inset 0 1px 0 rgba(255,255,255,.24), inset 1px 0 0 rgba(255,255,255,.14), 0 8px 28px rgba(0,0,0,.45), 0 0 clamp(10px,1.4vw,20px) clamp(3px,.5vw,7px) rgba(0,201,116,.48);
            }

            .orbit-card .card-icon {
                color: #00C97A;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .orbit-card .card-label {
                color: rgba(255,255,255,.72);
                font-weight: 500;
                white-space: nowrap;
                font-family: 'Public Sans',sans-serif;
            }

        .card-hero {
            width: clamp(50px,6.5vw,142px);
            height: clamp(50px,5.3vw,122px);
            border-color: rgba(0,201,116,.50);
            z-index: 4;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.20), inset 1px 0 0 rgba(255,255,255,.10), 0 18px 50px rgba(0,0,0,.55), 0 0 clamp(12px,1.8vw,24px) rgba(0,201,116,.20);
        }

            .card-hero .card-icon {
                font-size: clamp(1.4rem,1.9vw,2.5rem);
            }

            .card-hero .card-label {
                font-size: clamp(.62rem,.70vw,.85rem);
            }

        .card-normal {
            width: clamp(62px,6.6vw,106px);
            height: clamp(54px,5.8vw,92px);
            z-index: 3;
        }

            .card-normal .card-icon {
                font-size: clamp(1.05rem,1.35vw,1.9rem);
            }

            .card-normal .card-label {
                font-size: clamp(.56rem,.60vw,.72rem);
            }

        .card-far {
            width: clamp(48px,4.8vw,78px);
            height: clamp(42px,4.4vw,70px);
            filter: blur(2px);
            opacity: .55;
            z-index: 2;
        }

            .card-far .card-icon {
                font-size: clamp(.85rem,1.05vw,1.45rem);
            }

            .card-far .card-label {
                display: none;
            }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Logo */
        .brand-logo {
            display: flex;
            align-items: center;
            gap: .75rem;
            position: relative;
            z-index: 2;
            animation: fadeInUp .6s ease both;
        }

        .brand-logo-icon {
            width: clamp(32px, 2.8vw, 44px);
            height: clamp(32px, 2.8vw, 44px);
            border-radius: 10px;
            background: linear-gradient(135deg, #F59E0B, #FBBF24);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 14px rgba(245,158,11,.35);
        }

            .brand-logo-icon i {
                font-size: clamp(1.1rem, 1.4vw, 1.5rem);
                color: #fff;
            }

        .brand-logo-text {
            font-size: clamp(1rem, 1.2vw, 1.35rem);
            font-weight: 700;
            color: #fff;
            letter-spacing: -.5px;
        }

        .brand-logo-badge {
            font-size: clamp(.58rem, .55vw, .65rem);
            font-weight: 600;
            color: #00B074;
            background: rgba(0,176,116,.15);
            border: 1px solid rgba(0,176,116,.3);
            border-radius: 4px;
            padding: 1px 6px;
            margin-left: .25rem;
        }

        /* 品牌主內容 */
        .brand-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            z-index: 6;
            padding: clamp(.75rem, 1.5vh, 2rem) 0;
            max-width: 52%;
        }

        .brand-tagline {
            font-size: clamp(.7rem, .75vw, .9rem);
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #00B074;
            margin-bottom: clamp(.6rem, 1.1vh, 1.25rem);
            animation: fadeInUp .6s ease .2s both;
        }

        .brand-title {
            font-size: clamp(1.6rem, 2.8vw, 3rem);
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
            margin-bottom: clamp(.5rem, .9vh, 1rem);
            animation: fadeInUp .6s ease .35s both;
            white-space: nowrap;
        }

            .brand-title span {
                background: linear-gradient(90deg, #00B074, #34d399);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .brand-subtitle {
            color: #8da8c0;
            font-size: clamp(.78rem, .82vw, 1rem);
            line-height: 1.7;
            max-width: 100%;
            margin-bottom: clamp(1rem, 2.2vh, 2.5rem);
            animation: fadeInUp .6s ease .5s both;
        }

        /* 日期時間顯示 */
        .datetime-wrap {
            display: flex;
            align-items: center;
            gap: clamp(.7rem, 1vw, 1.25rem);
            margin-bottom: clamp(.8rem, 1.8vh, 2rem);
            animation: fadeInUp .6s ease .58s both;
            white-space: nowrap;
            flex-wrap: nowrap;
        }

        .datetime-time {
            font-size: clamp(1.2rem, 1.9vw, 2.2rem);
            font-weight: 600;
            color: rgba(255,255,255,0.45);
            letter-spacing: clamp(1px, .25vw, 3px);
            line-height: 1;
            font-variant-numeric: tabular-nums;
            flex-shrink: 0;
        }

            .datetime-time .colon {
                display: inline-block;
                opacity: 0.4;
            }

        .datetime-divider {
            width: 1px;
            height: clamp(24px, 3vh, 40px);
            background: rgba(255,255,255,0.15);
            flex-shrink: 0;
        }

        .datetime-date {
            display: flex;
            flex-direction: column;
            gap: .25rem;
            flex-shrink: 0;
        }

            .datetime-date .date-row {
                font-size: clamp(.72rem, .75vw, .9rem);
                color: #a9c1d8;
                font-weight: 500;
                letter-spacing: .5px;
            }

            .datetime-date .week-row {
                font-size: clamp(.65rem, .68vw, .8rem);
                color: #00B074;
                font-weight: 600;
                letter-spacing: 1px;
            }

        /* 功能特色列表 */
        .feature-list {
            display: flex;
            flex-direction: column;
            gap: clamp(.7rem, 1.4vh, 1.2rem);
            animation: fadeInUp .6s ease .65s both;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: clamp(.6rem,.8vw,.9rem);
        }

        .feature-icon {
            width: clamp(28px,2.5vw,38px);
            height: clamp(28px,2.5vw,38px);
            border-radius: 9px;
            background: rgba(0,176,116,.1);
            border: 1px solid rgba(0,201,116,.30);
            box-shadow: 0 0 8px rgba(0,201,116,.12);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .feature-icon i {
                color: #00D484;
                font-size: clamp(.85rem,.9vw,1.1rem);
            }

        .feature-text {
            font-size: clamp(.74rem,.78vw,.88rem);
            color: #a9c1d8;
            line-height: 1.5;
        }

            .feature-text strong {
                color: #d1e8f5;
                font-weight: 600;
            }

        /* 底部版權 */
        .brand-footer {
            position: relative;
            z-index: 2;
            color: #4a6a85;
            font-size: clamp(.68rem, .7vw, .78rem);
            animation: fadeInUp .6s ease .8s both;
        }

        /* ══════════ 右側表單區 ══════════ */
        .form-side {
            flex: 1;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            animation: slideInRight .55s ease .1s both;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 400px;
        }

        .form-header {
            margin-bottom: 2.25rem;
        }

            .form-header h2 {
                font-size: 1.75rem;
                font-weight: 700;
                color: #1e293b;
                margin: 0 0 .4rem;
            }

            .form-header p {
                color: #64748b;
                font-size: .93rem;
                margin: 0;
            }

        /* 錯誤訊息框 */
        .login-error-box {
            display: flex;
            align-items: flex-start;
            gap: .6rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: .85rem 1rem;
            margin-bottom: 1.5rem;
            color: #dc2626;
            font-size: .88rem;
            line-height: 1.5;
            animation: fadeInUp .3s ease both;
        }

            .login-error-box i {
                font-size: 1.1rem;
                flex-shrink: 0;
                margin-top: 1px;
            }

        /* 輸入框組 */
        .input-group-wrap {
            margin-bottom: 1.25rem;
        }

            .input-group-wrap label {
                display: block;
                font-size: .85rem;
                font-weight: 600;
                color: #374151;
                margin-bottom: .45rem;
            }

        .input-field-wrap {
            position: relative;
        }

            .input-field-wrap .input-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #9ca3af;
                font-size: 1.1rem;
                pointer-events: none;
                transition: color .25s;
            }

            .input-field-wrap input {
                width: 100%;
                padding: .72rem 1rem .72rem 2.8rem;
                border: 1.5px solid #e5e7eb;
                border-radius: 10px;
                font-size: .93rem;
                font-family: inherit;
                color: #1e293b;
                background: #f9fafb;
                transition: border-color .25s, box-shadow .25s, background .25s;
                outline: none;
            }

                .input-field-wrap input:focus {
                    border-color: #00B074;
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(0,176,116,.12);
                }

            .input-field-wrap:focus-within .input-icon {
                color: #00B074;
            }

        /* 密碼顯示/隱藏按鈕 */
        .pwd-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #9ca3af;
            font-size: 1.1rem;
            padding: 4px;
            display: flex;
            transition: color .2s;
        }

            .pwd-toggle:hover {
                color: #00B074;
            }

        /* 記住我 + 忘記密碼 */
        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.75rem;
        }

        .checkbox-wrap {
            display: flex;
            align-items: center;
            gap: .5rem;
            cursor: pointer;
        }

            .checkbox-wrap input[type="checkbox"] {
                width: 16px;
                height: 16px;
                accent-color: #00B074;
                cursor: pointer;
            }

            .checkbox-wrap span {
                font-size: .875rem;
                color: #4b5563;
                user-select: none;
            }

        .forgot-link {
            font-size: .875rem;
            color: #00B074;
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }

            .forgot-link:hover {
                color: #059669;
                text-decoration: underline;
            }

        /* 登入按鈕 */
        .btn-login {
            width: 100%;
            padding: .82rem 1.5rem;
            background: linear-gradient(135deg, #00B074, #059669);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: transform .2s ease, box-shadow .2s ease;
            box-shadow: 0 4px 14px rgba(0,176,116,.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            position: relative;
            overflow: hidden;
        }

            .btn-login:hover {
                transform: scale(1.02);
                box-shadow: 0 6px 20px rgba(0,176,116,.45);
            }

            .btn-login:active {
                transform: scale(0.99);
            }

            .btn-login:disabled {
                opacity: .75;
                cursor: not-allowed;
                transform: none;
            }

        /* Loading Spinner */
        .btn-spinner {
            display: none;
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
        }

        .btn-login.loading .btn-text {
            display: none;
        }

        .btn-login.loading .btn-spinner {
            display: block;
        }

        /* 快速填入測試帳號按鈕 */
        .btn-quick-fill {
            width: 100%;
            margin-top: .75rem;
            padding: .6rem 1rem;
            background: transparent;
            color: #9ca3af;
            border: 1.5px dashed #d1d5db;
            border-radius: 10px;
            font-size: .82rem;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            transition: border-color .2s, color .2s, background .2s;
        }

            .btn-quick-fill:hover {
                border-color: #00B074;
                color: #00B074;
                background: rgba(0,176,116,.04);
            }

            .btn-quick-fill i {
                font-size: .9rem;
            }

        /* 底部小字 */
        .form-footer {
            text-align: center;
            margin-top: 1.75rem;
            color: #9ca3af;
            font-size: .8rem;
        }

        /* ══════════ RWD ══════════ */
        @@media (max-width: 900px) {
            .brand-side {
                display: none;
            }

            .form-side {
                background: linear-gradient(160deg, #f0fdf8 0%, #ecfdf5 100%);
                animation: fadeInUp .5s ease both;
            }

            .login-form-wrap {
                max-width: 420px;
            }
        }

        @@media (max-width: 480px) {
            .form-side {
                padding: 2rem 1.25rem;
            }

            .form-header h2 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">

        <!-- ══ 左側品牌區 ══ -->
        <div class="brand-side">

            <!-- 背景層：網格 + 光暈 -->
            <div class="bg-grid"></div>
            <div class="bg-glow bg-glow-1"></div>
            <div class="bg-glow bg-glow-2"></div>

            <!-- ══ 融合場景：方塊核心 + 衛星卡片 ══ -->
            <div id="ecomScene">
                <canvas id="bgCanvas"></canvas>

                <!-- 3D 旋轉方塊（由 JS 定位） -->
                <div class="cube-scene" id="cubeScene">
                    <div class="cube-wrapper">
                        <div class="cube-core-dot"></div>
                        <div class="cube-face face-front"></div>
                        <div class="cube-face face-back"></div>
                        <div class="cube-face face-right"></div>
                        <div class="cube-face face-left"></div>
                        <div class="cube-face face-top"></div>
                        <div class="cube-face face-bottom"></div>
                    </div>
                    <div class="cube-platform"></div>
                </div>
            </div>

            <!-- Logo -->
            <div class="brand-logo">
                <div class="brand-logo-icon">
                    <i class="bx bx-store-alt"></i>
                </div>
                <span class="brand-logo-text">ISpanShop</span>
                <span class="brand-logo-badge">Admin</span>
            </div>

            <!-- 主要內容 -->
            <div class="brand-content">
                <div class="brand-tagline">Management System</div>
                <h1 class="brand-title">
                    歡迎回來<br />
                    <span> HowBuy 後台管理中心</span>
                </h1>
                <p class="brand-subtitle">
                    安全、穩定的電商協作環境。請登入以存取您的工作區域，我們將依據您的角色權限提供對應的功能服務。
                </p>

                <!-- 日期時間 -->
                <div class="datetime-wrap">
                    <div class="datetime-time" id="dtTime">
                        <span id="dtH">00</span><span class="colon">:</span><span id="dtM">00</span><span class="colon">:</span><span id="dtS">00</span>
                    </div>
                    <div class="datetime-divider"></div>
                    <div class="datetime-date">
                        <div class="date-row" id="dtDate">2026 / 01 / 01</div>
                        <div class="week-row" id="dtWeek">星期一</div>
                    </div>
                </div>

                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-shield-quarter"></i></div>
                        <div class="feature-text">
                            <strong>安全存取</strong><br />嚴密的身份驗證與權限管控機制
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-server"></i></div>
                        <div class="feature-text">
                            <strong>穩定可靠</strong><br />高可用性架構，確保服務持續運行
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-tachometer"></i></div>
                        <div class="feature-text">
                            <strong>高效協作</strong><br />依角色授權，讓每位成員聚焦本職
                        </div>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="bx bx-lock-open-alt"></i></div>
                        <div class="feature-text">
                            <strong>隱私合規</strong><br />操作記錄全程留存，行為可追溯
                        </div>
                    </div>
                </div>
            </div>

            <!-- 版權 -->
            <div class="brand-footer">
                &copy; 2026 ISpanShop. All rights reserved.
            </div>
        </div>

        <!-- ══ 右側登入表單區（完全不動）══ -->
        <div class="form-side">
            <div class="login-form-wrap">
                <!-- 表頭 -->
                <div class="form-header">
                    <h2>登入後台</h2>
                    <p>請輸入您的帳號及密碼以繼續</p>
                </div>

                <!-- 錯誤訊息 -->
                @if (!ViewData.ModelState.IsValid)
                {
                    var errors = ViewData.ModelState.Values
                    .SelectMany(v => v.Errors)
                    .Select(e => e.ErrorMessage)
                    .ToList();
                    if (errors.Any())
                    {
                        <div class="login-error-box">
                            <i class="bx bx-error-circle"></i>
                            <div>@string.Join(" ", errors)</div>
                        </div>
                    }
                }

                <!-- 表單 -->
                <form asp-area="Admin" asp-controller="Auth" asp-action="Login" method="post" id="loginForm">
                    @Html.AntiForgeryToken()
                    @if (ViewData["ReturnUrl"] != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    }

                    <!-- 帳號 -->
                    <div class="input-group-wrap">
                        <label asp-for="Account">帳號</label>
                        <div class="input-field-wrap">
                            <i class="bx bx-user input-icon"></i>
                            <input asp-for="Account"
                                   type="text"
                                   placeholder="請輸入管理員帳號"
                                   autocomplete="username" />
                        </div>
                    </div>

                    <!-- 密碼 -->
                    <div class="input-group-wrap">
                        <label asp-for="Password">密碼</label>
                        <div class="input-field-wrap">
                            <i class="bx bx-lock-alt input-icon"></i>
                            <input asp-for="Password"
                                   id="passwordInput"
                                   type="password"
                                   placeholder="請輸入密碼"
                                   autocomplete="current-password" />
                            <button type="button" class="pwd-toggle" id="pwdToggleBtn" tabindex="-1" title="顯示/隱藏密碼">
                                <i class="bx bx-hide" id="pwdToggleIcon"></i>
                            </button>
                        </div>
                    </div>

                    <!-- 記住我 + 忘記密碼 -->
                    <div class="form-options">
                        <label class="checkbox-wrap">
                            <input asp-for="RememberMe" type="checkbox" />
                            <span>記住我</span>
                        </label>
                        <a href="javascript:void(0);" class="forgot-link" id="forgotPwdLink">忘記密碼？</a>
                    </div>

                    <!-- 登入按鈕 -->
                    <button type="submit" class="btn-login" id="loginBtn">
                        <span class="btn-text">
                            <i class="bx bx-log-in-circle"></i>
                            登入後台
                        </span>
                        <span class="btn-spinner"></span>
                    </button>

                    <!-- 快速填入測試帳號 -->
                    <button type="button" class="btn-quick-fill" id="quickFillBtn">
                        <i class="bx bx-fill"></i>
                        快速填入測試帳號
                    </button>
                </form>

                <div class="form-footer">
                    © 2026 ISpanShop 後台管理系統
                </div>
            </div>
        </div>
    </div>

    <script>
        // ══════════ 融合場景：方塊核心 + 定錨浮動衛星卡片 ══════════
        (function () {
            var brandSide = document.querySelector('.brand-side');
            var scene     = document.getElementById('ecomScene');
            var canvas    = document.getElementById('bgCanvas');
            var ctx       = canvas.getContext('2d');
            var cubeScene = document.getElementById('cubeScene');

            // 衛星卡片定義
            // anchor: 相對方塊中心的偏移比例 [dx倍rate, dy倍rate]
            // floatPhase / floatAmp: 各自獨立的漂浮節奏
            var CARDS = [
                { bxIcon:'bx-package',      label:'包裹訂單', type:'hero',   anchor:[ 0.8, -1.1], floatPhase:0,   floatAmp:10, floatSpeed:0.85 },  // 右上
                { bxIcon:'bx-street-view',  label:'人員管理',   type:'normal', anchor:[ 1.2,  0.2], floatPhase:1.8, floatAmp:8,  floatSpeed:0.70 },  // 正右
                { bxIcon:'bx-credit-card',  label:'金流結算', type:'normal', anchor:[ 1.3,  1.2], floatPhase:3.2, floatAmp:9,  floatSpeed:0.95 },  // 右下
                { bxIcon:'bx-purchase-tag', label:'商品標籤', type:'far',    anchor:[ 1.5, -0.4], floatPhase:4.8, floatAmp:12, floatSpeed:0.58 },  // 遠右上（景深）
                { bxIcon:'bx-layer',        label:'商品庫存', type:'normal', anchor:[-0.75, -1.25], floatPhase:2.5, floatAmp:11, floatSpeed:0.75 },  // 左上
                { bxIcon:'bx-support',      label:'客服中心', type:'normal', anchor:[-0.40,  1.00], floatPhase:5.1, floatAmp:9,  floatSpeed:0.88 }

                ];
      
            // 建立卡片 & 連線 DOM
            var cardEls = [], lineEls = [];
            CARDS.forEach(function (c) {
                var el = document.createElement('div');
                el.className = 'orbit-card card-' + c.type;
                el.innerHTML = '<i class="bx ' + c.bxIcon + ' card-icon"></i>' +
                               (c.type !== 'far' ? '<span class="card-label">' + c.label + '</span>' : '');
                scene.appendChild(el);
                cardEls.push(el);

                var ln = document.createElement('div');
                ln.className = 'conn-line';
                scene.appendChild(ln);
                lineEls.push(ln);
            });

            // 粒子
            var PTCL_COUNT = 38;
            var ptcls = [];
            function resetPtcl(p) {
                var sw = brandSide.offsetWidth, sh = brandSide.offsetHeight;
                p.x    = Math.random() * sw;
                p.y    = sh + Math.random() * 20;
                p.vy   = 0.4 + Math.random() * 0.9;
                p.vx   = (Math.random() - 0.5) * 0.4;
                p.r    = 1 + Math.random() * 2.2;
                p.life = 0;
                p.maxL = 180 + Math.random() * 200;
                p.flicker = false;
            }
            for (var pi = 0; pi < PTCL_COUNT; pi++) {
                var p = {};
                resetPtcl(p);
                p.y = Math.random() * brandSide.offsetHeight;
                ptcls.push(p);
            }

            // 資料流
            var DATA_COLS = [];
            function initDataCols() {
                DATA_COLS = [];
                var sw = brandSide.offsetWidth;
                var cols = Math.floor(sw / 16);
                for (var ci = 0; ci < cols; ci++) {
                    DATA_COLS.push({
                        x: ci * 16 + 8,
                        y: Math.random() * brandSide.offsetHeight,
                        speed: 0.5 + Math.random() * 1.2,
                        chars: '0123456789ABCDEF#@@$%',
                        cur: Math.floor(Math.random() * 20),
                    });
                }
            }
            initDataCols();

            function resize() {
                canvas.width  = brandSide.offsetWidth;
                canvas.height = brandSide.offsetHeight;
                initDataCols();
            }
            resize();
            window.addEventListener('resize', resize);

            function setConnLine(ln, x1, y1, x2, y2) {
                var dx = x2 - x1, dy = y2 - y1;
                var len = Math.sqrt(dx*dx + dy*dy);
                var ang = Math.atan2(dy, dx) * 180 / Math.PI;
                ln.style.cssText =
                    'left:' + x1 + 'px;top:' + y1 + 'px;width:' + len + 'px;' +
                    'transform:rotate(' + ang + 'deg);' +
                    'background:linear-gradient(to right,rgba(0,201,116,.28),rgba(0,201,116,.02));';
            }

            var t = 0;

            function loop() {
                var sw = brandSide.offsetWidth, sh = brandSide.offsetHeight;
                t += 0.016;

                // ── 方塊尺寸：由 JS 計算，同步寫回 CSS 變數確保 cube DOM 一致 ──
                // 等同 clamp(160px, 18vw, 320px) 但改用 brandSide 寬度比例
                var cubeSize = Math.min(Math.max(140, sw * 0.30), 300);
                document.documentElement.style.setProperty('--cs', cubeSize + 'px');

                // 方塊中心（以 brand-side 內座標）
                var cx = sw * 0.58, cy = sh * 0.60;
                cubeScene.style.left = (cx - cubeSize / 2) + 'px';
                cubeScene.style.top  = (cy - cubeSize / 2) + 'px';

                // ── 衛星卡片：以同一個 cx/cy 為原點散開 ──
                var rate = cubeSize * 0.75;
                var cardPositions = [];
                CARDS.forEach(function (c, i) {
                    var bobY = Math.sin(t * c.floatSpeed + c.floatPhase) * c.floatAmp;
                    var bobX = Math.cos(t * c.floatSpeed * 0.6 + c.floatPhase) * (c.floatAmp * 0.35);
                    var x = cx + c.anchor[0] * rate + bobX;
                    var y = cy + c.anchor[1] * rate + bobY;
                    cardEls[i].style.left = x + 'px';
                    cardEls[i].style.top  = y + 'px';
                    setConnLine(lineEls[i], cx, cy, x, y);
                    cardPositions.push({ x: x, y: y });
                });

                // ── Canvas：資料流 + 粒子 ──
                ctx.clearRect(0, 0, sw, sh);

                ctx.font = '10px monospace';
                DATA_COLS.forEach(function (col) {
                    col.y += col.speed;
                    if (col.y > sh + 20) col.y = -16;
                    col.cur = (col.cur + (Math.random() > 0.92 ? 1 : 0)) % col.chars.length;
                    ctx.fillStyle = 'rgba(0,201,116,0.055)';
                    ctx.fillText(col.chars[col.cur], col.x, col.y);
                });

                ptcls.forEach(function (p) {
                    p.x += p.vx; p.y -= p.vy; p.life++;
                    if (p.life > p.maxL || p.y < -10) resetPtcl(p);

                    p.flicker = false;
                    cardPositions.forEach(function (cp, ci) {
                        var dx = p.x - cp.x, dy = p.y - cp.y;
                        if (Math.sqrt(dx*dx + dy*dy) < 36) {
                            p.flicker = true;
                            if (!cardEls[ci]._flk) {
                                cardEls[ci].classList.add('flicker');
                                cardEls[ci]._flk = true;
                                setTimeout(function(el){ el.classList.remove('flicker'); el._flk = false; }
                                    .bind(null, cardEls[ci]), 280);
                            }
                        }
                    });

                    var alpha = Math.sin((p.life / p.maxL) * Math.PI) * (p.flicker ? 1 : 0.65);
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.r * (p.flicker ? 1.6 : 1), 0, Math.PI * 2);
                    ctx.fillStyle = p.flicker
                        ? 'rgba(0,228,140,' + alpha + ')'
                        : 'rgba(0,176,116,' + alpha + ')';
                    ctx.fill();
                });

                requestAnimationFrame(loop);
            }
            loop();
        })();

        // 即時時鐘
        (function () {
            var weeks = ['星期日','星期一','星期二','星期三','星期四','星期五','星期六'];
            function pad(n) { return String(n).padStart(2, '0'); }
            function tick() {
                var now  = new Date();
                var y    = now.getFullYear();
                var mo   = pad(now.getMonth() + 1);
                var d    = pad(now.getDate());
                document.getElementById('dtH').textContent    = pad(now.getHours());
                document.getElementById('dtM').textContent    = pad(now.getMinutes());
                document.getElementById('dtS').textContent    = pad(now.getSeconds());
                document.getElementById('dtDate').textContent = y + ' / ' + mo + ' / ' + d;
                document.getElementById('dtWeek').textContent = weeks[now.getDay()];
            }
            tick();
            setInterval(tick, 1000);
        })();


        (function () {
            var input = document.getElementById('passwordInput');
            var btn   = document.getElementById('pwdToggleBtn');
            var icon  = document.getElementById('pwdToggleIcon');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var isHidden = input.type === 'password';
                input.type = isHidden ? 'text' : 'password';
                icon.className = isHidden ? 'bx bx-show' : 'bx bx-hide';
            });
        })();

        // 快速填入測試帳號
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('quickFillBtn');
            var accountInput = document.querySelector('input[name="Account"]');
            var passwordInput = document.getElementById('passwordInput');

            if (!btn || !accountInput || !passwordInput) return;

            btn.addEventListener('click', function () {
                accountInput.value = 'admin';
                passwordInput.value = 'Test123456';

                // 手動觸發 input 事件以確保瀏覽器或自訂腳本感應到變更
                accountInput.dispatchEvent(new Event('input', { bubbles: true }));
                passwordInput.dispatchEvent(new Event('input', { bubbles: true }));

                // 視覺反饋：短暫改變按鈕樣式
                var originalText = btn.innerHTML;
                btn.innerHTML = '<i class="bx bx-check"></i> 已填入';
                btn.style.color = '#00B074';
                btn.style.borderColor = '#00B074';
                setTimeout(function() {
                    btn.innerHTML = originalText;
                    btn.style.color = '';
                    btn.style.borderColor = '';
                }, 1000);
            });
        });

        (function () {
            var forgotLink = document.getElementById('forgotPwdLink');
            var form = document.getElementById('loginForm');
            if (!forgotLink || !form) return;

            forgotLink.addEventListener('click', function (e) {
                e.preventDefault();
                
                // 清除既有的錯誤訊息
                var existingErr = document.querySelector('.login-error-box.js-err');
                if (existingErr) existingErr.remove();

                // 建立新的提示框 (與錯誤訊息同樣式)
                var infoBox = document.createElement('div');
                infoBox.className = 'login-error-box js-err';
                infoBox.style.background = '#f0fdf4'; // 改為淡綠色背景表示提示
                infoBox.style.borderColor = '#bbf7d0';
                infoBox.style.color = '#166534';
                infoBox.innerHTML =
                    '<i class="bx bx-info-circle"></i>' +
                    '<div>請聯繫超級管理員以進行密碼重設。</div>';
                
                form.insertBefore(infoBox, form.firstChild);
            });
        })();

        // 前端驗證 + Loading 狀態
        (function () {
            var form       = document.getElementById('loginForm');
            var loginBtn   = document.getElementById('loginBtn');
            var accountEl  = document.querySelector('input[name="Account"]');
            var passwordEl = document.getElementById('passwordInput');

            form.addEventListener('submit', function (e) {
                var account  = (accountEl.value  || '').trim();
                var password = (passwordEl.value || '').trim();

                var existingErr = document.querySelector('.login-error-box.js-err');
                if (existingErr) existingErr.remove();

                if (!account || !password) {
                    e.preventDefault();
                    var errBox = document.createElement('div');
                    errBox.className = 'login-error-box js-err';
                    errBox.innerHTML =
                        '<i class="bx bx-error-circle"></i>' +
                        '<div>' + (!account ? '請輸入帳號' : '請輸入密碼') + '</div>';
                    form.insertBefore(errBox, form.firstChild);
                    (!account ? accountEl : passwordEl).focus();
                    return;
                }

                loginBtn.classList.add('loading');
                loginBtn.disabled = true;
            });
        })();
    </script>
</body>
</html>
