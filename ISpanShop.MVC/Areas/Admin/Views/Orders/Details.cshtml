@model ISpanShop.MVC.Areas.Admin.Models.Orders.OrderDetailsVm
@using ISpanShop.Common.Enums

@{
    ViewData["Title"] = "訂單明細 - " + Model.Order.OrderNumber;

    // 定義狀態樣式
    var statusCss = Model.Order.Status switch
    {
        OrderStatus.Pending => "bg-label-warning",
        OrderStatus.Processing => "bg-label-info",
        OrderStatus.Shipped => "bg-label-primary",
        OrderStatus.Completed => "bg-label-success",
        OrderStatus.Cancelled => "bg-label-secondary",
        _ => "bg-label-dark"
    };
}

@section Styles {
    <style>
        .badge-soft { 
            padding: .45em .85em; 
            border-radius: 6px; 
            font-size: .82rem; 
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            letter-spacing: 0.5px;
        }
        
        /* 待付款 - 琥珀色 */
        .bg-label-warning { background: #FFFBE6 !important; color: #D48806 !important; border: 1px solid #FFE58F; }
        
        /* 待出貨 (已付款) - 青綠色 */
        .bg-label-info { background: #E6FFFB !important; color: #08979C !important; border: 1px solid #87E8DE; }
        
        /* 運送中 - 品牌藍 */
        .bg-label-primary { background: #F0F5FF !important; color: #2F54EB !important; border: 1px solid #ADC6FF; }
        
        /* 已完成 - 森林綠 */
        .bg-label-success { background: #F6FFED !important; color: #52C41A !important; border: 1px solid #B7EB8F; }
        
        /* 已取消 - 玫瑰紅 */
        .bg-label-secondary { background: #FFF1F0 !important; color: #F5222D !important; border: 1px solid #FFA39E; }
        
        .bg-label-dark { background: #F5F5F5 !important; color: #8C8C8C !important; border: 1px solid #D9D9D9; }
    </style>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bx bx-receipt me-2 text-primary"></i>訂單明細: @Model.Order.OrderNumber</h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bx bx-arrow-back me-1"></i>返回列表
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3">
            <i class="bx bx-check-circle me-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- 訂單基本資訊 -->
        <div class="col-md-8">
            <div class="card mb-4 border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark">基本資訊</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <p class="mb-2"><span class="text-muted small text-uppercase fw-bold">客戶帳號:</span><br /> @Model.Order.UserName</p>
                            <p class="mb-2">
                                <span class="text-muted small text-uppercase fw-bold">下單時間:</span><br /> 
                                <span class="text-dark">@Model.Order.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss")</span>
                            </p>
                            <p class="mb-2">
                                <span class="text-muted small text-uppercase fw-bold">付款時間:</span><br /> 
                                @if (Model.Order.PaymentDate.HasValue)
                                {
                                    <span class="text-dark">@Model.Order.PaymentDate.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                }
                                else
                                {
                                    <span class="text-muted small">尚未付款</span>
                                }
                            </p>
                            <p class="mb-2">
                                <span class="text-muted small text-uppercase fw-bold">完成時間:</span><br /> 
                                @if (Model.Order.CompletedAt.HasValue)
                                {
                                    <span class="text-dark">@Model.Order.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                }
                                else
                                {
                                    <span class="text-muted small">尚未完成</span>
                                }
                            </p>
                            <p class="mb-0">
                                <span class="text-muted small text-uppercase fw-bold d-block mb-1">目前狀態:</span>
                                <span class="badge-soft @statusCss">@Model.Order.Status.GetDisplayName()</span>
                            </p>
                        </div>
                        <div class="col-6">
                            <p><strong>收件人:</strong> @Model.Order.RecipientName</p>
                            <p><strong>收件電話:</strong> @Model.Order.RecipientPhone</p>
                            <p><strong>收件地址:</strong> @Model.Order.RecipientAddress</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 商品明細 -->
            <div class="card">
                <div class="card-header bg-dark text-white">商品明細</div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>商品</th>
                                <th>規格</th>
                                <th class="text-end">單價</th>
                                <th class="text-center">數量</th>
                                <th class="text-end">小計</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Order.Details)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.VariantName</td>
                                    <td class="text-end">@item.Price.ToString("C0")</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.SubTotal.ToString("C0")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end"><strong>總計:</strong></td>
                                <td class="text-end text-danger"><strong>@Model.Order.FinalAmount.ToString("C0")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- 狀態修改區 -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-warning">修改訂單狀態</div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Order.Id" />
                        <div class="mb-3">
                            <label class="form-label">選擇新狀態</label>
                            <select name="status" class="form-select">
                                @foreach (var status in Enum.GetValues(typeof(OrderStatus)).Cast<OrderStatus>())
                                {
                                    <option value="@((byte)status)" selected="@(Model.Order.Status == status)">@status.GetDisplayName()</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" onclick="return confirm('確定要修改狀態嗎?')">更新狀態</button>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">備註</div>
                <div class="card-body">
                    <p class="text-muted">@(string.IsNullOrEmpty(Model.Order.Note) ? "無備註" : Model.Order.Note)</p>
                </div>
            </div>
        </div>
    </div>
</div>