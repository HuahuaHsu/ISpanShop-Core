                                name: { show: false },
                                value: {
                                    offsetY: 10,
                                    fontSize: '32px',
                                    color: data.growthRate >= 0 ? '#ff3e1d' : '#71dd37',
                                    fontWeight: 'bold',
                                    formatter: () => (data.growthRate > 0 ? '+' : '') + data.growthRate + '%'
                                }
                            }
                        }
                    },
                    fill: {
                        type: 'gradient',
                        gradient: {
                            shade: 'dark',
                            type: 'horizontal',
                            shadeIntensity: 0.5,
                            gradientToColors: [data.growthRate >= 0 ? '#ffab00' : '#03c3ec'], // 成長用紅橘漸層，衰退用綠藍漸層
                            inverseColors: true,
                            opacityFrom: 1,
                            opacityTo: 1,
                            stops: [0, 100]
                        }
                    },
                    stroke: { 
                        lineCap: 'round'
                    },
                    colors: [data.growthRate >= 0 ? '#ff3e1d' : '#71dd37'], // 成長紅 / 衰退綠
                    labels: ['Growth']
                };

                if (growthGaugeChart) growthGaugeChart.destroy();
                growthGaugeChart = new ApexCharts(document.querySelector("#growthGaugeChart"), radialOptions);
                growthGaugeChart.render();

                // 3. 載入成長動因瀑布圖 (Growth Bridge)
                loadGrowthBridgeChart(y1, y2, storeId);

                // 4. 載入類別月度消長趨勢圖 (Line Chart)
                loadCategoryDeltaTrend(y1, y2, storeId);

            }).fail(function(err) {
                console.error("Year Comparison Chart failed:", err);
            });
        }

        function loadGrowthBridgeChart(y1, y2, storeId) {
            $.get(`/Orders/GetGrowthBridgeData?year1=${y1}&year2=${y2}&storeId=${storeId}`, function(data) {
                if (!data || data.length === 0) return;

                // 1. 計算總量與排序
                const totalYear2Revenue = data.reduce((sum, item) => sum + (item.v2 || 0), 0) || 1;
                const totalDelta = data.reduce((sum, item) => sum + item.y, 0);
                
                // 數據排序：從增長最多到衰退最多
                data.sort((a, b) => b.y - a.y);

                // 2. 準備數據 (僅保留各類別變動)
                const seriesData = data.map(item => {
                    const contributionPercent = (item.y / totalYear2Revenue) * 100;
                    return {
                        x: item.x,
                        y: item.y,
                        percent: contributionPercent,
                        color: item.y >= 0 ? '#ff3e1d' : '#71dd37' // 台灣股市：成長紅 / 衰退綠
                    };
                });

                const options = {
                    series: [{
                        name: '營收變動',
                        data: seriesData
                    }],
                    chart: {
                        type: 'bar',
                        height: 450,
                        toolbar: { show: false },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    plotOptions: {
                        bar: {
                            horizontal: false,
                            columnWidth: '60%',
                            distributed: true,
                            borderRadius: 4,
                            dataLabels: { position: 'top' }
                        }
                    },
                    colors: seriesData.map(d => d.color),
                    dataLabels: {
                        enabled: true,
                        formatter: function(val) {
                            return (val > 0 ? '+' : '') + '$' + Math.abs(Math.round(val)).toLocaleString();
                        },
                        style: {
                            fontSize: '11px',
                            fontWeight: '600',
                            colors: ['#566a7f']
                        },
                        offsetY: -20
                    },
                    xaxis: {
                        type: 'category',
                        labels: {
                            rotate: -45,
                            style: { fontSize: '12px' }
                        }
                    },
                    yaxis: {
                        labels: {
                            formatter: function(val) {
                                return (val > 0 ? '+' : '') + '$' + Math.round(val).toLocaleString();
                            },
                            style: { fontSize: '11px' }
                        }
                    },
                    grid: {
                        xaxis: { lines: { show: false } },
                        yaxis: { lines: { show: true } }
                    },
                    legend: { show: false },
                    tooltip: {
                        shared: true,
                        intersect: false,
                        y: {
                            formatter: function(val, { dataPointIndex, w }) {
                                // 由於 shared: true，val 會是當前點的數值
                                const item = w.config.series[0].data[dataPointIndex];
                                if (!item) return '';
                                const label = val >= 0 ? '營收增加 ' : '營收減少 ';
                                return `${label} $${Math.abs(val).toLocaleString()} (${item.percent.toFixed(2)}%)`;
                            }
                        }
                    },
                    annotations: {
                        yaxis: [{
                            y: 0,
                            borderColor: '#8592a3',
                            strokeDashArray: 0,
                            borderWidth: 1
                        }]
                    }
                };

                // 更新標題旁的總淨額標籤 (保留邏輯)
                const totalGrowthPercent = (totalDelta / totalYear2Revenue) * 100;
                const totalText = (totalDelta >= 0 ? '總體成長 ' : '總體衰退 ') + totalGrowthPercent.toFixed(1) + '% ($' + Math.abs(totalDelta).toLocaleString() + ')';
                const totalBadgeClass = totalDelta >= 0 ? 'bg-label-danger' : 'bg-label-success';
                
                $('#bridgeTotalBadge').remove();
                $('#growthBridgeYearLabel').after(`<span class="badge ${totalBadgeClass} ms-2 fw-bold" id="bridgeTotalBadge">${totalText}</span>`);

                if (growthBridgeChart) growthBridgeChart.destroy();
                growthBridgeChart = new ApexCharts(document.querySelector("#growthBridgeChart"), options);
                growthBridgeChart.render();
            });
        }

        function loadCategoryDeltaTrend(y1, y2, storeId) {
            $.get(`/Orders/GetCategoryMonthlyGrowth?year1=${y1}&year2=${y2}&storeId=${storeId}`, function(data) {
                if (!data || data.length === 0) return;

                const trendSeries = data.map(item => ({
                    name: item.categoryName,
                    data: item.monthlyGrowthRates
                }));

                // 動態計算所有數據點中的最大與最小值
                let allPoints = [];
                trendSeries.forEach(s => allPoints.push(...s.data));
                const maxPoint = Math.max(...allPoints);
                const minPoint = Math.min(...allPoints);

                // 設定以 10% 為單位的刻度邏輯
                const yMin = Math.floor(minPoint / 10) * 10 - 10; // 向下取 10 的倍數並多給一格緩衝
                const yMax = Math.ceil(maxPoint / 10) * 10 + 10;  // 向上取 10 的倍數並多給一格緩衝
                const tickAmount = (yMax - yMin) / 10;

                const options = {
                    series: trendSeries,
                    chart: {
                        height: 450,
                        type: 'line',
                        toolbar: { 
                            show: false 
                        },
                        zoom: {
                            enabled: true,
                            type: 'x',
                            autoScaleYaxis: true
                        },
                        panning: {
                            enabled: true
                        },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    colors: data.map(item => getCategoryColor(item.categoryName)),
                    stroke: {
                        width: 4,
                        curve: 'straight',
                        lineCap: 'round'
                    },
                    legend: {
                        position: 'top',
                        horizontalAlign: 'center',
                        onItemHover: { highlightDataSeries: true }
                    },
                    markers: {
                        size: 6,
                        hover: { size: 9 }
                    },
                    annotations: {
                        yaxis: [{
                            y: 0,
                            borderColor: '#8592a3',
                            strokeDashArray: 0
                        }]
                    },
                    xaxis: {
                        categories: ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月']
                    },
                    yaxis: {
                        min: yMin,
                        max: yMax,
                        tickAmount: tickAmount,
                        forceNiceScale: false,
                        labels: {
                            formatter: (val) => (val > 0 ? '+' : '') + Math.round(val) + '%'
                        }
                    },
                    tooltip: {
                        shared: false,
                        intersect: true,
                        y: {
                            formatter: function(val, { seriesIndex, dataPointIndex, w }) {
                                const categoryData = data[seriesIndex];
                                const revenueDelta = categoryData.monthlyRevenueDeltas[dataPointIndex];
                                
                                let text = (val >= 0 ? '市佔擴張 ' : '市佔萎縮 ') + Math.abs(val).toFixed(2) + '%';
                                text += ' | ' + (revenueDelta >= 0 ? '營收增加 ' : '營收減少 ') + '$' + Math.abs(revenueDelta).toLocaleString();
                                return text;
                            }
                        }
                    }
                };

                if (deltaTrendChart) deltaTrendChart.destroy();
                deltaTrendChart = new ApexCharts(document.querySelector("#categoryDeltaLineChart"), options);
                deltaTrendChart.render();
            });
        }
    </script>
}