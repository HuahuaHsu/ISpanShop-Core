@model ISpanShop.MVC.Areas.Admin.Models.Orders.OrderDashboardVm
@{
    ViewData["Title"] = "訂單分析儀表板";
}

@section Styles {
    <link rel="stylesheet" href="~/sneat/assets/vendor/libs/apex-charts/apex-charts.css" />
    <style>
        .card-header .btn-group .btn { padding: 0.25rem 0.5rem; }
        .hero-card {
            background: linear-gradient(135deg, #696cff 0%, #4339f2 100%);
            color: #fff;
            border: none;
            transition: transform 0.2s;
        }
        .hero-card:hover { transform: translateY(-5px); }
        .hero-card .avatar-initial { background: rgba(255,255,255,0.2) !important; color: #fff !important; }
        .hero-card .text-muted { color: rgba(255,255,255,0.7) !important; }
        
        .metric-card { border-left: 4px solid #696cff; }
        .metric-card.border-info { border-left-color: #03c3ec !important; }
        .metric-card.border-danger { border-left-color: #ff3e1d !important; }
        
        .cursor-pointer { cursor: pointer; }
    </style>
}

<!-- 頂部：維度切換與待辦中心 -->
<div class="row mb-4">
    <!-- 左側：核心待辦中心 (不隨時間變動) -->
    <div class="col-12 col-lg-4 mb-4 mb-lg-0">
        <div class="card hero-card h-100 shadow-lg cursor-pointer" onclick="window.location.href='@Url.Action("Index", "ShipmentWorkstation", new { area = "Admin" })'">
            <div class="card-body d-flex flex-column justify-content-between p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="avatar avatar-lg">
                        <span class="avatar-initial rounded-circle"><i class="bx bx-package fs-2"></i></span>
                    </div>
                    <span class="badge bg-white text-primary fw-bold">Active Tasks</span>
                </div>
                <div>
                    <h1 class="display-4 fw-bold text-white mb-1" id="kpiPendingShip">0</h1>
                    <h4 class="text-white mb-2">待出貨訂單總數</h4>
                    <p class="text-muted mb-4 small">這是當前系統中所有需要處理的訂單，不限時間區間。</p>
                </div>
                <a href="@Url.Action("Index", "ShipmentWorkstation", new { area = "Admin" })" class="btn btn-white w-100 fw-bold" style="color: #696cff; text-decoration: none;">
                    <i class="bx bx-right-arrow-alt me-1"></i> 立即前往處理
                </a>
            </div>
        </div>
    </div>

    <!-- 右側：表現分析區 (隨時間與商店變動) -->
    <div class="col-12 col-lg-8">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3 pb-0">
                <div class="d-flex align-items-center gap-3">
                    <h5 class="mb-0 fw-bold">營收表現分析</h5>
                    <select id="periodFilter" class="form-select form-select-sm w-auto border-0 bg-light fw-bold" onchange="refreshAllDashboard()">
                        <option value="7days">近 7 天</option>
                        <option value="month" selected>近一個月 (30天)</option>
                        <option value="3months">近三個月</option>
                        <option value="6months">近六個月</option>
                        <option value="year">近一年</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <select id="storeFilter" class="form-select form-select-sm w-auto border-0 bg-light" onchange="refreshAllDashboard()">
                        <option value="">全平台資料</option>
                        @foreach (var item in Model.StoreOptions)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>
                <!-- 標籤導覽 -->
                <div class="nav-align-top w-100 mt-3">
                    <ul class="nav nav-tabs border-bottom-0" role="tablist">
                        <li class="nav-item">
                            <button type="button" class="nav-link active fw-bold" role="tab" data-bs-toggle="tab" data-bs-target="#navs-core" aria-controls="navs-core" aria-selected="true">
                                <i class="bx bx-home-alt me-1"></i> 核心概覽
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link fw-bold" role="tab" data-bs-toggle="tab" data-bs-target="#navs-customer" aria-controls="navs-customer" aria-selected="false">
                                <i class="bx bx-user me-1"></i> 顧客行為
                            </button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link fw-bold" role="tab" data-bs-toggle="tab" data-bs-target="#navs-efficiency" aria-controls="navs-efficiency" aria-selected="false">
                                <i class="bx bx-bolt-circle me-1"></i> 營運效率
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="card-body pt-4">
                <div class="tab-content p-0 shadow-none border-0">
                    <!-- 標籤一：核心概覽 -->
                    <div class="tab-pane fade show active" id="navs-core" role="tabpanel">
                        <div class="row g-4">
                            <!-- 實收營收 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-money text-primary me-2"></i>
                                        <span class="text-muted small fw-bold">實收營收</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiNetRevenue">$0</h3>
                                    <div id="kpiRevGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                            <!-- 連帶率 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-info">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-cart text-info me-2"></i>
                                        <span class="text-muted small fw-bold">連帶率</span>
                                        <i class="bx bx-info-circle ms-1 text-muted cursor-pointer" 
                                           data-bs-toggle="tooltip" 
                                           data-bs-placement="top" 
                                           title="平均每筆訂單購買的商品件數 (總銷量 / 總訂單數)"></i>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiItemsPerOrder">0.0</h3>
                                    <div id="kpiItemsGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                            <!-- 客單價 (AOV) -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-warning">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-purchase-tag text-warning me-2"></i>
                                        <span class="text-muted small fw-bold">客單價 (AOV)</span>
                                        <i class="bx bx-info-circle ms-1 text-muted cursor-pointer" 
                                           data-bs-toggle="tooltip" 
                                           data-bs-placement="top" 
                                           title="平均每筆訂單的消費金額 (總營收 / 總訂單數)"></i>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiAov">$0</h3>
                                    <div id="kpiAovGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 標籤二：顧客行為 -->
                    <div class="tab-pane fade" id="navs-customer" role="tabpanel">
                        <div class="row g-4">
                            <!-- 新會員數 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-primary">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-user-plus text-primary me-2"></i>
                                        <span class="text-muted small fw-bold">新註冊會員</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiNewMembers">0</h3>
                                    <div id="kpiMemberGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                            <!-- 回購率 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-success">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-refresh text-success me-2"></i>
                                        <span class="text-muted small fw-bold">回購率</span>
                                        <i class="bx bx-info-circle ms-1 text-muted cursor-pointer" 
                                           data-bs-toggle="tooltip" 
                                           data-bs-placement="top" 
                                           title="期間內有二次以上下單行為的顧客佔比"></i>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiRepeatRate">0%</h3>
                                    <div id="kpiRepeatGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                            <!-- 活躍會員數 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-info">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-face text-info me-2"></i>
                                        <span class="text-muted small fw-bold">活躍下單會員</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiActiveMembers">0</h3>
                                    <div id="kpiActiveGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 標籤三：營運效率 -->
                    <div class="tab-pane fade" id="navs-efficiency" role="tabpanel">
                        <div class="row g-4">
                            <!-- 退貨率 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-danger cursor-pointer" onclick="window.location.href='@Url.Action("Index", "ReturnRequests", new { area = "Admin" })'">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-undo text-danger me-2"></i>
                                        <span class="text-muted small fw-bold">退訂/取消率</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiReturnRate">0%</h3>
                                    <div id="kpiReturnGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                            <!-- 平均出貨時長 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-warning cursor-pointer" onclick="window.location.href='@Url.Action("Index", "ShipmentWorkstation", new { area = "Admin" })'">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-timer text-warning me-2"></i>
                                        <span class="text-muted small fw-bold">平均出貨時長</span>
                                        <i class="bx bx-info-circle ms-1 text-muted cursor-pointer" 
                                           data-bs-toggle="tooltip" 
                                           data-bs-placement="top" 
                                           title="訂單從成立到標記為已出貨的平均天數"></i>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiAvgShipTime">0.0 天</h3>
                                    <div id="kpiShipTimeGrowth" class="small fw-bold">0%</div>
                                </div>
                            </div>
                            <!-- 庫存預警數 -->
                            <div class="col-md-4">
                                <div class="p-3 rounded bg-light metric-card border-secondary cursor-pointer" onclick="window.location.href='@Url.Action("Index", "Inventory", new { area = "Admin" })'">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bx bx-fridge text-secondary me-2"></i>
                                        <span class="text-muted small fw-bold">庫存預警品項</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="kpiStockAlerts">0</h3>
                                    <p class="mb-0 small text-muted">目前缺貨或低庫存品項</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 圖表區 -->
<div class="row">
    <!-- 年度銷售趨勢圖 -->
    <div class="col-12 col-xl-8 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">月營收額趨勢圖 (最近12個月) <span id="trendTotalBadge"></span></h5>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-label-secondary" onclick="toggleTrendChartType('line')"><i class="bx bx-line-chart"></i></button>
                    <button type="button" class="btn btn-label-secondary" onclick="toggleTrendChartType('bar')"><i class="bx bx-bar-chart-alt-2"></i></button>
                </div>
            </div>
            <div class="card-body">
                <div id="trendChart"></div>
            </div>
        </div>
    </div>

    <!-- 全站類別構成 -->
    <div class="col-12 col-xl-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 fw-bold">全站商品類別占比</h5>
            </div>
            <div class="card-body">
                <div id="categoryCompositionChart"></div>
            </div>
        </div>
    </div>

    <!-- 熱銷類別 -->
    <div class="col-12 col-xl-6 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">熱銷類別</h5>
                <span class="badge bg-label-primary">依銷量</span>
            </div>
            <div class="card-body">
                <div id="topSellingCategoriesChart"></div>
            </div>
        </div>
    </div>

    <!-- 類別貢獻度 (需求：切換 Bar/Pie) -->
    <div class="col-12 col-xl-6 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">類別營收貢獻度</h5>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-label-secondary" onclick="toggleCategoryChartType('bar')" title="柱狀圖"><i class="bx bx-bar-chart-square"></i></button>
                    <button type="button" class="btn btn-label-secondary" onclick="toggleCategoryChartType('pie')" title="圓餅圖"><i class="bx bx-pie-chart-alt"></i></button>
                </div>
            </div>
            <div class="card-body">
                <div id="categoryChart"></div>
            </div>
        </div>
    </div>

    <!-- 年度營收對比 (Diverging Bar Chart + Growth Analysis) -->
    <div class="col-12 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">年度營收雙向對比與增長分析 <span id="compYear1TotalBadge"></span> <span id="compYear2TotalBadge"></span></h5>
                <div class="d-flex align-items-center gap-2">
                    <select id="compYear1" class="form-select form-select-sm w-auto" onchange="loadComparisonChart()">
                        <option value="2026">2026</option>
                        <option value="2025" selected>2025</option>
                        <option value="2024">2024</option>
                    </select>
                    <span class="text-muted small">vs</span>
                    <select id="compYear2" class="form-select form-select-sm w-auto" onchange="loadComparisonChart()">
                        <option value="2026">2026</option>
                        <option value="2025">2025</option>
                        <option value="2024" selected>2024</option>
                    </select>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- 左側：雙向柱狀圖 -->
                    <div class="col-12 col-lg-8 border-end">
                        <div id="comparisonChart"></div>
                    </div>
                    <!-- 右側：增長分析 -->
                    <div class="col-12 col-lg-4 d-flex flex-column align-items-center justify-content-center">
                        <div id="growthGaugeChart"></div>
                        <div class="text-center mt-3">
                            <h5 id="growthText" class="fw-bold mb-1">0% Growth</h5>
                            <p class="text-muted small">年度營收成長率</p>
                        </div>
                        <div class="d-flex w-100 mt-4 px-3 gap-3">
                            <div class="flex-grow-1 p-3 rounded bg-label-primary">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="bx bx-dollar-circle me-1"></i>
                                    <span class="small fw-bold" id="labelYear1">2025</span>
                                </div>
                                <h5 class="mb-0 fw-bold" id="valTotal1">$0</h5>
                            </div>
                            <div class="flex-grow-1 p-3 rounded bg-label-info">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="bx bx-calendar me-1"></i>
                                    <span class="small fw-bold" id="labelYear2">2024</span>
                                </div>
                                <h5 class="mb-0 fw-bold" id="valTotal2">$0</h5>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 新增：成長動因分析 (Growth Bridge) -->
                <div class="row mt-4 pt-4 border-top">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-3 px-3">
                            <div>
                                <h5 class="card-title mb-0 fw-bold">年度營收成長分解(依商品類別) <span class="badge bg-label-info ms-2 small comp-year-label" id="growthBridgeYearLabel"></span></h5>
                                <p class="text-muted small mb-0 mt-1" id="growthBridgeDesc">展示各類別對營收變動的具體貢獻</p>
                            </div>
                            <span class="badge bg-label-primary">Waterfall Analysis</span>
                        </div>
                        <div id="growthBridgeChart" class="px-3"></div>
                    </div>
                </div>

                <!-- 新增：類別市佔百分點變動趨勢圖 (Category Market Share Delta Trend Chart) -->
                <div class="row mt-4 pt-4 border-top">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-3 px-3">
                            <div>
                                <h5 class="card-title mb-0 fw-bold">類別市佔率月間變動趨勢圖 <span class="badge bg-label-info ms-2 small comp-year-label" id="categoryDeltaYearLabel"></span></h5>
                                <p class="text-muted small mb-0 mt-1" id="categoryDeltaDesc">分析各類別市佔率對比去年的增減情況，正值為擴張，負值為萎縮。</p>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="btn-group btn-group-sm me-3">
                                    <button type="button" class="btn btn-label-secondary" id="zoomInDelta" title="放大">
                                        <i class="bx bx-zoom-in"></i>
                                    </button>
                                    <button type="button" class="btn btn-label-secondary" id="zoomOutDelta" title="縮小">
                                        <i class="bx bx-zoom-out"></i>
                                    </button>
                                    <button type="button" class="btn btn-label-secondary" id="resetDeltaZoom" title="重設縮放">
                                        <i class="bx bx-refresh"></i>
                                    </button>
                                </div>
                                <span class="badge bg-label-primary">Competitive Analysis</span>
                            </div>
                        </div>
                        <div id="categoryDeltaLineChart" class="px-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 「其他」類別細節彈窗 -->
<div class="modal fade" id="othersDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="othersDetailTitle">「其他」類別細節分解</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="othersDetailChart"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/sneat/assets/vendor/libs/apex-charts/apexcharts.js"></script>
    <script>
        let trendChart, categoryCompositionChart, topSellingCategoriesChart, categoryChart, comparisonChart, growthGaugeChart, deltaTrendChart, growthBridgeChart;
        let grandTotalSales = 0;    // 全域變數：總銷售量
        let grandTotalRevenue = 0;  // 全域變數：總營收額
        let currentCategoryChartType = 'bar'; // 預設為柱狀圖
        const palette = ['#696cff', '#71dd37', '#03c3ec', '#ffab00', '#ff3e1d', '#8592a3', '#e3028a', '#00d2d3', '#54a0ff', '#5f27cd'];
        
        const categoryColorMap = {};
        let colorIndex = 0;

        function getCategoryColor(name) {
            if (!categoryColorMap[name]) {
                categoryColorMap[name] = palette[colorIndex % palette.length];
                colorIndex++;
            }
            return categoryColorMap[name];
        }

        $(document).ready(function() {
            // 初始化 Bootstrap Tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })

            refreshAllDashboard();

            // 新增：縮放按鈕事件 (使用 zoomX 確保在 Toolbar 隱藏時仍有效)
            let currentZoomLevel = 0;
            $('#zoomInDelta').on('click', function() {
                if (deltaTrendChart) {
                    currentZoomLevel++;
                    const min = 1 + currentZoomLevel;
                    const max = 12 - currentZoomLevel;
                    if (min < max) {
                        deltaTrendChart.zoomX(min, max);
                    } else {
                        currentZoomLevel--; // 達到極限，退回
                    }
                }
            });
            $('#zoomOutDelta').on('click', function() {
                if (deltaTrendChart) {
                    currentZoomLevel = Math.max(0, currentZoomLevel - 1);
                    if (currentZoomLevel === 0) {
                        deltaTrendChart.resetSeries();
                    } else {
                        deltaTrendChart.zoomX(1 + currentZoomLevel, 12 - currentZoomLevel);
                    }
                }
            });
            $('#resetDeltaZoom').on('click', function() {
                if (deltaTrendChart) {
                    currentZoomLevel = 0;
                    deltaTrendChart.resetSeries();
                }
            });
        });

        function refreshAllDashboard() {
            refreshMetrics();
            loadTrendChart();
            loadCategoryCompositionChart();
            loadTopSellingCategoriesChart();
            loadCategoryContribution();
            loadComparisonChart();
        }

        function refreshMetrics() {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            $.get(`/Orders/GetDashboardKpis?period=${period}&storeId=${storeId}`, function(data) {
                $('#kpiPendingShip').text(data.pendingShipmentCount);
                
                // 核心概覽
