        let othersChart;
        function showCategoryDetail(type, categoryName) {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            const denominator = (type === 'Sales' || type === 'Composition') ? grandTotalSales : grandTotalRevenue;
            
            $.get(`/Orders/GetCategoryDetail?type=${type}&period=${period}&storeId=${storeId}&categoryName=${encodeURIComponent(categoryName)}`, function(data) {
                if(!data || !data.series || data.series.length === 0 || data.labels.length === 0) {
                    alert('沒有更多細節數據');
                    return;
                }

                const rawData = data.series[0].data;
                const othersTotal = rawData.reduce((a, b) => a + b, 0);
                const othersToGrandPercent = denominator > 0 ? ((othersTotal / denominator) * 100).toFixed(1) : 0;

                // 智慧型最大值計算邏輯 (參考熱銷類別成功案例)
                const rawMax = rawData.length > 0 ? Math.max(...rawData) : 0;
                let finalMax = 4;
                if (rawMax > 0) {
                    // 1. 預留 30% 緩衝空間
                    let target = rawMax * 1.3;
                    
                    // 2. 根據數據規模找漂亮的步長 (Step)
                    // 如果數據小於 10，每格 2 或 5
                    // 如果數據較大，找一個能讓 tickAmount=4 跑出漂亮整數的值
                    let step;
                    if (target <= 10) step = 2;
                    else if (target <= 20) step = 5;
                    else if (target <= 100) step = 10;
                    else if (target <= 500) step = 50;
                    else if (target <= 2000) step = 200;
                    else if (target <= 10000) step = 1000;
                    else step = Math.pow(10, Math.floor(Math.log10(target / 4))) * 2; // 大數據自動步長
                    
                    finalMax = Math.ceil(target / step) * step;
                    // 確保能被 4 整除以便對齊刻度
                    if (finalMax % 4 !== 0) {
                        finalMax = Math.ceil(finalMax / (step * 4)) * (step * 4);
                    }
                }

                // 動態更新標題
                let typeText = '營收額';
                if (type === 'Sales') typeText = '銷售量';
                if (type === 'Composition') typeText = '商品數';

                const titlePrefix = categoryName === '其他' ? '「其他」類別細節' : `「${categoryName}」子類別明細`;
                $('#othersDetailTitle').html(`${titlePrefix} - ${typeText}分解 <span class="badge bg-label-primary ms-2">(總計佔全體 ${othersToGrandPercent}%)</span>`);

                const options = {
                    series: [{
                        name: typeText,
                        data: rawData
                    }],
                    chart: {
                        type: 'bar',
                        height: Math.max(400, rawData.length * 40), 
                        toolbar: { show: true },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    plotOptions: {
                        bar: {
                            horizontal: true,
                            borderRadius: 4,
                            distributed: true,
                            dataLabels: { 
                                position: 'top',
                                hideOverflowingLabels: false
                            }
                        }
                    },
                    dataLabels: {
                        enabled: true,
                        textAnchor: 'start',
                        style: {
                            colors: ['#566a7f'],
                            fontWeight: '600',
                            fontSize: '11px'
                        },
                        formatter: function(val) {
                            if (type === 'Sales' || type === 'Composition') {
                                // 顯示：實際件數
                                return val.toLocaleString() + ' 件';
                            } else {
                                // 營收顯示：格式化金額 (萬)
                                return '$' + formatRevenue(val);
                            }
                        },
                        offsetX: 25, // 增加偏移量，確保長文字(如 $116.9 萬) 不會蓋到柱子
                        dropShadow: { enabled: false }
                    },
                    colors: data.labels.map(name => getCategoryColor(name)),
                    xaxis: { 
                        categories: data.labels,
                        max: finalMax,
                        tickAmount: 4,
                        labels: {
                            formatter: function(val) {
                                if (type === 'Sales' || type === 'Composition') {
                                    return Math.round(val);
                                }
                                return formatRevenue(val);
                            }
                        }
                    },
                    legend: { show: false },
                    tooltip: {
                        y: {
                            formatter: (val) => {
                                const suffix = (type === 'Sales' || type === 'Composition') ? ' 件' : '';
                                const prefix = type === 'Revenue' ? '$' : '';
                                return prefix + val.toLocaleString() + suffix;
                            }
                        }
                    },
                    grid: {
                        xaxis: { lines: { show: true } },
                        padding: { right: 80 } 
                    }
                };

                $('#othersDetailModal').modal('show');
                
                setTimeout(() => {
                    if(othersChart) othersChart.destroy();
                    othersChart = new ApexCharts(document.querySelector("#othersDetailChart"), options);
                    othersChart.render();
                }, 300);
            });
        }

