@model ISpanShop.MVC.Areas.Admin.Models.Orders.OrderDashboardVm
@{
    ViewData["Title"] = "訂單分析儀表板";
}

@section Styles {
    <link rel="stylesheet" href="~/sneat/assets/vendor/libs/apex-charts/apex-charts.css" />
    <style>
        .card-header .btn-group .btn { padding: 0.25rem 0.5rem; }
        .hero-card {
            background: linear-gradient(135deg, #696cff 0%, #4339f2 100%);
            color: #fff;
            border: none;
            transition: transform 0.2s;
        }
        .hero-card:hover { transform: translateY(-5px); }
        .hero-card .avatar-initial { background: rgba(255,255,255,0.2) !important; color: #fff !important; }
        .hero-card .text-muted { color: rgba(255,255,255,0.7) !important; }
        
        .metric-card { border-left: 4px solid #696cff; }
        .metric-card.border-info { border-left-color: #03c3ec !important; }
        .metric-card.border-danger { border-left-color: #ff3e1d !important; }
        
        .cursor-pointer { cursor: pointer; }
    </style>
}

<!-- 頂部：維度切換與待辦中心 -->
<div class="row mb-4">
    <!-- 左側：核心待辦中心 (不隨時間變動) -->
    <div class="col-12 col-lg-4 mb-4 mb-lg-0">
        <div class="card hero-card h-100 shadow-lg cursor-pointer" onclick="window.location.href='@Url.Action("Index", "ShipmentWorkstation", new { area = "Admin" })'">
            <div class="card-body d-flex flex-column justify-content-between p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="avatar avatar-lg">
                        <span class="avatar-initial rounded-circle"><i class="bx bx-package fs-2"></i></span>
                    </div>
                    <span class="badge bg-white text-primary fw-bold">Active Tasks</span>
                </div>
                <div>
                    <h1 class="display-4 fw-bold text-white mb-1" id="kpiPendingShip">0</h1>
                    <h4 class="text-white mb-2">待出貨訂單總數</h4>
                    <p class="text-muted mb-4 small">這是當前系統中所有需要處理的訂單，不限時間區間。</p>
                </div>
                <a href="@Url.Action("Index", "ShipmentWorkstation", new { area = "Admin" })" class="btn btn-white w-100 fw-bold" style="color: #696cff; text-decoration: none;">
                    <i class="bx bx-right-arrow-alt me-1"></i> 立即前往處理
                </a>
            </div>
        </div>
    </div>

    <!-- 右側：表現分析區 (隨時間與商店變動) -->
    <div class="col-12 col-lg-8">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div class="d-flex align-items-center gap-3">
                    <h5 class="mb-0 fw-bold">營收表現分析</h5>
                    <select id="periodFilter" class="form-select form-select-sm w-auto border-0 bg-light fw-bold" onchange="refreshAllDashboard()">
                        <option value="7days">近 7 天</option>
                        <option value="month" selected>近一個月 (30天)</option>
                        <option value="3months">近三個月</option>
                        <option value="6months">近六個月</option>
                        <option value="year">近一年</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <select id="storeFilter" class="form-select form-select-sm w-auto border-0 bg-light" onchange="refreshAllDashboard()">
                        <option value="">全平台資料</option>
                        @foreach (var item in Model.StoreOptions)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <!-- 實收營收 -->
                    <div class="col-md-4">
                        <div class="p-3 rounded bg-light metric-card">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bx bx-money text-primary me-2"></i>
                                <span class="text-muted small fw-bold">實收營收</span>
                            </div>
                            <h3 class="mb-1 fw-bold" id="kpiNetRevenue">$0</h3>
                            <div id="kpiRevGrowth" class="small fw-bold">0%</div>
                        </div>
                    </div>
                    <!-- 連帶率 -->
                    <div class="col-md-4">
                        <div class="p-3 rounded bg-light metric-card border-info">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bx bx-cart text-info me-2"></i>
                                <span class="text-muted small fw-bold">連帶率</span>
                            </div>
                            <h3 class="mb-1 fw-bold" id="kpiItemsPerOrder">0.0</h3>
                            <div id="kpiItemsGrowth" class="small fw-bold">0%</div>
                        </div>
                    </div>
                    <!-- 退貨率 -->
                    <div class="col-md-4">
                        <div class="p-3 rounded bg-light metric-card border-danger">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bx bx-refresh text-danger me-2"></i>
                                <span class="text-muted small fw-bold">退訂/取消率</span>
                            </div>
                            <h3 class="mb-1 fw-bold" id="kpiReturnRate">0%</h3>
                            <div id="kpiReturnGrowth" class="small fw-bold">0%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 圖表區 -->
<div class="row">
    <!-- 年度銷售趨勢圖 -->
    <div class="col-12 col-xl-8 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">月營收額趨勢圖 (最近12個月)</h5>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-label-secondary" onclick="toggleTrendChartType('line')"><i class="bx bx-line-chart"></i></button>
                    <button type="button" class="btn btn-label-secondary" onclick="toggleTrendChartType('bar')"><i class="bx bx-bar-chart-alt-2"></i></button>
                </div>
            </div>
            <div class="card-body">
                <div id="trendChart"></div>
            </div>
        </div>
    </div>

    <!-- 類別銷售比例 -->
    <div class="col-12 col-xl-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 fw-bold">類別銷量佔比</h5>
            </div>
            <div class="card-body">
                <div id="productPieChart"></div>
            </div>
        </div>
    </div>

    <!-- 熱銷排行 Top 10 -->
    <div class="col-12 col-xl-6 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">熱銷商品 Top 10 (依類別著色)</h5>
                <select id="top10OrderBy" class="form-select form-select-sm w-auto" onchange="loadTop10Chart()">
                    <option value="volume">依銷量</option>
                    <option value="revenue">依銷售額</option>
                </select>
            </div>
            <div class="card-body">
                <div id="top10Chart"></div>
            </div>
        </div>
    </div>

    <!-- 類別貢獻度 (需求：切換 Bar/Treemap/Radar) -->
    <div class="col-12 col-xl-6 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">類別營收貢獻度</h5>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-label-secondary" onclick="toggleCategoryChartType('bar')" title="柱狀圖"><i class="bx bx-bar-chart-square"></i></button>
                    <button type="button" class="btn btn-label-secondary" onclick="toggleCategoryChartType('treemap')" title="矩形圖"><i class="bx bx-grid-alt"></i></button>
                </div>
            </div>
            <div class="card-body">
                <div id="categoryChart"></div>
            </div>
        </div>
    </div>

    <!-- 年度營收對比 (Diverging Bar Chart + Growth Analysis) -->
    <div class="col-12 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">年度營收雙向對比與增長分析</h5>
                <div class="d-flex align-items-center gap-2">
                    <select id="compYear1" class="form-select form-select-sm w-auto" onchange="loadComparisonChart()">
                        <option value="2026">2026</option>
                        <option value="2025" selected>2025</option>
                        <option value="2024">2024</option>
                    </select>
                    <span class="text-muted small">vs</span>
                    <select id="compYear2" class="form-select form-select-sm w-auto" onchange="loadComparisonChart()">
                        <option value="2026">2026</option>
                        <option value="2025">2025</option>
                        <option value="2024" selected>2024</option>
                    </select>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- 左側：雙向柱狀圖 -->
                    <div class="col-12 col-lg-8 border-end">
                        <div id="comparisonChart"></div>
                    </div>
                    <!-- 右側：增長分析 -->
                    <div class="col-12 col-lg-4 d-flex flex-column align-items-center justify-content-center">
                        <div id="growthGaugeChart"></div>
                        <div class="text-center mt-3">
                            <h5 id="growthText" class="fw-bold mb-1">0% Growth</h5>
                            <p class="text-muted small">年度營收成長率</p>
                        </div>
                        <div class="d-flex w-100 mt-4 px-3 gap-3">
                            <div class="flex-grow-1 p-3 rounded bg-label-primary">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="bx bx-dollar-circle me-1"></i>
                                    <span class="small fw-bold" id="labelYear1">2025</span>
                                </div>
                                <h5 class="mb-0 fw-bold" id="valTotal1">$0</h5>
                            </div>
                            <div class="flex-grow-1 p-3 rounded bg-label-info">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="bx bx-calendar me-1"></i>
                                    <span class="small fw-bold" id="labelYear2">2024</span>
                                </div>
                                <h5 class="mb-0 fw-bold" id="valTotal2">$0</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 「其他」類別細節彈窗 -->
<div class="modal fade" id="othersDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="othersDetailTitle">「其他」類別細節分解</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="othersDetailChart"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">關閉</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/sneat/assets/vendor/libs/apex-charts/apexcharts.js"></script>
    <script>
        let trendChart, pieChart, top10Chart, categoryChart, comparisonChart, growthGaugeChart;
        let grandTotalSales = 0;    // 全域變數：總銷售量
        let grandTotalRevenue = 0;  // 全域變數：總營收額
        let currentCategoryChartType = 'bar'; // 預設為柱狀圖
        const palette = ['#696cff', '#71dd37', '#03c3ec', '#ffab00', '#ff3e1d', '#8592a3', '#e3028a', '#00d2d3', '#54a0ff', '#5f27cd'];
        
        const categoryColorMap = {};
        let colorIndex = 0;

        function getCategoryColor(name) {
            if (!categoryColorMap[name]) {
                categoryColorMap[name] = palette[colorIndex % palette.length];
                colorIndex++;
            }
            return categoryColorMap[name];
        }

        $(document).ready(function() {
            refreshAllDashboard();
        });

        function refreshAllDashboard() {
            refreshMetrics();
            loadTrendChart();
            loadPieChart();
            loadTop10Chart();
            loadCategoryContribution();
            loadComparisonChart();
        }

        function refreshMetrics() {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            $.get(`/Orders/GetDashboardKpis?period=${period}&storeId=${storeId}`, function(data) {
                $('#kpiPendingShip').text(data.pendingShipmentCount);
                $('#kpiNetRevenue').text('$' + data.netRevenue.toLocaleString());
                $('#kpiItemsPerOrder').text(data.itemsPerOrder.toFixed(1));
                $('#kpiReturnRate').text(data.returnRate.toFixed(1) + '%');
                updateGrowth('#kpiRevGrowth', data.netRevenueGrowthRate, false);
                updateGrowth('#kpiItemsGrowth', data.itemsPerOrderGrowthRate, false);
                updateGrowth('#kpiReturnGrowth', data.returnRateGrowthRate, true);
            });
        }

        function updateGrowth(selector, rate, invert) {
            const el = $(selector);
            const isNegative = rate < 0;
            el.removeClass('text-success text-danger');
            let colorClass = isNegative ? 'text-danger' : 'text-success';
            if(invert) colorClass = isNegative ? 'text-success' : 'text-danger';
            el.addClass(colorClass).html(`${rate >= 0 ? '↑' : '↓'} ${Math.abs(rate)}% <span class="text-muted fw-normal">vs 前期</span>`);
        }

        // 通用營收格式化函式 (自動轉 萬)
        function formatRevenue(val) {
            if (val === null || val === undefined) return '$0';
            var num = parseFloat(val);
            if (num >= 10000) return (num / 10000).toFixed(1) + ' 萬';
            return num.toLocaleString();
        }

        function loadTrendChart() {
            const storeId = $('#storeFilter').val();
            $.get(`/Orders/GetMonthlyTrend?storeId=${storeId}`, function(data) {
                if (!data || !data.series || !data.labels) return;
                
                const options = {
                    series: data.series,
                    chart: { 
                        height: 350, 
                        type: 'line', 
                        toolbar: { show: false },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    stroke: { curve: 'smooth', width: 4 },
                    colors: [palette[0]],
                    grid: { 
                        borderColor: '#f1f1f1',
                        padding: { bottom: 15 }
                    },
                    xaxis: {
                        categories: data.labels,
                        axisBorder: { show: false },
                        axisTicks: { show: false },
                        tickPlacement: 'on',
                        labels: {
                            style: { colors: '#a1acb8', fontSize: '12px' },
                            hideOverlappingLabels: false,
                            trim: false,
                            rotate: -30,
                            rotateAlways: false,
                            formatter: function(value, timestamp, opts) {
                                if (!value) return value;
                                var strVal = String(value);
                                var parts = strVal.split('/');
                                if (parts.length < 2) return strVal;
                                
                                var year = parts[0];
                                var month = parseInt(parts[1], 10);
                                
                                // 判斷是否為首筆數據：檢查 opts.i 或 opts.index
                                var isFirst = opts && (opts.i === 0 || opts.index === 0);
                                
                                // 1月或是第一筆數據，顯示完整年份作為標記
                                if (month === 1 || isFirst) {
                                    return year + '/' + parts[1] + '月';
                                }
                                return month + '月';
                            }
                        }
                    },
                    yaxis: {
                        labels: {
                            style: { colors: '#a1acb8', fontSize: '13px' },
                            formatter: function(val) {
                                return formatRevenue(val);
                            }
                        },
                        tickAmount: 5
                    },
                    markers: {
                        size: 4,
                        colors: [palette[0]],
                        strokeColors: '#fff',
                        strokeWidth: 2,
                        hover: { size: 6 }
                    },
                    tooltip: {
                        y: {
                            formatter: function(val) {
                                return '$' + parseFloat(val).toLocaleString();
                            }
                        }
                    }
                };
                if(trendChart) trendChart.destroy();
                trendChart = new ApexCharts(document.querySelector("#trendChart"), options);
                trendChart.render();
            });
        }

        function toggleTrendChartType(type) {
            if(trendChart) trendChart.updateOptions({ chart: { type: type } });
        }

        function loadPieChart() {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            $.get(`/Orders/GetProductSalesChart?type=Pie&period=${period}&storeId=${storeId}`, function(data) {
                if(!data.series || data.series.length === 0) return;
                
                const realSeries = data.series[0].data;
                grandTotalSales = realSeries.reduce((a, b) => a + b, 0);

                // 視覺優化：設定「最小視覺佔比」為 2%，避免區塊太小點不到
                const minVisualPercent = 0.02; 
                const visualFloor = grandTotalSales * minVisualPercent;
                const visualSeries = realSeries.map(v => Math.max(v, visualFloor));

                const chartColors = data.labels.map(name => getCategoryColor(name));
                const options = {
                    series: visualSeries, // 使用「視覺地板」序列繪圖
                    labels: data.labels,
                    chart: { 
                        type: 'donut', 
                        height: 350,
                        events: {
                            dataPointSelection: function(event, chartContext, config) {
                                const label = config.w.config.labels[config.dataPointIndex];
                                showCategoryDetail('Sales', label);
                            }
                        }
                    },
                    colors: chartColors,
                    legend: { 
                        position: 'bottom',
                        onItemClick: { toggleDataSeries: true } 
                    },
                    plotOptions: { 
                        pie: { 
                            donut: { size: '70%' },
                            expandOnClick: true,
                            dataLabels: {
                                offset: -5,
                                minAngleToShowLabel: 10 
                            }
                        } 
                    },
                    tooltip: {
                        y: {
                            formatter: function(val, { seriesIndex, dataPointIndex, w }) {
                                const actualValue = realSeries[dataPointIndex];
                                const percent = grandTotalSales > 0 ? ((actualValue / grandTotalSales) * 100).toFixed(1) : 0;
                                return `${actualValue.toLocaleString()} 件 (${percent}%)`;
                            }
                        }
                    },
                    dataLabels: {
                        enabled: true,
                        formatter: function (val, opts) {
                            return val >= 4 ? val.toFixed(1) + "%" : ""; 
                        },
                        style: {
                            fontSize: '13px',
                            fontWeight: 'bold',
                            colors: ['#fff']
                        },
                        dropShadow: {
                            enabled: true,
                            opacity: 0.5
                        }
                    }
                };
                if(pieChart) pieChart.destroy();
                pieChart = new ApexCharts(document.querySelector("#productPieChart"), options);
                pieChart.render();
            });
        }

        function loadTop10Chart() {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            const orderBy = $('#top10OrderBy').val();
            $.get(`/Orders/GetTop10Products?period=${period}&storeId=${storeId}&orderBy=${orderBy}`, function(data) {
                const barColors = data.map(item => getCategoryColor(item.categoryName));
                const options = {
                    series: [{ 
                        name: orderBy === 'revenue' ? '銷售額' : '銷量', 
                        data: data.map(x => orderBy === 'revenue' ? x.salesRevenue : x.salesVolume) 
                    }],
                    chart: { 
                        type: 'bar', 
                        height: 350, 
                        toolbar: { show: false },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    plotOptions: { 
                        bar: { 
                            horizontal: true, 
                            borderRadius: 4, 
                            distributed: true,
                            dataLabels: { position: 'top' }
                        } 
                    },
                    dataLabels: {
                        enabled: true,
                        offsetX: -6,
                        style: { fontSize: '12px', colors: ['#fff'] },
                        formatter: function(val) {
                            return orderBy === 'revenue' ? '$' + formatRevenue(val) : val;
                        },
                        dropShadow: {
                            enabled: true,
                            top: 1,
                            left: 1,
                            blur: 1,
                            color: '#000',
                            opacity: 0.45
                        }
                    },
                    xaxis: { 
                        categories: data.map(x => x.productName),
                        labels: {
                            formatter: function(val) {
                                if (orderBy === 'revenue') {
                                    return formatRevenue(val);
                                } else {
                                    // 銷量(件數)只顯示整數標籤
                                    return (val % 1 === 0) ? val : '';
                                }
                            }
                        }
                    },
                    colors: barColors,
                    legend: { show: false },
                    tooltip: {
                        y: {
                            formatter: function(val) {
                                return orderBy === 'revenue' ? '$' + val.toLocaleString() : val + ' 件';
                            }
                        }
                    }
                };
                if(top10Chart) top10Chart.destroy();
                top10Chart = new ApexCharts(document.querySelector("#top10Chart"), options);
                top10Chart.render();
            });
        }

        function toggleCategoryChartType(type) {
            currentCategoryChartType = type;
            loadCategoryContribution();
        }

        function loadCategoryContribution() {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            $.get(`/Orders/GetCategoryContribution?period=${period}&storeId=${storeId}`, function(data) {
                if(!data.series || data.series.length === 0) return;
                
                // 紀錄全體總營收 (用於彈窗百分比計算)
                grandTotalRevenue = data.series[0].data.reduce((a, b) => a + b, 0);

                const chartColors = data.labels.map(name => getCategoryColor(name));
                let options = {
                    chart: { 
                        height: 350, 
                        toolbar: { show: false },
                        fontFamily: 'Public Sans, -apple-system, sans-serif',
                        events: {
                            dataPointSelection: function(event, chartContext, config) {
                                let label = "";
                                if (currentCategoryChartType === 'treemap') {
                                    label = config.w.config.series[config.seriesIndex].data[config.dataPointIndex].x;
                                } else if (currentCategoryChartType === 'bar') {
                                    label = config.w.config.xaxis.categories[config.dataPointIndex];
                                }
                                
                                showCategoryDetail('Revenue', label);
                            }
                        }
                    },
                    colors: chartColors
                };

                if (currentCategoryChartType === 'treemap') {
                    const treemapData = data.labels.map((label, index) => ({ x: label, y: data.series[0].data[index] }));
                    options = {
                        ...options,
                        series: [{ data: treemapData }],
                        chart: { ...options.chart, type: 'treemap' },
                        plotOptions: { treemap: { distributed: true, enableShades: false } },
                        dataLabels: { 
                            enabled: true, 
                            formatter: function(text, op) {
                                const val = op.value;
                                const percent = grandTotalRevenue > 0 ? (val / grandTotalRevenue) * 100 : 0;
                                
                                // 策略：保留文字的前提下優化顯示
                                // 1. 極小區塊 (< 3%): 顯示前兩個字 + ".."，不顯示金額 (防止旋轉)
                                if (percent < 3) {
                                    return text.length > 2 ? text.substring(0, 2) + ".." : text;
                                }
                                // 2. 中小區塊 (3% - 10%): 顯示完整類別名稱，不顯示金額
                                if (percent < 10) {
                                    return text;
                                }
                                // 3. 大型區塊 (> 10%): 顯示兩行 (名稱 + 金額)
                                return [text, '$' + formatRevenue(val)];
                            },
                            style: {
                                fontSize: '11px',
                                fontWeight: '600',
                                colors: ['#fff'] // 強制白色，配合陰影效果最好
                            },
                            dropShadow: {
                                enabled: true,
                                top: 1,
                                left: 1,
                                blur: 1,
                                color: '#000',
                                opacity: 0.5
                            }
                        },
                        tooltip: {
                            y: { formatter: (val) => '$' + val.toLocaleString() }
                        }
                    };
                } else {
                    // 預設：柱狀圖 (Bar)
                    options = {
                        ...options,
                        series: data.series,
                        chart: { ...options.chart, type: 'bar' },
                        plotOptions: { 
                            bar: { 
                                distributed: true, 
                                borderRadius: 4, 
                                columnWidth: '50%',
                                dataLabels: { position: 'top' } // 確保標籤在柱位頂端
                            } 
                        },
                        xaxis: { categories: data.labels },
                        legend: { show: false },
                        dataLabels: { 
                            enabled: true, 
                            formatter: function(val, opts) {
                                const realVal = opts.w.config.series[opts.seriesIndex].data[opts.dataPointIndex];
                                return '$' + formatRevenue(realVal);
                            },
                            offsetY: 10, // 向下偏移一點，讓它進到柱位內部
                            style: { 
                                fontSize: '12px',
                                colors: ['#fff'], // 改為白色
                                fontWeight: 600
                            },
                            dropShadow: {
                                enabled: true,
                                top: 1,
                                left: 1,
                                blur: 1,
                                color: '#000',
                                opacity: 0.45
                            }
                        },
                        yaxis: {
                            logarithmic: true,
                            forceNiceScale: true,
                            labels: { formatter: (val) => formatRevenue(val) }
                        },
                        tooltip: {
                            y: { formatter: (val) => '$' + val.toLocaleString() }
                        }
                    };
                }

                if(categoryChart) categoryChart.destroy();
                categoryChart = new ApexCharts(document.querySelector("#categoryChart"), options);
                categoryChart.render();
            });
        }

        let othersChart;
        function showCategoryDetail(type, categoryName) {
            const period = $('#periodFilter').val();
            const storeId = $('#storeFilter').val();
            const denominator = type === 'Sales' ? grandTotalSales : grandTotalRevenue;
            
            $.get(`/Orders/GetCategoryDetail?type=${type}&period=${period}&storeId=${storeId}&categoryName=${encodeURIComponent(categoryName)}`, function(data) {
                if(!data || !data.series || data.series.length === 0 || data.labels.length === 0) {
                    alert('沒有更多細節數據');
                    return;
                }

                const rawData = data.series[0].data;
                const othersTotal = rawData.reduce((a, b) => a + b, 0);
                const othersToGrandPercent = denominator > 0 ? ((othersTotal / denominator) * 100).toFixed(1) : 0;

                // 動態更新標題
                const typeText = type === 'Sales' ? '銷售量' : '營收額';
                const titlePrefix = categoryName === '其他' ? '「其他」類別細節' : `「${categoryName}」子類別明細`;
                $('#othersDetailTitle').html(`${titlePrefix} - ${typeText}分解 <span class="badge bg-label-primary ms-2">(總計佔全體 ${othersToGrandPercent}%)</span>`);

                const options = {
                    series: [{
                        name: type === 'Sales' ? '銷售量' : '營收額',
                        data: rawData
                    }],
                    chart: {
                        type: 'bar',
                        height: Math.max(400, rawData.length * 40), 
                        toolbar: { show: true },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    plotOptions: {
                        bar: {
                            horizontal: true,
                            borderRadius: 4,
                            distributed: true,
                            dataLabels: { 
                                position: 'top'
                            }
                        }
                    },
                    dataLabels: {
                        enabled: true,
                        textAnchor: 'start',
                        style: {
                            colors: ['#566a7f'],
                            fontWeight: 600,
                            fontSize: '12px'
                        },
                        formatter: function(val) {
                            if (type === 'Sales') {
                                // 銷量顯示：佔全體百分比
                                if (grandTotalSales === 0) return '0%';
                                return ((val / grandTotalSales) * 100).toFixed(1) + '%';
                            } else {
                                // 營收顯示：格式化金額 (萬)
                                return '$' + formatRevenue(val);
                            }
                        },
                        offsetX: 10
                    },
                    colors: data.labels.map(name => getCategoryColor(name)),
                    xaxis: { 
                        categories: data.labels,
                        labels: {
                            formatter: function(val) {
                                if (type === 'Sales') {
                                    // 銷量(件數)只顯示整數標籤，避免出現 0.5, 1.5 等碎片化刻度
                                    return (val % 1 === 0) ? val : '';
                                }
                                return formatRevenue(val);
                            }
                        }
                    },
                    legend: { show: false },
                    tooltip: {
                        y: {
                            formatter: (val) => {
                                const suffix = type === 'Sales' ? ' 件' : '';
                                const prefix = type === 'Revenue' ? '$' : '';
                                return prefix + val.toLocaleString() + suffix;
                            }
                        }
                    },
                    grid: {
                        xaxis: { lines: { show: true } },
                        padding: { right: 60 } 
                    }
                };

                $('#othersDetailModal').modal('show');
                
                setTimeout(() => {
                    if(othersChart) othersChart.destroy();
                    othersChart = new ApexCharts(document.querySelector("#othersDetailChart"), options);
                    othersChart.render();
                }, 300);
            });
        }

        function loadComparisonChart() {
            const y1 = $('#compYear1').val();
            const y2 = $('#compYear2').val();
            const storeId = $('#storeFilter').val();
            
            $.get(`/Orders/GetYearOverYearComparison?year1=${y1}&year2=${y2}&storeId=${storeId}`, function(data) {
                if (!data || !data.series) return;

                // 更新標籤與總金額
                $('#labelYear1').text(y1);
                $('#labelYear2').text(y2);
                $('#valTotal1').text('$' + formatRevenue(data.total1));
                $('#valTotal2').text('$' + formatRevenue(data.total2));
                $('#growthText').text(data.growthRate + '% Growth');

                // 1. 更新雙向柱狀圖
                const barOptions = {
                    series: data.series,
                    chart: {
                        type: 'bar',
                        height: 400,
                        stacked: false,
                        toolbar: { show: false },
                        fontFamily: 'Public Sans, -apple-system, sans-serif'
                    },
                    colors: ['#696cff', '#03c3ec'],
                    plotOptions: {
                        bar: {
                            horizontal: false,
                            columnWidth: '40%',
                            borderRadius: 4
                        }
                    },
                    dataLabels: { enabled: false },
                    grid: { 
                        borderColor: '#f1f1f1',
                        strokeDashArray: 3,
                        xaxis: { lines: { show: true } } 
                    },
                    yaxis: {
                        labels: { formatter: (val) => formatRevenue(val) }
                    },
                    xaxis: { categories: data.labels },
                    legend: { position: 'top', horizontalAlign: 'right' },
                    tooltip: {
                        shared: true,
                        intersect: false,
                        y: { formatter: (val) => "$" + Math.abs(val).toLocaleString() }
                    }
                };

                if (comparisonChart) comparisonChart.destroy();
                comparisonChart = new ApexCharts(document.querySelector("#comparisonChart"), barOptions);
                comparisonChart.render();

                // 2. 更新實心漸層圓環 (Smooth Gradient Radial Bar)
                const absGrowth = Math.min(Math.abs(data.growthRate), 100);
                const radialOptions = {
                    series: [absGrowth],
                    chart: {
                        type: 'radialBar',
                        height: 250,
                        sparkline: { enabled: true }
                    },
                    plotOptions: {
                        radialBar: {
                            startAngle: -135,
                            endAngle: 135,
                            hollow: { size: '70%' },
                            track: { 
                                background: '#f2f2f2', 
                                strokeWidth: '100%',
                                margin: 5
                            },
                            dataLabels: {
                                name: { show: false },
                                value: {
                                    offsetY: 10,
                                    fontSize: '32px',
                                    color: data.growthRate >= 0 ? '#696cff' : '#ff3e1d',
                                    fontWeight: 'bold',
                                    formatter: () => (data.growthRate > 0 ? '+' : '') + data.growthRate + '%'
                                }
                            }
                        }
                    },
                    fill: {
                        type: 'gradient',
                        gradient: {
                            shade: 'dark',
                            type: 'horizontal',
                            shadeIntensity: 0.5,
                            gradientToColors: [data.growthRate >= 0 ? '#71dd37' : '#ffab00'],
                            inverseColors: true,
                            opacityFrom: 1,
                            opacityTo: 1,
                            stops: [0, 100]
                        }
                    },
                    stroke: { 
                        lineCap: 'round'
                    },
                    colors: [data.growthRate >= 0 ? '#696cff' : '#ff3e1d'],
                    labels: ['Growth']
                };

                if (growthGaugeChart) growthGaugeChart.destroy();
                growthGaugeChart = new ApexCharts(document.querySelector("#growthGaugeChart"), radialOptions);
                growthGaugeChart.render();

            }).fail(function(err) {
                console.error("Year Comparison Chart failed:", err);
            });
        }
    </script>
}