        function updateGrowth(selector, rate, invert) {
            const el = $(selector);
            const isNegative = rate < 0;
            el.removeClass('text-success text-danger');
            let colorClass = isNegative ? 'text-danger' : 'text-success';
            if(invert) colorClass = isNegative ? 'text-success' : 'text-danger';
            el.addClass(colorClass).html(`${rate >= 0 ? '↑' : '↓'} ${Math.abs(rate)}% <span class="text-muted fw-normal">vs 前期</span>`);
        }

        // 通用營收格式化函式 (自動轉 萬，支援正負數)
        function formatRevenue(val) {
            if (val === null || val === undefined) return '$0';
            var num = parseFloat(val);
            var absNum = Math.abs(num);
            if (absNum >= 10000) {
                var sign = num < 0 ? '-' : '';
                return sign + (absNum / 10000).toFixed(1) + ' 萬';
            }
            return num.toLocaleString();
        }

