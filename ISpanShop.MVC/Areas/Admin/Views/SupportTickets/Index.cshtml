@model IEnumerable<ISpanShop.MVC.Areas.Admin.Models.Support.SupportTicketVm>

@{
    ViewData["Title"] = "客服工單管理";
    Layout = "_SneatLayout";
}

<style>
    .highlight-row {
        background-color: #d4edda !important; /* 淡綠色 */
        transition: background-color 1s ease-in-out;
        box-shadow: inset 0 0 10px rgba(40, 167, 69, 0.2);
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="mb-0">客服工單管理</h2>
        
        <div class="d-flex gap-2">
            @* 展示與測試工具下拉選單 *@
            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    🛠️ 展示/測試工具
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li>
                        <form asp-action="GenerateTestTickets" method="post" id="genTicketsForm">
                            <button type="button" class="dropdown-item" onclick="confirmAction('genTicketsForm', '生成測試工單', '系統將會隨機生成 20 筆客服工單。')">
                                <i class="bx bx-plus-circle me-2 text-info"></i>生成 20 筆工單
                            </button>
                        </form>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-action="ClearAllTickets" method="post" id="clearTicketsForm">
                            <button type="button" class="dropdown-item text-danger" onclick="confirmAction('clearTicketsForm', '清空所有工單', '此操作將會刪除目前資料庫中所有的客服工單！')">
                                <i class="bx bx-trash me-2"></i>清空所有資料
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bx bx-check-circle me-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>單號</th>
                <th>主旨</th>
                <th>分類</th>
                <th>建立時間</th>
                <th>狀態</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int? processedId = TempData["ProcessedTicketId"] as int?;
                foreach (var item in Model)
                {
                    <tr class="@(item.Id == processedId ? "table-success highlight-row" : "")">
                        <td>#@item.Id</td>
                        <td>@item.Subject</td>
                        <td>
                            <span class="badge border border-secondary text-secondary">@item.CategoryName</span>
                        </td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (item.Status == 0)
                            {
                                <span class="badge bg-warning text-dark">待處理</span>
                            }
                            else if (item.Status == 1)
                            {
                                <span class="badge bg-primary">處理中</span>
                            }
                            else if (item.Status == 2)
                            {
                                <span class="badge bg-success">已結案</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Process" asp-route-id="@item.Id" asp-route-page="@ViewBag.CurrentPage">處理</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">目前沒有任何客服工單。</td>
                </tr>
            }
        </tbody>
    </table>

    @* 分頁控制項 *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1"><i class="tf-icon bx bx-chevrons-left"></i></a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@ViewBag.TotalPages"><i class="tf-icon bx bx-chevrons-right"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        function confirmAction(formId, title, text) {
            Swal.fire({
                title: title,
                text: text,
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: title.includes('清空') ? '#d33' : '#3085d6',
                cancelButtonColor: '#aaa',
                confirmButtonText: '確定執行',
                cancelButtonText: '取消'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(formId).submit();
                }
            })
        }
    </script>
}