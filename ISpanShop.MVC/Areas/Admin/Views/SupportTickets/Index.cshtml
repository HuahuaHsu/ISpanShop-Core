@model IEnumerable<ISpanShop.MVC.Areas.Admin.Models.Support.SupportTicketVm>

@{
    ViewData["Title"] = "客服工單管理";

    Layout = "_SneatLayout";}

<div class="container mt-4">
    <h2 class="text-center">客服工單管理</h2>
    <hr />

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>單號</th>
                <th>主旨</th>
                <th>分類</th>
                <th>建立時間</th>
                <th>狀態</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.Subject</td>
                        <td>
                            <span class="badge border border-secondary text-secondary">@item.CategoryName</span>
                        </td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @* 根據狀態顯示不同顏色的標籤 *@
                            @if (item.Status == 0)
                            {
                                <span class="badge bg-warning text-dark">待處理</span>
                            }
                            else if (item.Status == 1)
                            {
                                <span class="badge bg-primary">處理中</span>
                            }
                            else if (item.Status == 2)
                            {
                                <span class="badge bg-success">已結案</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">未知狀態</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Process" asp-route-id="@item.Id">處理</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">目前沒有任何客服工單。</td>
                </tr>
            }
        </tbody>
    </table>

    @* 分頁控制項 *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @* 回第一頁 & 上一頁 *@
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1">
                        <i class="tf-icon bx bx-chevrons-left"></i>
                    </a>
                </li>
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">
                        <i class="tf-icon bx bx-chevron-left"></i>
                    </a>
                </li>

                @* 頁碼 *@
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                @* 下一頁 & 最後一頁 *@
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">
                        <i class="tf-icon bx bx-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@ViewBag.TotalPages">
                        <i class="tf-icon bx bx-chevrons-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>