@model IEnumerable<ISpanShop.MVC.Models.ViewModels.OrderReviewVm>

@{
    ViewData["Title"] = "評論管理";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="mb-0">商品評論審核與管理</h2>
        
        <div class="d-flex gap-2">
            @* 展示與測試工具下拉選單 *@
            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    🛠️ 展示/測試工具
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li>
                        <form asp-action="GenerateTestReviews" method="post" id="genReviewsForm">
                            <button type="button" class="dropdown-item" onclick="confirmAction('genReviewsForm', '生成測試評論', '系統將會隨機生成 30 筆商品評論。')">
                                <i class="bx bx-plus-circle me-2 text-info"></i>生成 30 筆評論
                            </button>
                        </form>
                    </li>
                    <li>
                        <form asp-action="TestAutoModeration" method="post" id="testModForm">
                            <button type="button" class="dropdown-item" onclick="confirmAction('testModForm', '模擬敏感字偵測', '系統將會生成一筆包含「詐騙集團」等字眼的評論，測試自動標記功能。')">
                                <i class="bx bx-bot me-2 text-warning"></i>模擬敏感字偵測
                            </button>
                        </form>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-action="ClearAllReviews" method="post" id="clearReviewsForm">
                            <button type="button" class="dropdown-item text-danger" onclick="confirmAction('clearReviewsForm', '清空所有評論', '此操作將會刪除目前資料庫中所有的商品評論！')">
                                <i class="bx bx-trash me-2"></i>清空所有資料
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bx bx-check-circle me-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-hover mt-3 align-middle">
        <thead class="table-dark">
            <tr>
                <th>評論 ID</th>
                <th>訂單編號</th>
                <th>星等</th>
                <th style="width: 40%;">內容</th>
                <th>發表時間</th>
                <th>目前狀態</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr class="@(item.IsHidden ? "table-secondary text-muted" : "")">
                        <td># @item.Id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                @{
                                    var mainImg = item.ProductMainImage;
                                    if (!string.IsNullOrEmpty(mainImg) && !mainImg.StartsWith("http") && !mainImg.StartsWith("/")) {
                                        mainImg = "/images/" + mainImg;
                                    }
                                }
                                <img src="@mainImg" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;" onerror="this.src='/images/no-image.png';" />
                                <span># @item.OrderId</span>
                            </div>
                        </td>
                        <td class="text-warning">
                            @for (int i = 0; i < item.Rating; i++) { <span>★</span> }
                            @for (int i = item.Rating; i < 5; i++) { <span>☆</span> }
                        </td>
                        <td>
                            @if (item.IsAutoFlagged)
                            {
                                <span class="badge bg-warning text-dark mb-1"><i class="fas fa-exclamation-triangle"></i> 系統偵測到敏感字</span><br />
                            }
                            @item.Comment 
                            
                            @if (item.ImageUrls != null && item.ImageUrls.Any())
                            {
                                <div class="review-images mt-2 d-flex flex-wrap gap-2">
                                    @foreach (var imgUrl in item.ImageUrls)
                                    {
                                        <a href="@imgUrl" target="_blank" class="review-image-link">
                                            <img src="@imgUrl" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.src='/images/no-image.png';" />
                                        </a>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(item.StoreReply))
                            {
                                <div class="text-success small mt-1"><strong>賣家回覆：</strong> @item.StoreReply</div>
                            }
                        </td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (item.IsHidden) { <span class="badge bg-danger">已隱藏</span> }
                            else { <span class="badge bg-success">正常顯示</span> }
                        </td>
                        <td>
                            <form asp-action="ToggleHidden" asp-route-id="@item.Id" method="post" style="display:inline;" class="toggle-hidden-form">
                                @if (item.IsHidden)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-success btn-toggle-hidden" data-title="確定要解除隱藏嗎？" data-text="前台將恢復顯示這筆評論。" data-confirm-text="解除隱藏">解除隱藏</button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-toggle-hidden" data-title="確定要隱藏這筆評論嗎？" data-text="前台將不再顯示這筆評論。" data-confirm-text="確定隱藏">隱藏違規</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center text-muted py-4">目前沒有任何商品評論。</td></tr>
            }
        </tbody>
    </table>

    @* 分頁控制項 *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1"><i class="tf-icon bx bx-chevrons-left"></i></a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@ViewBag.TotalPages"><i class="tf-icon bx bx-chevrons-right"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.btn-toggle-hidden').on('click', function (e) {
                const $btn = $(this);
                const $form = $btn.closest('form');
                const title = $btn.data('title');
                const isHidden = $btn.hasClass('btn-outline-danger');

                Swal.fire({
                    title: isHidden ? `<span style="color: #d33; font-weight: bold;">${title}</span>` : title,
                    text: $btn.data('text'),
                    icon: isHidden ? 'warning' : 'question',
                    showCancelButton: true,
                    confirmButtonColor: isHidden ? '#d33' : '#28a745',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: $btn.data('confirm-text'),
                    cancelButtonText: '取消',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) { $form.submit(); }
                });
            });
        });

        function confirmAction(formId, title, text) {
            Swal.fire({
                title: title,
                text: text,
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: title.includes('清空') ? '#d33' : '#3085d6',
                cancelButtonColor: '#aaa',
                confirmButtonText: '確定執行',
                cancelButtonText: '取消'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(formId).submit();
                }
            })
        }
    </script>
}