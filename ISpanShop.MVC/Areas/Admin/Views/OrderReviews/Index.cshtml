@model IEnumerable<ISpanShop.MVC.Models.ViewModels.OrderReviewVm>

@{
    ViewData["Title"] = "評論管理";
}

<div class="container mt-4">
    <h2>商品評論審核與管理</h2>
    <hr />

    <table class="table table-striped table-hover mt-3 align-middle">
        <thead class="table-dark">
            <tr>
                <th>評論 ID</th>
                <th>訂單編號</th>
                <th>星等</th>
                <th style="width: 40%;">內容</th>
                <th>發表時間</th>
                <th>目前狀態</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    // 根據隱藏狀態決定整行的背景色，被隱藏的稍微反灰
                    <tr class="@(item.IsHidden ? "table-secondary text-muted" : "")">
                        <td># @item.Id</td>
                        <td> @item.OrderId</td>
                        <td class="text-warning">
                            @for (int i = 0; i < item.Rating; i++)
                            {
                                <span>★</span>
                            }
                            @for (int i = item.Rating; i < 5; i++)
                            {
                                <span>☆</span>
                            }
                        </td>
                        <td>
                            @if (item.IsAutoFlagged)
                            {
                                <span class="badge bg-warning text-dark mb-1">
                                    <i class="fas fa-exclamation-triangle"></i> 系統偵測到敏感字
                                </span>
                                <br />
                            }
                            @item.Comment @if (!string.IsNullOrEmpty(item.SellerReply))
                            {
                                <div class="text-success small mt-1">
                                    <strong>賣家回覆：</strong> @item.SellerReply
                                </div>
                            }
                        </td>
                        <td> @item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (item.IsHidden)
                            {
                                <span class="badge bg-danger">已隱藏</span>
                            }
                            else
                            {
                                <span class="badge bg-success">正常顯示</span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleHidden" asp-route-id="@item.Id" method="post" style="display:inline;">
                                @if (item.IsHidden)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success">解除隱藏</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('確定要隱藏這筆評論嗎？前台將不再顯示。');">隱藏違規</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">目前沒有任何商品評論。</td>
                </tr>
            }
        </tbody>
    </table>

    @* 分頁控制項 *@
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @* 回第一頁 & 上一頁 *@
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="1">
                        <i class="tf-icon bx bx-chevrons-left"></i>
                    </a>
                </li>
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">
                        <i class="tf-icon bx bx-chevron-left"></i>
                    </a>
                </li>

                @* 頁碼 *@
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }

                @* 下一頁 & 最後一頁 *@
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">
                        <i class="tf-icon bx bx-chevron-right"></i>
                    </a>
                </li>
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@ViewBag.TotalPages">
                        <i class="tf-icon bx bx-chevrons-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
