@model ISpanShop.MVC.Areas.Admin.Models.Products.ProductDetailVm
@using System.Text.Json

@{
    Layout = "~/Views/Shared/_SneatLayout.cshtml";
    ViewData["Title"] = $"商品詳情 - {Model?.Name ?? "未知"}";

    // 狀態 pill CSS class
    var stClass = Model?.Status switch
    {
        1 => "st-success",
        2 => "st-warning",
        3 => "st-danger",
        0 => "st-secondary",
        _ => "st-secondary"
    };

    // 解析規格維度欄位名稱（優先 SpecDefinitionJson → SpecValueJson keys → 單欄 fallback）
    var dimNames = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model?.SpecDefinitionJson) && Model.SpecDefinitionJson != "[]")
    {
        try
        {
            var arr = JsonSerializer.Deserialize<JsonElement[]>(Model.SpecDefinitionJson);
            if (arr != null)
                dimNames = arr
                    .Where(el => el.TryGetProperty("name", out _))
                    .Select(el => el.GetProperty("name").GetString() ?? "")
                    .Where(n => n.Length > 0)
                    .ToList();
        }
        catch { }
    }
    if (dimNames.Count == 0 && Model?.Variants != null)
    {
        var firstWithSpec = Model.Variants.FirstOrDefault(v => !v.IsDeleted && v.SpecValues.Count > 0);
        if (firstWithSpec != null) dimNames = firstWithSpec.SpecValues.Keys.ToList();
    }
    bool hasMultiDims = dimNames.Count > 0;
}

@* ────────────────── 待審核 Action Bar ────────────────── *@
@if (Model.Status == 2)
{
    <div class="alert alert-warning border-0 rounded-3 mb-4 d-flex align-items-center justify-content-between shadow-sm" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i class="bx bx-time-five fs-4"></i>
            <div>
                <strong>此商品正等待人工審核</strong>
                <div class="small text-muted mt-1">請仔細檢查商品資訊後，選擇核准上架或退回修改。</div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm px-3" onclick="approveProduct(@Model.Id)">
                <i class="bx bx-check me-1"></i>核准上架
            </button>
            <button class="btn btn-danger btn-sm px-3" data-bs-toggle="modal" data-bs-target="#rejectModal">
                <i class="bx bx-x me-1"></i>退回修改
            </button>
        </div>
    </div>
}

@* ────────────────── 退回原因顯示區 ────────────────── *@
@if (Model.Status == 3 && !string.IsNullOrWhiteSpace(Model.RejectReason))
{
    <div class="alert alert-danger border-0 rounded-3 mb-4 shadow-sm" role="alert">
        <div class="d-flex align-items-center gap-2 mb-1">
            <i class="bx bx-error-circle fs-5"></i>
            <strong>審核退回原因</strong>
        </div>
        <p class="mb-0 ms-4 text-danger-emphasis">@Model.RejectReason</p>
    </div>
}


@* ────────────────── 成功訊息 ────────────────── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible border-0 rounded-3 shadow-sm mb-4 d-flex align-items-center gap-2" role="alert">
        <i class="bx bx-check-circle fs-5"></i>
        <span>@TempData["SuccessMessage"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* ────────────────── 頁面標題列 ────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="color:#1e2d3d;">商品詳情</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 fs-sm">
                <li class="breadcrumb-item"><a href="@(ViewBag.ReturnUrl ?? Url.Action("Index", "Products"))">@(ViewBag.ReturnUrl != null && ((string)ViewBag.ReturnUrl).Contains("Inventory") ? "庫存監控" : "商品總覽")</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        @if (Model.Status == 1)
        {
            <button class="btn btn-danger btn-sm px-3" data-bs-toggle="modal" data-bs-target="#forceUnpublishModal">
                <i class="bx bx-block me-1"></i>強制下架
            </button>
        }
        <a href="@(ViewBag.ReturnUrl ?? Url.Action("Index", "Products"))" class="btn btn-outline-secondary btn-sm">
            <i class="bx bx-arrow-back me-1"></i>返回
        </a>
    </div>
</div>

@* ────────────────── 主體雙欄佈局 ────────────────── *@
<div class="row g-4 mb-4">

    @* 左欄：圖片輪播 *@
    <div class="col-lg-5">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            @if (Model.Images != null && Model.Images.Any())
            {
                <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Model.Images[i]" class="d-block w-100 product-main-img" alt="商品圖片 @(i + 1)" loading="lazy">
                            </div>
                        }
                    </div>
                    @if (Model.Images.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }
                </div>
                @if (Model.Images.Count > 1)
                {
                    <div class="d-flex gap-2 p-3 overflow-auto bg-white border-top">
                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            <img src="@Model.Images[i]" class="product-thumb" alt="縮圖 @(i + 1)" loading="lazy"
                                 data-bs-target="#productCarousel" data-bs-slide-to="@i" />
                        }
                    </div>
                }
            }
            else
            {
                <div class="no-image-placeholder">
                    <i class="bx bx-image-alt"></i>
                    <p class="mb-0 text-muted">尚無商品圖片</p>
                </div>
            }
        </div>
    </div>

    @* 右欄：商品資訊卡 *@
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-body p-4">

                @* 商店 / 分類 / 品牌 標籤 *@
                <div class="d-flex flex-wrap gap-2 mb-3">

                    @* 商店 *@
                    <span style="display:inline-flex;align-items:center;gap:4px;
                                 background:#e8eeff !important;color:#3d5afe !important;
                                 padding:4px 12px;border-radius:8px;font-size:.82rem;font-weight:600;
                                 border:1px solid #c5cffe">
                        <i class="bi bi-shop"></i>@Model.StoreName
                    </span>

                    @* 分類 *@
                    @if (!string.IsNullOrEmpty(Model.CategoryName))
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;
                                     background:#e8f5e9 !important;color:#1b5e20 !important;
                                     padding:4px 12px;border-radius:8px;font-size:.82rem;font-weight:600;
                                     border:1px solid #c8e6c9">
                            <i class="bi bi-tag"></i>@Model.CategoryName
                        </span>
                    }

                    @* 品牌 *@
                    @if (!string.IsNullOrEmpty(Model.BrandName))
                    {
                        <span style="display:inline-flex;align-items:center;gap:4px;
                                     background:#fce4ec !important;color:#880e4f !important;
                                     padding:4px 12px;border-radius:8px;font-size:.82rem;font-weight:600;
                                     border:1px solid #f8bbd0">
                            <i class="bi bi-bookmark"></i>@Model.BrandName
                        </span>
                    }
                </div>

                @* 商品名稱 *@
                <h3 class="fw-bold mb-3" style="color:#1e2d3d;">@Model.Name</h3>

                @* 狀態 Pill *@
                <div class="mb-3">
                    <span class="st-pill @stClass">
                        @Model.StatusText
                    </span>
                </div>

                <hr class="my-3">

                @* 價格區間 *@
                @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
                {
                    <div class="mb-3">
                        <span class="text-muted small">售價範圍</span>
                        <div class="fw-bold fs-4 text-primary">
                            @if (Model.MinPrice == Model.MaxPrice)
                            {
                                @($"NT$ {Model.MinPrice:N0}")
                            }
                            else
                            {
                                @($"NT$ {Model.MinPrice:N0} ~ {Model.MaxPrice:N0}")
                            }
                        </div>
                    </div>
                }

                @* 四格統計資訊 *@
                <div class="row g-2 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="info-stat-box">
                            <div class="info-stat-label">規格數</div>
                            <div class="info-stat-value">@(Model.Variants?.Count ?? 0)</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-stat-box">
                            <div class="info-stat-label">圖片數</div>
                            <div class="info-stat-value">@(Model.Images?.Count ?? 0)</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-stat-box">
                            <div class="info-stat-label">銷售量</div>
                            <div class="info-stat-value">@(Model.TotalSales?.ToString("N0") ?? "-")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-stat-box">
                            <div class="info-stat-label">瀏覽數</div>
                            <div class="info-stat-value">@(Model.ViewCount?.ToString("N0") ?? "-")</div>
                        </div>
                    </div>
                </div>

                @* 商品描述 *@
                <div class="mb-3">
                    <div class="small text-muted fw-semibold mb-1 text-uppercase" style="letter-spacing:1px;">商品描述</div>
                    <p class="text-secondary mb-0 lh-lg">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "賣家尚未填寫商品描述。" : Model.Description)
                    </p>
                </div>

                @* ── 時間軸（由新到舊） ── *@
                <hr class="my-3">
                <div class="audit-timeline">

                    @* 最後更新 *@
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="tl-item">
                            <div class="tl-dot tl-dot-gray"></div>
                            <div class="tl-body">
                                <div class="tl-label">最後更新</div>
                                <div class="tl-time">@Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                            </div>
                        </div>
                    }

                    @* 審核節點 *@
                    @if (Model.ReviewStatus == 1)
                    {
                        <div class="tl-item">
                            <div class="tl-dot tl-dot-green"></div>
                            <div class="tl-body">
                                <div class="tl-label">審核通過 <span class="tl-reviewer">@(Model.ReviewedBy ?? "—")</span></div>
                                <div class="tl-time">@(Model.ReviewDate?.ToString("yyyy/MM/dd HH:mm") ?? "—")</div>
                            </div>
                        </div>
                    }
                    else if (Model.ReviewStatus == 2)
                    {
                        <div class="tl-item">
                            <div class="tl-dot tl-dot-red"></div>
                            <div class="tl-body">
                                <div class="tl-label">審核退回 <span class="tl-reviewer">@(Model.ReviewedBy ?? "—")</span></div>
                                <div class="tl-time">@(Model.ReviewDate?.ToString("yyyy/MM/dd HH:mm") ?? "—")</div>
                                @if (!string.IsNullOrWhiteSpace(Model.RejectReason))
                                {
                                    <div class="tl-reason">@Model.RejectReason</div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="tl-item">
                            <div class="tl-dot tl-dot-gray"></div>
                            <div class="tl-body">
                                <div class="tl-label">待審核</div>
                            </div>
                        </div>
                    }

                    @* 建檔 *@
                    @if (Model.CreatedAt.HasValue)
                    {
                        <div class="tl-item tl-last">
                            <div class="tl-dot tl-dot-gray"></div>
                            <div class="tl-body">
                                <div class="tl-label">建檔</div>
                                <div class="tl-time">@Model.CreatedAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                            </div>
                        </div>
                    }

                </div>

            </div>
        </div>
    </div>
</div>

@* ────────────────── 規格與庫存明細 ────────────────── *@
<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0" style="color:#1e2d3d;">
            <i class="bx bx-list-ul me-2 text-primary"></i>規格與庫存明細
        </h5>
    </div>
    <div class="card-body px-4 pb-4">
        @if (Model.Variants != null && Model.Variants.Any())
        {
            <div class="table-responsive mt-3">
                <table class="table table-hover align-middle mb-0 spec-table">
                    <thead>
                        <tr>
                            <th>SKU 代碼</th>
                            @if (hasMultiDims)
                            {
                                foreach (var dim in dimNames)
                                {
                                    <th>@dim</th>
                                }
                            }
                            else
                            {
                                <th>規格名稱</th>
                            }
                            <th class="text-end">售價</th>
                            <th class="text-center">庫存</th>
                            <th class="text-center">安全庫存</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model.Variants)
                        {
                            <tr>
                                <td><code class="sku-code">@v.SkuCode</code></td>
                                @if (hasMultiDims)
                                {
                                    foreach (var dim in dimNames)
                                    {
                                        var cellVal = v.SpecValues.TryGetValue(dim, out var sv) ? sv : "-";
                                        <td class="fw-medium">@cellVal</td>
                                    }
                                }
                                else
                                {
                                    <td class="fw-medium">@v.VariantName</td>
                                }
                                <td class="text-end fw-bold text-primary">NT$ @v.Price.ToString("N0")</td>
                                <td class="text-center">
                                    @{
                                        var stock = v.Stock ?? 0;
                                    }
                                    @if (stock > 10)
                                    {
                                        <span class="stk-ok">@stock 件</span>
                                    }
                                    else if (stock > 0)
                                    {
                                        <span class="stk-low">緊張 @stock 件</span>
                                    }
                                    else
                                    {
                                        <span class="stk-out">已售罄</span>
                                    }
                                </td>
                                <td class="text-center text-muted small">
                                    @(v.SafetyStock.HasValue ? v.SafetyStock.Value.ToString() : "-")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bx bx-package fs-1 d-block mb-2 opacity-50"></i>
                <p class="mb-1">暫無規格資訊</p>
            </div>
        }
    </div>
</div>

@* ────────────────── 強制下架 Modal ────────────────── *@
<div class="modal fade" id="forceUnpublishModal" tabindex="-1" aria-labelledby="forceUnpublishModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="forceUnpublishModalLabel">
                    <i class="bx bx-block text-danger me-2"></i>強制下架商品
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">強制下架後，商品將立即從前台隱藏。此操作僅限管理員執行。</p>
                <label class="form-label fw-medium mb-2">下架原因（選填）</label>
                <textarea id="forceUnpublishReasonInput" class="form-control" rows="3"
                          placeholder="請輸入下架原因，將記錄於系統中..."></textarea>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger" onclick="confirmForceUnpublish(@Model.Id)">
                    <i class="bx bx-block me-1"></i>確認強制下架
                </button>
            </div>
        </div>
    </div>
</div>

@* ────────────────── 退回原因 Modal ────────────────── *@
<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="rejectModalLabel">
                    <i class="bx bx-x-circle text-danger me-2"></i>退回商品審核
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label fw-medium mb-2">退回原因 <span class="text-danger">*</span></label>
                <textarea id="rejectReasonInput" class="form-control" rows="4"
                          placeholder="請輸入退回原因，賣家將會看到此說明..."></textarea>
                <div id="rejectReasonError" class="text-danger small mt-1 d-none">請填寫退回原因。</div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger" onclick="confirmReject(@Model.Id)">
                    <i class="bx bx-x me-1"></i>確認退回
                </button>
            </div>
        </div>
    </div>
</div>

@* ────────────────── AJAX Scripts ────────────────── *@
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    async function approveProduct(id) {
        const result = await Swal.fire({
            title: '確認核准上架', text: '確定要核准此商品上架嗎？',
            icon: 'question', showCancelButton: true,
            confirmButtonColor: '#38a169', cancelButtonColor: '#a0aec0',
            confirmButtonText: '確認上架', cancelButtonText: '取消'
        });
        if (!result.isConfirmed) return;

        const data = await apiPost('/Admin/Products/ApproveProduct', { id });
        if (data.success) {
            await Swal.fire({ title: '成功', text: data.message, icon: 'success', timer: 1500 });
            location.reload();
        } else {
            Swal.fire({ title: '失敗', text: '操作失敗，請稍後再試。', icon: 'error' });
        }
    }

    async function confirmReject(id) {
        const reason = document.getElementById('rejectReasonInput').value.trim();
        const errEl = document.getElementById('rejectReasonError');
        if (!reason) { errEl.classList.remove('d-none'); return; }
        errEl.classList.add('d-none');

        const data = await apiPost('/Admin/Products/RejectProduct', { id, reason });
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('rejectModal'))?.hide();
            await Swal.fire({ title: '已退回', text: data.message, icon: 'success', timer: 1800 });
            location.reload();
        } else {
            Swal.fire({ title: '失敗', text: '操作失敗，請稍後再試。', icon: 'error' });
        }
    }

    async function confirmForceUnpublish(id) {
        const reason = document.getElementById('forceUnpublishReasonInput').value.trim();
        const data = await apiPost('/Admin/Products/ForceUnpublish', { id, reason });
        bootstrap.Modal.getInstance(document.getElementById('forceUnpublishModal'))?.hide();
        if (data.success) {
            await Swal.fire({ title: '已強制下架', text: data.message, icon: 'success', timer: 1800 });
            location.reload();
        } else {
            Swal.fire({ title: '操作失敗', text: data.message, icon: 'error' });
        }
    }
</script>

@* ────────────────── 頁面樣式 ────────────────── *@
<style>
    .product-main-img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        background-color: #f8f9fa;
    }

    .product-thumb {
        width: 64px;
        height: 64px;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        opacity: 0.65;
        border: 2px solid transparent;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    .product-thumb:hover {
        opacity: 1;
        border-color: #0D9488;
        transform: translateY(-2px);
    }

    .no-image-placeholder {
        aspect-ratio: 1 / 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        color: #adb5bd;
    }
    .no-image-placeholder i { font-size: 3rem; margin-bottom: 0.5rem; }

    .info-stat-box {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        text-align: center;
    }
    .info-stat-label { font-size: 0.75rem; color: #8592a3; }
    .info-stat-value { font-size: 1.25rem; font-weight: 700; color: #1e2d3d; }

    /* 狀態 Pill */
    .st-pill {
        display:inline-flex !important;
        align-items:center !important;
        gap:5px !important;
        padding:5px 14px !important;
        border-radius:20px !important;
        font-size:.85rem !important;
        font-weight:600 !important;
    }
    .st-success   { background:#e6f4ea !important; color:#1b5e20 !important; border:1px solid #c8e6c9; }
    .st-warning   { background:#fff8e1 !important; color:#e65100 !important; border:1px solid #ffe082; }
    .st-danger    { background:#fde8e8 !important; color:#b71c1c !important; border:1px solid #ffcdd2; }
    .st-secondary { background:#f5f5f5 !important; color:#424242 !important; border:1px solid #e0e0e0; }

    /* 規格表 */
    .spec-table th {
        background-color: #f8f9fa;
        font-size: 0.8rem;
        font-weight: 600;
        color: #8592a3;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.85rem 1rem;
        border-bottom: none;
        white-space: nowrap;
    }
    .spec-table td {
        padding: 0.85rem 1rem;
        border-bottom: 1px solid #f0f2f5;
