    <script>
    // ── AJAX 分頁：面板展開時換頁不重整（近期退回紀錄 Tab）──
    (function () {
        function _reviewBindRejectedRows() {
            document.querySelectorAll('#rejectedPanel tbody tr[data-id]').forEach(function (tr) {
                tr.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input')) return;
                    openProductOffcanvas(parseInt(this.dataset.id), this.dataset.name);
                });
            });
            // 重綁 per-row checkbox（重置批次列的選取狀態）
            var batchBar = document.getElementById('rejectedBatchBar');
            var batchBtn = document.getElementById('btnBatchUndoReject');
            var countEl  = document.getElementById('rejected-selected-count');
            if (countEl) countEl.textContent = '0';
            if (batchBtn) batchBtn.disabled = true;
            document.querySelectorAll('#rejectedPanel .rejected-row-check').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var checked = document.querySelectorAll('#rejectedPanel .rejected-row-check:checked').length;
                    if (countEl) countEl.textContent = checked;
                    if (batchBar) batchBar.style.removeProperty('display');
                    if (batchBtn) batchBtn.disabled = (checked === 0);
                });
            });
            var allCheck = document.getElementById('selectAllRejected');
            if (allCheck) {
                allCheck.checked = false;
                allCheck.addEventListener('change', function () {
                    document.querySelectorAll('#rejectedPanel .rejected-row-check').forEach(function (cb) {
                        cb.checked = allCheck.checked;
                        cb.dispatchEvent(new Event('change'));
                    });
                });
            }
        }

        function ajaxLoadRejectedPage(href) {
            var fetchUrl   = href.split('#')[0];          // 去除 #rejectedTab hash 後再 fetch
            var tabContent = document.getElementById('reviewTabsContent');
            var listCol    = document.getElementById('reviewListCol');
            if (tabContent) tabContent.style.opacity = '0.4';
            fetch(fetchUrl)
                .then(function (res) { if (!res.ok) throw new Error(); return res.text(); })
                .then(function (html) {
                    var doc = new DOMParser().parseFromString(html, 'text/html');
                    // 更新退回紀錄表格 tbody
                    var newTbody = doc.querySelector('#rejectedPanel .table-custom tbody');
                    var tbody    = document.querySelector('#rejectedPanel .table-custom tbody');
                    if (tbody && newTbody) tbody.innerHTML = newTbody.innerHTML;
                    // 更新退回紀錄分頁導航
                    var newNav = doc.querySelector('#rejectedPanel nav');
                    var curNav = document.querySelector('#rejectedPanel nav');
                    if (curNav && newNav) curNav.outerHTML = newNav.outerHTML;
                    // 重綁行點擊與 checkbox（含倒數 — setInterval 會自動接管新 .live-countdown）
                    _reviewBindRejectedRows();
                    // 滾回頂部
                    if (listCol) listCol.scrollTop = 0;
                    // 恢復透明度
                    if (tabContent) tabContent.style.opacity = '1';
                    // 自動開啟第一筆
                    _activeProductRowId = null;
                    var firstRow = document.querySelector('#rejectedPanel tbody tr[data-id]');
                    if (firstRow) {
                        openProductOffcanvas(parseInt(firstRow.dataset.id), firstRow.dataset.name || '商品詳情');
                    }
                    // 同步網址列（保留 hash 讓 Tab 維持選中）
                    history.pushState(null, '', href);
                })
                .catch(function () { window.location.href = href; });
        }

        // 事件委派：攔截 #reviewListCol 內近期退回 Tab 的分頁點擊（面板已開啟時）
        document.getElementById('reviewListCol').addEventListener('click', function (e) {
            var panel = document.getElementById('productDetailPanel');
            if (!panel || !panel.classList.contains('open')) return;
            if (!e.target.closest('#rejectedPanel')) return;
            var link = e.target.closest('.page-link');
            if (!link) return;
            var pageItem = link.closest('.page-item');
            if (!pageItem || pageItem.classList.contains('disabled') || pageItem.classList.contains('active')) return;
            var href = link.getAttribute('href');
            if (!href || href === '#') return;
            e.preventDefault();
            ajaxLoadRejectedPage(href);
        });
    })();
    </script>
    <script>
    // ── Tab 切換時自動選中新 Tab 第一筆（面板開啟中）──
    document.getElementById('reviewTabs').addEventListener('shown.bs.tab', function (e) {
        var panel = document.getElementById('productDetailPanel');
        if (!panel || !panel.classList.contains('open')) return;
        var target = e.target.getAttribute('data-bs-target');
        var pane = target ? document.querySelector(target) : null;
        if (!pane) return;
        var firstRow = pane.querySelector('tbody tr[data-id]');
        if (firstRow) {
            openProductOffcanvas(parseInt(firstRow.dataset.id), firstRow.dataset.name || '商品詳情');
        } else {
            // 無資料時清空面板內容但保持面板開啟
            var body = document.getElementById('productDetailPanelBody');
            if (body) body.innerHTML = '<div class="text-center py-5 text-muted"><i class="bx bx-inbox" style="font-size:2.5rem;"></i><div class="mt-2">此分頁無資料</div></div>';
        }
    });
    </script>
