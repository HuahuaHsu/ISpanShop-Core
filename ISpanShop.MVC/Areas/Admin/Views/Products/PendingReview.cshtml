@{
    Layout = "~/Views/Shared/_SneatLayout.cshtml";
}
@model ISpanShop.Models.DTOs.Common.PagedResult<ISpanShop.MVC.Areas.Admin.Models.Products.ProductReviewListVm>

@{
    ViewData["Title"] = "商品審核中心";
    var rejectedPaged    = ViewBag.RejectedRecords as ISpanShop.Models.DTOs.Common.PagedResult<ISpanShop.MVC.Areas.Admin.Models.Products.ProductReviewListVm>;
    var rejectedList     = rejectedPaged?.Data;
    int rejectedPage     = ViewBag.RejectedPage ?? 1;
    var reApplyPaged     = ViewBag.ReApplyRecords as ISpanShop.Models.DTOs.Common.PagedResult<ISpanShop.MVC.Areas.Admin.Models.Products.ProductReviewListVm>;
    var reApplyList      = reApplyPaged?.Data ?? new List<ISpanShop.MVC.Areas.Admin.Models.Products.ProductReviewListVm>();
    int reApplyPage      = ViewBag.ReApplyPage ?? 1;
    var approvedPaged    = ViewBag.ApprovedRecords as ISpanShop.Models.DTOs.Common.PagedResult<ISpanShop.MVC.Areas.Admin.Models.Products.ProductReviewListVm>;
    var approvedList     = approvedPaged?.Data ?? new List<ISpanShop.MVC.Areas.Admin.Models.Products.ProductReviewListVm>();
    int approvedPage     = ViewBag.ApprovedPage ?? 1;
}

<div class="page-fluid-root container-fluid font-noto">
<div class="page-above-content">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold tracking-tight mb-1" style="color:#1e2d3d;">商品審核中心</h2>
            <p class="mb-0 fs-7" style="color:#4a5a6a;">
                待審核商品共 <span class="fw-bold text-warning" id="pendingCount">@(Model?.TotalCount ?? 0)</span> 筆
            </p>
        </div>
        <div class="d-flex justify-content-end gap-2 mb-3">
            <span id="pending-batch-tag" class="batch-tag d-none">
                <i class="bx bx-checkbox-checked"></i>
                已選取 <span id="pending-selected-count">0</span> 筆
                <button id="btn-clear-pending" type="button" class="batch-tag-close" aria-label="清除選取">×</button>
            </span>
            <button id="btnBatchApprove" class="btn btn-success rounded-pill px-4" disabled>
                <i class="bx bx-check-circle me-1"></i> 批次審核通過
            </button>
            <button id="btnBatchReject" class="btn btn-danger rounded-pill px-4" disabled>
                <i class="bx bx-x-circle me-1"></i> 批次審核退回
            </button>
            <button id="btnGenerateTestProducts" class="btn btn-secondary rounded-pill px-4">
                <i class="bx bx-data me-1"></i> 生成測試商品
            </button>
            <button id="btnSimulateAutoReview" class="btn btn-warning rounded-pill px-4">
                <i class="fas fa-robot me-1"></i> 模擬自動審核
            </button>
            <a href="@Url.Action("Index")" class="btn btn-back rounded-pill px-4">
                <i class="bx bx-arrow-back me-1"></i> 回商品總覽
            </a>
        @*
            手動清理按鈕已由前端 JS 自動觸發取代，暫時隱藏
            <form asp-action="ForceCleanupExpiredProducts" method="post"
                  onsubmit="return confirm('確認執行：將所有審核退回商品立即標記為已刪除（Demo 用）？');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="expirationSeconds" value="60" />
                <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold">
                    <i class="bx bx-trash me-1"></i> 手動清理過期退回商品
                </button>
            </form>
        *@
        </div>
    </div>

    @* Bootstrap Nav Tabs *@
    <ul class="nav nav-tabs mb-0 border-0" id="reviewTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active px-4 py-2 fw-semibold" id="pending-tab"
                    data-bs-toggle="tab" data-bs-target="#pendingPanel"
                    type="button" role="tab">
                <i class="bx bx-hourglass me-1 text-warning"></i>
                待審核
                <span class="badge rounded-pill ms-1"
                      style="background:#fef3c7;color:#92400e;font-size:0.78rem;">@(Model?.TotalCount ?? 0)</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link px-4 py-2 fw-semibold" id="reapply-tab"
                    data-bs-toggle="tab" data-bs-target="#reApplyPanel"
                    type="button" role="tab">
                <i class="bx bx-revision me-1" style="color:#dc2626;"></i>
                重新申請審核
                <span class="badge rounded-pill ms-1"
                      style="background:#fde8e8;color:#dc2626;font-size:0.78rem;">@(reApplyPaged?.TotalCount ?? 0)</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link px-4 py-2 fw-semibold" id="rejected-tab"
                    data-bs-toggle="tab" data-bs-target="#rejectedPanel"
                    type="button" role="tab">
                <i class="bx bx-x-circle me-1 text-danger"></i>
                近期退回紀錄
                <span class="badge rounded-pill ms-1" id="rejected-count-badge"
                      style="background:#fee2e2;color:#991b1b;font-size:0.78rem;">@(rejectedPaged?.TotalCount ?? 0)</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link px-4 py-2 fw-semibold" id="approved-tab"
                    data-bs-toggle="tab" data-bs-target="#approvedPanel"
                    type="button" role="tab">
                <i class="bx bx-check-circle me-1 text-success"></i>
                近期審核通過
                <span class="badge rounded-pill ms-1" id="approved-count-badge"
                      style="background:#d1fae5;color:#065f46;font-size:0.78rem;">@(approvedPaged?.TotalCount ?? 0)</span>
            </button>
        </li>
    </ul>

</div><!-- /page-above-content -->

    <div id="reviewLayout" class="split-layout">
    <div id="reviewListCol" class="split-list-col">

    @* ── 返回完整列表（精簡模式按鈕）── *@
    <div class="back-to-list-btn">
        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill"
                onclick="closeProductDetailPanel()" title="返回完整列表">
            <i class="bx bx-arrow-back me-1"></i>返回完整列表
        </button>
    </div>

    <div class="tab-content" id="reviewTabsContent">

        <div class="tab-pane fade show active" id="pendingPanel" role="tabpanel">
            <div class="filter-card rounded-top-0" style="border-top-left-radius:0!important;border-top-right-radius:0!important;">
                @if (Model != null && Model.Data != null && Model.Data.Any())
                {
                    <div>
                        <table class="table table-custom align-middle">
                            <thead>
                                <tr>
                                    <th style="width:44px;" class="text-center col-cb">
                                        <input class="form-check-input" type="checkbox" id="selectAll" title="全選 / 取消全選">
                                    </th>
                                    <th style="width:60px;" class="col-img">圖片</th>
                                    <th style="max-width:280px;">商品名稱</th>
                                    <th>審核狀態</th>
                                    <th class="col-store">商店</th>
                                    <th class="col-catbrand">分類 / 品牌</th>
                                    <th class="col-date">建檔日期</th>
                                    <th class="text-end col-rowact" style="min-width:200px;">審核操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in Model.Data)
                                {
                                    <tr data-id="@product.Id" data-name="@product.Name.Replace("'","\\'")">
                                        <td class="text-center cb-cell col-cb" style="width:44px;">
                                            <input class="form-check-input row-check" type="checkbox" value="@product.Id">
                                        </td>
                                        <td class="col-img">
                                            @if (!string.IsNullOrEmpty(product.MainImageUrl))
                                            {
                                                <img src="@product.MainImageUrl" alt="@product.Name" loading="lazy"
                                                     style="width:60px;height:60px;object-fit:cover;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.08);" />
                                            }
                                            else
                                            {
                                                <div style="width:60px;height:60px;border-radius:8px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">🖼️</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-bold product-name-cell" style="color:#1e2d3d;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                                 title="@product.Description"
                                                 data-bs-toggle="tooltip" data-bs-placement="top">
                                                @product.Name
                                            </div>
                                        </td>
                                        <td>
                                            @{
                                                var (badgeClass, badgeText) = product.ReviewStatus switch
                                                {
                                                    1 => ("bg-success", "✅ 已通過"),
                                                    2 => ("bg-danger",  "❌ 已退回"),
                                                    _ => ("bg-warning text-dark", "⏳ 待審核")
                                                };
                                            }
                                            <span class="badge @badgeClass">@badgeText</span>
                                        </td>
                                        <td class="col-store fs-7" style="color:#5a6a7a;">@(product.StoreName ?? $"Store #{product.StoreId}")</td>
                                        <td class="col-catbrand">
                                            <span class="badge-soft bg-primary-soft text-primary me-1">@product.CategoryName</span>
                                            <span class="badge-soft bg-info-soft text-info">@product.BrandName</span>
                                        </td>
                                        <td class="col-date fs-7" style="color:#4a5a6a;">@(product.CreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                        <td class="text-end col-rowact">
                                            <button class="btn btn-sm btn-approve rounded-pill px-3 me-1"
                                                    data-id="@product.Id" data-name="@product.Name">
                                                <i class="bx bx-check-circle me-1"></i>核准上架
                                            </button>
                                            <button class="btn btn-sm btn-reject rounded-pill px-3"
                                                    data-id="@product.Id" data-name="@product.Name">
                                                <i class="bx bx-x-circle me-1"></i>退回
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-3" style="color:#1abb9c;font-size:2.5rem;"><i class="bx bx-check-circle"></i></div>
                        <h5 class="fw-bold mb-1" style="color:#1e2d3d;">目前沒有待審核的商品</h5>
                        <p class="fs-7 mb-0" style="color:#718096;">所有商品均已完成審核，稍後再來查看。</p>
                    </div>
                }

                @* ── 待審核分頁 ── *@
                @if (Model != null)
                {
                    @await Html.PartialAsync("_Pagination", new ISpanShop.MVC.Areas.Admin.Models.Common.PaginationVm
                    {
                        CurrentPage = Model.CurrentPage,
                        TotalPages  = Model.TotalPages,
                        UrlForPage  = p => Url.Action("PendingReview", new { pendingPage = p, rejectedPage })!
                    })
                }
            </div>
        </div>

        @* ── 重新申請審核 Tab Panel ── *@
        <div class="tab-pane fade" id="reApplyPanel" role="tabpanel">
            <div class="filter-card rounded-top-0" style="border-top-left-radius:0!important;border-top-right-radius:0!important;">
                @if (reApplyList.Any())
                {
                    <div style="overflow-x:auto;min-width:0;">
                        <table class="table table-custom align-middle">
                            <thead>
                                <tr>
                                    <th style="width:60px;" class="col-img">圖片</th>
                                    <th>商品名稱</th>
                                    <th class="col-store">商店</th>
                                    <th class="col-reapply-reason">原始下架原因</th>
                                    <th class="col-date">下架時間</th>
                                    <th class="col-date">申請時間</th>
                                    <th class="text-end">審核操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in reApplyList)
                                {
                                    <tr data-id="@item.Id" data-name="@item.Name.Replace("'","\\'")">
                                        <td class="col-img">
                                            @if (!string.IsNullOrEmpty(item.MainImageUrl))
                                            {
                                                <img src="@item.MainImageUrl" alt="@item.Name" loading="lazy"
                                                     style="width:54px;height:54px;object-fit:cover;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,0.08);" />
                                            }
                                            else
                                            {
                                                <div style="width:54px;height:54px;border-radius:10px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">🖼️</div>
                                            }
                                        </td>
                                        <td class="product-name-cell">
                                            <div class="fw-semibold" style="color:#1e2d3d;">@item.Name</div>
                                        </td>
                                        <td class="fs-7 col-store" style="color:#5a6a7a;">@(item.StoreName ?? $"Store #{item.StoreId}")</td>
                                        <td class="col-reapply-reason">
                                            @if (!string.IsNullOrWhiteSpace(item.ForceOffShelfReason))
                                            {
                                                <span style="background:#fef2f2;color:#dc2626;border:1px solid #fca5a5;border-radius:6px;font-size:0.82rem;padding:0.3em 0.7em;display:inline-block;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                                      title="@item.ForceOffShelfReason">@item.ForceOffShelfReason</span>
                                                @if (item.ForceOffShelfBy.HasValue)
                                                {
                                                    <div class="fs-7 mt-1" style="color:#9ca3af;">操作人 ID：@item.ForceOffShelfBy</div>
                                                }
                                            }
                                            else
                                            {
                                                <span class="fs-7" style="color:#a0aec0;">—</span>
                                            }
                                        </td>
                                        <td class="fs-7 col-date" style="color:#4a5a6a;">
                                            @(item.ForceOffShelfDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                                        </td>
                                        <td class="fs-7 col-date" style="color:#4a5a6a;">
                                            @(item.ReApplyDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                                        </td>
                                        <td class="text-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-success rounded-pill px-3 me-1 btn-approve-forced"
                                                    data-id="@item.Id" data-name="@item.Name">
                                                <i class="bx bx-check-circle me-1"></i>核准上架
                                            </button>
                                            <button type="button"
                                                    class="btn btn-sm btn-danger rounded-pill px-3 btn-reject-forced"
                                                    data-id="@item.Id" data-name="@item.Name">
                                                <i class="bx bx-x-circle me-1"></i>駁回
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* ── 重新申請分頁 ── *@
                    @if (reApplyPaged != null)
                    {
                        @await Html.PartialAsync("_Pagination", new ISpanShop.MVC.Areas.Admin.Models.Common.PaginationVm
                        {
                            CurrentPage = reApplyPaged.CurrentPage,
                            TotalPages  = reApplyPaged.TotalPages,
                            UrlForPage  = p => Url.Action("PendingReview", new { pendingPage = Model?.CurrentPage ?? 1, reApplyPage = p, rejectedPage })!
                        })
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-2" style="font-size:2rem;color:#fca5a5;"><i class="bx bx-revision" style="font-size:2.5rem;"></i></div>
                        <p class="mb-0" style="color:#a0aec0;">目前沒有待重新審核的商品</p>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="rejectedPanel" role="tabpanel">
            <div class="filter-card rounded-top-0" style="border-top-left-radius:0!important;border-top-right-radius:0!important;">
                @if (rejectedList != null && rejectedList.Any())
                {
                    <div id="rejectedBatchBar" class="mb-3 d-flex align-items-center gap-2" style="display:none!important;">
                        <span id="rejected-batch-tag" class="batch-tag">
                            <i class="bx bx-checkbox-checked"></i>
                            已選取 <span id="rejected-selected-count">0</span> 筆
                            <button id="btn-clear-rejected" type="button" class="batch-tag-close" aria-label="清除選取">×</button>
                        </span>
                        <button id="btnBatchUndoReject" class="btn btn-outline-primary rounded-pill px-4" disabled>
                            <i class="bx bx-revision me-1"></i> 批次重新審核
                        </button>
                    </div>
                    <div style="overflow-x:auto;min-width:0;">
                        <table class="table table-custom align-middle">
                            <thead>
                                <tr>
                                    <th style="width:40px;" class="text-center col-rej-cb">
                                        <input type="checkbox" id="selectAllRejected" class="form-check-input" title="全選退回">
                                    </th>
                                    <th style="width:70px;" class="col-img">圖片</th>
                                    <th>商品名稱</th>
                                    <th class="col-store">商家</th>
                                    <th class="col-rej-reason">退回原因</th>
                                    <th>自動刪除倒數</th>
                                    <th class="col-reviewer">審核人</th>
                                    <th class="col-date">審核時間</th>
                                    <th class="text-end">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in rejectedList)
                                {
                                    <tr data-id="@item.Id" data-name="@item.Name.Replace("'","\\'")">
                                        <td class="text-center col-rej-cb" style="width:40px;">
                                            <input type="checkbox" class="form-check-input rejected-row-check" value="@item.Id">
                                        </td>
                                        <td class="col-img">
                                            @if (!string.IsNullOrEmpty(item.MainImageUrl))
                                            {
                                                <img src="@item.MainImageUrl" alt="@item.Name" loading="lazy"
                                                     style="width:54px;height:54px;object-fit:cover;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,0.08);" />
                                            }
                                            else
                                            {
                                                <div style="width:54px;height:54px;border-radius:10px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">🖼️</div>
                                            }
                                        </td>
                                        <td class="fw-semibold product-name-cell" style="color:#1e2d3d;">@item.Name</td>
                                        <td class="fs-7 col-store" style="color:#5a6a7a;">@item.StoreName</td>
                                        <td class="col-rej-reason">
                                            @if (!string.IsNullOrWhiteSpace(item.RejectReason))
                                            {
                                                <span style="background:#fff0f0;color:#c53030;border-radius:6px;font-size:0.82rem;font-weight:500;padding:0.3em 0.7em;display:inline-block;">
                                                    @item.RejectReason
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="fs-7" style="color:#a0aec0;">（未填寫）</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.ReviewDate.HasValue)
                                            {
                                                var expireTime = item.ReviewDate.Value.AddSeconds(60).ToString("yyyy-MM-ddTHH:mm:ss");
                                                <span class="live-countdown badge bg-warning text-dark"
                                                      data-expire="@expireTime">
                                                    ⏳ 計算中...
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="fs-7" style="color:#a0aec0;">—</span>
                                            }
                                        </td>
                                        <td class="fs-7 col-reviewer" style="color:#4a5a6a;">@(item.ReviewedBy ?? "—")</td>
                                        <td class="fs-7 col-date" style="color:#4a5a6a;">@(item.ReviewDate?.ToString("yyyy-MM-dd HH:mm") ?? item.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                        <td class="text-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                    onclick="undoReject(@item.Id, '@item.Name.Replace("'", "\\'")') ">
                                                <i class="bx bx-revision me-1"></i>重新審核
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-2" style="font-size:2rem;">📭</div>
                        <p class="mb-0" style="color:#a0aec0;">近期無退回紀錄</p>
                    </div>
                }

                @* ── 退回紀錄分頁 ── *@
                @if (rejectedPaged != null)
                {
                    @await Html.PartialAsync("_Pagination", new ISpanShop.MVC.Areas.Admin.Models.Common.PaginationVm
                    {
                        CurrentPage = rejectedPaged.CurrentPage,
                        TotalPages  = rejectedPaged.TotalPages,
                        UrlForPage  = p => Url.Action("PendingReview", new { pendingPage = Model?.CurrentPage ?? 1, rejectedPage = p }) + "#rejectedTab"
                    })
                }
            </div>
        </div>

        @* ── 近期審核通過 Tab Panel ── *@
        <div class="tab-pane fade" id="approvedPanel" role="tabpanel">
            <div class="filter-card rounded-top-0" style="border-top-left-radius:0!important;border-top-right-radius:0!important;">
                @if (approvedList.Any())
                {
                    <p class="fs-7 mb-3" style="color:#4a5a6a;">
                        顯示過去 <strong>24 小時</strong>內系統或管理員審核通過的商品，共
                        <span class="fw-bold text-success">@(approvedPaged?.TotalCount ?? 0)</span> 筆。
                    </p>
                    <div style="overflow-x:auto;min-width:0;">
                        <table class="table table-custom align-middle">
                            <thead>
                                <tr>
                                    <th style="width:60px;" class="col-img">圖片</th>
                                    <th>商品名稱</th>
                                    <th class="col-store">商店</th>
                                    <th class="col-catbrand">分類 / 品牌</th>
                                    <th class="col-reviewer">審核人</th>
                                    <th>通過時間</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in approvedList)
                                {
                                    <tr data-id="@item.Id" data-name="@item.Name.Replace("'","\\'")">
                                        <td class="col-img">
                                            @if (!string.IsNullOrEmpty(item.MainImageUrl))
                                            {
                                                <img src="@item.MainImageUrl" alt="@item.Name" loading="lazy"
                                                     style="width:54px;height:54px;object-fit:cover;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,0.08);" />
                                            }
                                            else
                                            {
                                                <div style="width:54px;height:54px;border-radius:10px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">🖼️</div>
                                            }
                                        </td>
                                        <td class="fw-semibold product-name-cell" style="color:#1e2d3d;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                            @item.Name
                                        </td>
                                        <td class="fs-7 col-store" style="color:#5a6a7a;">@item.StoreName</td>
                                        <td class="col-catbrand">
                                            <span class="badge-soft bg-primary-soft text-primary me-1">@item.CategoryName</span>
                                            <span class="badge-soft bg-info-soft text-info">@item.BrandName</span>
                                        </td>
                                        <td class="fs-7 col-reviewer" style="color:#4a5a6a;">@(item.ReviewedBy ?? "—")</td>
                                        <td class="fs-7" style="color:#4a5a6a;">@(item.ReviewDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* ── 近期通過分頁 ── *@
                    @if (approvedPaged != null)
                    {
                        @await Html.PartialAsync("_Pagination", new ISpanShop.MVC.Areas.Admin.Models.Common.PaginationVm
                        {
                            CurrentPage = approvedPaged.CurrentPage,
                            TotalPages  = approvedPaged.TotalPages,
                            UrlForPage  = p => Url.Action("PendingReview", new { pendingPage = Model?.CurrentPage ?? 1, rejectedPage = rejectedPage, approvedPage = p }) + "#approvedTab"
                        })
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-2" style="font-size:2rem;">📋</div>
                        <h5 class="fw-bold mb-1" style="color:#1e2d3d;">過去 24 小時內無審核通過記錄</h5>
                        <p class="fs-7 mb-0" style="color:#718096;">可先生成測試商品，再執行模擬自動審核以產生資料。</p>
                    </div>
                }
            </div>
        </div>

    </div>
    </div><!-- /reviewListCol -->

    <div id="productDetailPanel" class="split-detail-panel">
        <div class="split-detail-panel-inner">
            <div class="side-panel-header">
                <div class="side-panel-title" id="productDetailPanelLabel" title="商品詳情">商品詳情</div>
                <button type="button" class="side-panel-close" onclick="closeProductDetailPanel()" aria-label="Close" title="關閉">
                    <i class="bx bx-x"></i>
                </button>
            </div>
            <div class="panel-body" id="productDetailPanelBody">
                <div class="text-center py-5 text-muted">
                    <i class="bx bx-loader-alt bx-spin fs-1 d-block mb-2"></i>載入中…
                </div>
            </div>
        </div>
    </div>

    </div><!-- /reviewLayout -->
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap');

    body {
        background-color: #f4f6f8;
    }

    .font-noto {
        font-family: 'Noto Sans TC', sans-serif;
    }

    .tracking-tight {
        letter-spacing: -0.5px;
    }

    .fs-7 {
        font-size: 0.9rem;
    }

    /* 回商品總覽按鈕 - 明顯青綠色 */
    .btn-back {
        background-color: #1abb9c;
        color: #ffffff;
        border: none;
        font-weight: 600;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(26,187,156,0.3);
    }

        .btn-back:hover {
            background-color: #0e8a72;
            color: #ffffff;
            box-shadow: 0 5px 16px rgba(14,138,114,0.4);
            transform: translateY(-1px);
        }

    /* Tabs */
    #reviewTabs .nav-link {
        color: #718096;
        border: 1px solid transparent;
        border-bottom: none;
        border-radius: 12px 12px 0 0;
        background: rgba(255,255,255,0.5);
        transition: all 0.2s;
    }

        #reviewTabs .nav-link:hover {
            color: #2d3748;
            background: rgba(255,255,255,0.8);
        }

        #reviewTabs .nav-link.active {
            color: #2d3748;
            background: #fff;
            border-color: rgba(226,232,240,0.8);
            border-bottom-color: #fff;
        }

    /* 卡片 */
    .filter-card {
        background: #ffffff;
        border-radius: 0 20px 20px 20px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        border: 1px solid rgba(226,232,240,0.8);
    }

    /* 表格 */
    .table-custom {
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .table-custom th {
            border: none;
            color: #3d5166;
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 0.85rem;
            padding: 0.4rem 1.2rem;
            background: #f4f6f8;
            text-transform: uppercase;
            position: sticky;
            top: 0;
            z-index: 2;
        }

        .table-custom td {
            background: #fff;
            border: none;
            padding: 1rem 1.2rem;
            font-size: 0.95rem;
        }

            .table-custom td:first-child {
                border-top-left-radius: 12px;
                border-bottom-left-radius: 12px;
            }

            .table-custom td:last-child {
                border-top-right-radius: 12px;
                border-bottom-right-radius: 12px;
            }

        .table-custom tbody tr {
            box-shadow: 0 3px 12px rgba(0,0,0,0.03);
            transition: all 0.25s ease;
        }

            .table-custom tbody tr:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 22px rgba(0,0,0,0.07);
            }

    .badge-soft {
        padding: 0.35em 0.75em;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .bg-primary-soft {
        background-color: #ebf8ff;
    }

    .text-primary {
        color: #3182ce !important;
    }

    .bg-info-soft {
        background-color: #e6fffa;
    }

    .text-info {
        color: #319795 !important;
    }

    /* 審核按鈕 */
    .btn-approve {
        background-color: #d1fae5;
        color: #065f46;          /* 深綠字，對比比原 #276749 更高 */
        border: 1px solid #6ee7b7;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-approve:hover {
            background-color: #059669;
            color: #fff;
            border-color: #059669;
            box-shadow: 0 4px 12px rgba(5,150,105,0.30);
        }

    .btn-reject {
        background-color: #fed7d7;
        color: #9b2c2c;
        border: none;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-reject:hover {
            background-color: #e53e3e;
            color: #fff;
            box-shadow: 0 4px 12px rgba(229,62,62,0.3);
        }

    /* 批次選取 Tag */
    .batch-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: transparent;
        color: #374151;
        border: 1.5px solid #d1d5db;
        border-radius: 20px;
        padding: 0.3rem 0.75rem;
        font-size: 0.88rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .batch-tag-close {
        background: none;
        border: none;
        color: #6b7280;
        font-size: 1.1rem;
        line-height: 1;
        padding: 0 2px;
        cursor: pointer;
        opacity: 0.75;
    }

        .batch-tag-close:hover {
            opacity: 1;
            color: #374151;
        }

    .cb-cell {
        border-top-left-radius: 12px !important;
        border-bottom-left-radius: 12px !important;
    }

    /* ── PendingReview 頁面專屬 ── */
    /* 選中列高亮 */
    .table-custom tbody tr.row-active td { background: #ebf8ff !important; }
    .table-custom tbody tr.row-active td:first-child { box-shadow: inset 3px 0 0 #3182ce; }
    /* 表格淡入淡出 */
    #reviewTabsContent { transition: opacity 0.18s ease; }
    /* 精簡模式 */
    #reviewLayout.panel-open .col-img,
    #reviewLayout.panel-open .col-store,
    #reviewLayout.panel-open .col-catbrand,
    #reviewLayout.panel-open .col-date,
    #reviewLayout.panel-open .col-rowact,
    #reviewLayout.panel-open .col-reviewer,
    #reviewLayout.panel-open .col-reapply-reason,
    #reviewLayout.panel-open .col-rej-cb,
    #reviewLayout.panel-open .col-rej-reason { display: none; }
    #reviewLayout.panel-open .table-custom td { padding: 0.55rem 1.2rem; }
    #reviewLayout.panel-open .product-name-cell { max-width: 180px; }
    /* 面板展開時 6:4 比例（覆蓋共用 65%）*/
    #reviewLayout #productDetailPanel.open { flex: 0 0 40%; width: 40%; }
    .table-custom tbody tr { cursor: pointer; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ══════════════════════════════════════════════════════
        //  批次審核：checkbox 全選與按鈕連動
        // ══════════════════════════════════════════════════════
        (function () {
            var urlApprove              = '@Url.Action("ApproveProduct", "Products")';
            var urlReject               = '@Url.Action("RejectProduct", "Products")';
            var urlBatchApprove         = '@Url.Action("BatchApprove", "Products")';
            var urlBatchReject          = '@Url.Action("BatchReject", "Products")';
            var urlSimulateAutoReview   = '@Url.Action("SimulateAutoReview", "Products")';
            var urlProductIndex         = '@Url.Action("Index", "Products")';
            var urlUndoReject           = '@Url.Action("UndoReject", "Products")';
            var urlApproveForcedProduct = '@Url.Action("ApproveForcedProduct", "Products")';
            var urlRejectForcedProduct  = '@Url.Action("RejectForcedProduct", "Products")';

            // ── 批次按鈕 disabled 切換 ──
            function updateBatchButtons() {
                var count = document.querySelectorAll('.row-check:checked').length;
                var tag   = document.getElementById('pending-batch-tag');
                var badge = document.getElementById('pending-selected-count');
                var btnApprove = document.getElementById('btnBatchApprove');
                var btnReject  = document.getElementById('btnBatchReject');
                if (tag)   { count > 0 ? tag.classList.remove('d-none') : tag.classList.add('d-none'); }
                if (badge) badge.textContent = count;
                if (btnApprove) btnApprove.disabled = count === 0;
                if (btnReject)  btnReject.disabled  = count === 0;
            }

            // ── 全選 checkbox ──
            var selectAllCb = document.getElementById('selectAll');
            if (selectAllCb) {
                selectAllCb.addEventListener('change', function () {
                    document.querySelectorAll('.row-check').forEach(cb => cb.checked = this.checked);
                    updateBatchButtons();
                });
            }

            // ── 單選 checkbox ──
            document.querySelectorAll('.row-check').forEach(cb => {
                cb.addEventListener('change', function () {
                    var all     = document.querySelectorAll('.row-check');
                    var checked = document.querySelectorAll('.row-check:checked');
                    var selectAll = document.getElementById('selectAll');
                    if (selectAll) {
                        selectAll.checked       = checked.length === all.length && all.length > 0;
                        selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
                    }
                    updateBatchButtons();
                });
            });

            updateBatchButtons(); // 初始化狀態

            // ── 叉叉清除按鈕（待審核）──
            var btnClearPending = document.getElementById('btn-clear-pending');
            if (btnClearPending) {
                btnClearPending.addEventListener('click', function () {
                    document.querySelectorAll('.row-check').forEach(cb => cb.checked = false);
                    var selectAll = document.getElementById('selectAll');
                    if (selectAll) { selectAll.checked = false; selectAll.indeterminate = false; }
                    updateBatchButtons();
                });
            }

            // ── 批次審核通過 ──
            var btnBatchApprove = document.getElementById('btnBatchApprove');
            if (btnBatchApprove) {
                btnBatchApprove.addEventListener('click', function () {
                    var ids = Array.from(document.querySelectorAll('.row-check:checked')).map(cb => parseInt(cb.value));
                    if (ids.length === 0) { Swal.fire('請先選擇商品', '', 'warning'); return; }
                    Swal.fire({
                        title: '批次審核通過',
                        html: '確定要核准 <strong>' + ids.length + '</strong> 筆商品上架嗎？',
                        icon: 'question', showCancelButton: true,
                        confirmButtonColor: '#1abb9c', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認核准', cancelButtonText: '取消'
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        Swal.fire({ title: '處理中…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        try {
                            const res = await apiPost(urlBatchApprove, { ids: ids });
                            if (res.success) {
                                Swal.fire({ title: '批次核准成功！', text: res.message, icon: 'success',
                                            confirmButtonColor: '#1abb9c', timer: 2000, timerProgressBar: true })
                                    .then(() => location.reload());
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            }

            // ── 批次審核退回 ──
            var btnBatchReject = document.getElementById('btnBatchReject');
            if (btnBatchReject) {
                btnBatchReject.addEventListener('click', function () {
                    var ids = Array.from(document.querySelectorAll('.row-check:checked')).map(cb => parseInt(cb.value));
                    if (ids.length === 0) { Swal.fire('請先選擇商品', '', 'warning'); return; }
                    Swal.fire({
                        title: '批次審核退回',
                        html: '即將退回 <strong>' + ids.length + '</strong> 筆商品',
                        input: 'textarea', inputLabel: '退回原因（必填，套用至所有選取商品）',
                        inputPlaceholder: '請填寫退回原因...',
                        inputAttributes: { rows: 3 },
                        icon: 'warning', showCancelButton: true,
                        confirmButtonColor: '#e53e3e', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認退回', cancelButtonText: '取消',
                        inputValidator: function(value) { if (!value || !value.trim()) return '退回原因為必填欄位'; }
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        Swal.fire({ title: '處理中…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        try {
                            const res = await apiPost(urlBatchReject, { ids: ids, reason: result.value.trim() });
                            if (res.success) {
                                Swal.fire({ title: '批次退回完成！', text: res.message, icon: 'success',
                                            confirmButtonColor: '#1abb9c', timer: 2000, timerProgressBar: true })
                                    .then(() => { window.location.hash = '#rejectedTab'; location.reload(); });
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            }

            // ── 啟用 Bootstrap Tooltips ──
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el) {
                new bootstrap.Tooltip(el);
            });

            // ══════════════════════════════════════════════════════
            //  退回記錄頁：checkbox 全選與批次重新審核
            // ══════════════════════════════════════════════════════
            var urlBatchUndoReject = '@Url.Action("BatchUndoReject", "Products")';

            function updateRejectedBatchButtons() {
                var count = document.querySelectorAll('.rejected-row-check:checked').length;
                var tag   = document.getElementById('rejected-batch-tag');
                var badge = document.getElementById('rejected-selected-count');
                var btn   = document.getElementById('btnBatchUndoReject');
                var bar   = document.getElementById('rejectedBatchBar');
                if (tag)   { count > 0 ? tag.classList.remove('d-none') : tag.classList.add('d-none'); }
                if (badge) badge.textContent = count;
                if (btn)   btn.disabled = count === 0;
                if (bar)   bar.style.display = count > 0 ? 'flex' : 'none';
            }

            // 退回頁全選
            var selectAllRejected = document.getElementById('selectAllRejected');
            if (selectAllRejected) {
                selectAllRejected.addEventListener('change', function () {
                    document.querySelectorAll('.rejected-row-check').forEach(cb => cb.checked = this.checked);
                    updateRejectedBatchButtons();
                });
            }

            // 退回頁單選
            document.querySelectorAll('.rejected-row-check').forEach(cb => {
                cb.addEventListener('change', function () {
                    var all = document.querySelectorAll('.rejected-row-check');
                    var checked = document.querySelectorAll('.rejected-row-check:checked');
                    if (selectAllRejected) {
                        selectAllRejected.checked       = all.length === checked.length && checked.length > 0;
                        selectAllRejected.indeterminate = checked.length > 0 && checked.length < all.length;
                    }
                    updateRejectedBatchButtons();
                });
            });

            updateRejectedBatchButtons(); // 初始化

            // ── 叉叉清除按鈕（退回頁）──
            var btnClearRejected = document.getElementById('btn-clear-rejected');
            if (btnClearRejected) {
                btnClearRejected.addEventListener('click', function () {
                    document.querySelectorAll('.rejected-row-check').forEach(cb => cb.checked = false);
                    var selectAllR = document.getElementById('selectAllRejected');
                    if (selectAllR) { selectAllR.checked = false; selectAllR.indeterminate = false; }
                    updateRejectedBatchButtons();
                });
            }

            // 批次重新審核按鈕
            var btnBatchUndoReject = document.getElementById('btnBatchUndoReject');
            if (btnBatchUndoReject) {
                btnBatchUndoReject.addEventListener('click', function () {
                    var ids = Array.from(document.querySelectorAll('.rejected-row-check:checked')).map(cb => parseInt(cb.value));
                    if (ids.length === 0) { Swal.fire('請先選擇商品', '', 'warning'); return; }
                    Swal.fire({
                        title: '批次移回待審核',
                        html: '確定要將 <strong>' + ids.length + '</strong> 筆商品移回待審核佇列嗎？',
                        icon: 'question', showCancelButton: true,
                        confirmButtonColor: '#3182ce', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認', cancelButtonText: '取消'
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        Swal.fire({ title: '處理中…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        try {
                            const res = await apiPost(urlBatchUndoReject, { ids: ids });
                            if (res.success) {
                                Swal.fire({ title: '已批次移回待審核！', text: res.message, icon: 'success',
                                            confirmButtonColor: '#1abb9c', timer: 2000, timerProgressBar: true })
                                    .then(() => location.reload());
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            }
        })();

        (function () {
            var urlUndoReject          = '@Url.Action("UndoReject",          "Products")';
            var urlApprove             = '@Url.Action("ApproveProduct",       "Products")';
            var urlReject              = '@Url.Action("RejectProduct",        "Products")';
            var urlSimulateAutoReview  = '@Url.Action("SimulateAutoReview",   "Products")';
            var urlGenerateTestProducts= '@Url.Action("GenerateTestProducts", "Products")';
            var urlProductIndex        = '@Url.Action("Index",                "Products")';

            // ── 生成測試商品 ──
            var btnGenerate = document.getElementById('btnGenerateTestProducts');
            if (btnGenerate) {
                btnGenerate.addEventListener('click', function () {
                    Swal.fire({
                        title: '生成測試商品',
                        html:  '將新增 <strong>15</strong> 筆待審核測試商品：<br>' +
                               '<span style="font-size:0.88rem;color:#4a5a6a;">' +
                               '✅ 5 筆完全乾淨（預期：自動通過）<br>' +
                               '🚫 5 筆高風險（敏感字在名稱中，預期：自動退回）<br>' +
                               '⚠️ 5 筆邊緣（敏感字在描述出現 1 次，預期：人工複審）</span><br><br>' +
                               '<small style="color:#9ca3af;">敏感字清單從資料庫動態讀取</small>',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#6b7280',
                        cancelButtonColor:  '#a0aec0',
                        confirmButtonText:  '<i class="bx bx-data me-1"></i> 確認生成',
                        cancelButtonText:   '取消'
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        Swal.fire({ title: '生成中…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        try {
                            const res = await apiPost(urlGenerateTestProducts, {});
                            if (res.success) {
                                Swal.fire({
                                    title: '生成完成！',
                                    html:  '共新增 <strong>' + res.count + '</strong> 筆待審核測試商品<br>' +
                                           '<span style="font-size:0.88rem;">' +
                                           '✅ 乾淨商品 <strong>' + res.clean + '</strong> 筆&nbsp;&nbsp;' +
                                           '🚫 高風險 <strong>' + res.highRisk + '</strong> 筆&nbsp;&nbsp;' +
                                           '⚠️ 邊緣 <strong>' + res.borderline + '</strong> 筆</span>',
                                    icon: 'success',
                                    confirmButtonColor: '#1abb9c',
                                    confirmButtonText:  '重新整理查看'
                                }).then(() => location.reload());
                            } else {
                                Swal.fire({ title: '生成失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            }

            // ── 模擬自動審核 ──
            var btnSimulate = document.getElementById('btnSimulateAutoReview');
            if (btnSimulate) {
                btnSimulate.addEventListener('click', function () {
                    Swal.fire({
                        title: '模擬系統自動審核',
                        html:  '系統將從資料庫載入真實敏感字清單，<br>對目前所有 <strong>待審核</strong> 商品進行比對。<br><br>' +
                               '<small style="color:#6b7280;">判斷規則：名稱含敏感字 / 描述累計 2 次 → 退回；僅出現 1 次 → 人工複審；無命中 → 通過</small>',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#f59e0b',
                        cancelButtonColor:  '#a0aec0',
                        confirmButtonText:  '<i class="fas fa-robot me-1"></i> 開始模擬',
                        cancelButtonText:   '取消'
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        Swal.fire({ title: '模擬執行中…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                        try {
                            const res = await apiPost(urlSimulateAutoReview, {});
                            if (res.success) {
                                // ── 依審核結果逐筆更新畫面 ──
                                var approvedNames = [];
                                if (res.items && res.items.length > 0) {
                                    res.items.forEach(function (item) {
                                        var row = document.querySelector('tr[data-id="' + item.productId + '"]');
                                        if (!row) return;

                                        var nameCell   = row.querySelector('td:nth-child(3) .fw-bold');
                                        var statusCell = row.querySelector('td:nth-child(4)');

                                        if (item.outcome === 'Rejected') {
                                            if (nameCell && item.matchedWords && item.matchedWords.length > 0) {
                                                var highlighted = nameCell.textContent;
                                                item.matchedWords.forEach(function (word) {
                                                    var esc = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                                                    highlighted = highlighted.replace(
                                                        new RegExp(esc, 'gi'),
                                                        '<span style="background:#fed7d7;color:#c53030;border-radius:3px;padding:0 2px;font-weight:700;">$&</span>'
                                                    );
                                                });
                                                nameCell.innerHTML = highlighted;
                                                nameCell.closest('td').insertAdjacentHTML('beforeend',
                                                    '<div class="mt-1"><span style="background:#fed7d7;color:#9b2c2c;border-radius:4px;padding:2px 7px;font-size:0.78rem;">🚫 ' +
                                                    item.matchedWords.join('、') + '</span></div>');
                                            }
                                            if (statusCell) statusCell.innerHTML = '<span class="badge bg-danger">❌ 已退回</span>';
                                            setTimeout(function () {
                                                row.style.transition = 'opacity 1.5s';
                                                row.style.opacity    = '0.3';
                                            }, 1200);

                                        } else if (item.outcome === 'Uncertain') {
                                            if (nameCell && item.matchedWords && item.matchedWords.length > 0) {
                                                nameCell.closest('td').insertAdjacentHTML('beforeend',
                                                    '<div class="mt-1"><span style="background:#fef3c7;color:#92400e;border-radius:4px;padding:2px 7px;font-size:0.78rem;">⚠️ 疑似：' +
                                                    item.matchedWords.join('、') + '</span></div>');
                                            }
                                            if (statusCell) statusCell.innerHTML = '<span class="badge bg-warning text-dark">⚠️ 待人工審核</span>';

                                        } else if (item.outcome === 'Approved') {
                                            approvedNames.push(item.productName);
                                            if (statusCell) statusCell.innerHTML = '<span class="badge bg-success">✅ 已通過</span>';
                                            setTimeout(function () {
                                                row.style.transition = 'opacity 1s';
                                                row.style.opacity    = '0.3';
                                            }, 600);
                                        }
                                    });
                                }

                                // ── 彙總對話框（含上架商品清單）──
                                var approvedList = approvedNames.length > 0
                                    ? '<hr style="margin:0.6rem 0;"><div style="text-align:left;font-size:0.82rem;max-height:160px;overflow-y:auto;">' +
                                      '<strong style="display:block;margin-bottom:4px;">✅ 剛剛成功上架的商品：</strong>' +
                                      approvedNames.map(function(n) {
                                          return '<div style="padding:2px 0;color:#065f46;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">• ' + n + '</div>';
                                      }).join('') + '</div>'
                                    : '';

                                var totalProcessed = (res.items || []).length;
                                Swal.fire({
                                    title: '模擬審核完畢！',
                                    html:  '本次共處理 <strong>' + totalProcessed + '</strong> 筆商品<br>' +
                                           '✅ 成功上架：<strong style="color:#059669;">' + res.approved     + '</strong> 筆&nbsp;' +
                                           '❌ 自動退回：<strong style="color:#dc2626;">' + res.rejected     + '</strong> 筆&nbsp;' +
                                           '⚠️ 保留待審核：<strong style="color:#d97706;">' + res.manualReview + '</strong> 筆' +
                                           approvedList,
                                    icon: 'success',
                                    confirmButtonColor: '#1abb9c',
                                    confirmButtonText:  '重新整理',
                                    width: approvedNames.length > 0 ? '520px' : '440px'
                                }).then(() => location.reload());
                            } else {
                                Swal.fire({ title: '模擬失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            }

            window.undoReject = function (id, name) {
                Swal.fire({
                    title: '移回待審核',
                    html: '確定要將商品<br><strong>「' + name + '」</strong><br>移回待審核佇列嗎？',
                    icon: 'question', showCancelButton: true,
                    confirmButtonColor: '#3182ce', cancelButtonColor: '#a0aec0',
                    confirmButtonText: '確認', cancelButtonText: '取消'
                }).then(async function (result) {
                    if (!result.isConfirmed) return;
                    try {
                        const res = await apiPost(urlUndoReject, { id: parseInt(id) });
                        if (res.success) {
                            Swal.fire({ title: '已移回待審核', text: res.message, icon: 'success',
                                        confirmButtonColor: '#1abb9c', timer: 2000, timerProgressBar: true })
                                .then(() => location.reload());
                        } else {
                            Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                        }
                    } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                });
            };

            document.addEventListener('DOMContentLoaded', function () {
                var hash = window.location.hash;
                var tabMap = { '#rejectedTab': '#rejected-tab', '#approvedTab': '#approved-tab' };
                if (tabMap[hash]) {
                    var tabEl = document.querySelector(tabMap[hash]);
                    if (tabEl && typeof bootstrap !== 'undefined') {
                        new bootstrap.Tab(tabEl).show();
                    }
                    history.replaceState(null, '', window.location.pathname + window.location.search);
                }
            });

            function removeRow(id) {
                var row = document.querySelector('#pendingPanel tr[data-id="' + id + '"]');
                // 先找到下一筆或上一筆（移除前找，避免 DOM 消失）
                var nextRow = null;
                if (row) {
                    var ns = row.nextElementSibling;
                    while (ns && !ns.dataset.id) ns = ns.nextElementSibling;
                    if (ns) {
                        nextRow = ns;
                    } else {
                        var ps = row.previousElementSibling;
                        while (ps && !ps.dataset.id) ps = ps.previousElementSibling;
                        if (ps) nextRow = ps;
                    }
                }
                if (row) row.remove();
                // 只計算 data-id 列（排除 accordion sub-rows）
                var remaining = document.querySelectorAll('#pendingPanel tbody tr[data-id]').length;
                document.querySelectorAll('#pendingCount, .text-warning.fw-bold').forEach(function(el) { el.textContent = remaining; });
                var badge = document.querySelector('#pending-tab .badge');
                if (badge) badge.textContent = remaining;
                // 面板開啟時：自動選中下一筆或顯示空狀態
                var panel = document.getElementById('productDetailPanel');
                if (panel && panel.classList.contains('open')) {
                    if (remaining === 0) {
                        var body = document.getElementById('productDetailPanelBody');
                        if (body) body.innerHTML = '<div class="text-center py-5 text-muted"><i class="bx bx-inbox" style="font-size:2.5rem;"></i><div class="mt-2 fw-semibold">待審核列表已清空</div></div>';
                        _activeProductRowId = null;
                    } else if (nextRow) {
                        openProductOffcanvas(parseInt(nextRow.dataset.id), nextRow.dataset.name || '商品詳情');
                    }
                } else if (remaining === 0) {
                    location.reload();
                }
            }

            document.querySelectorAll('.btn-approve').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = this.dataset.id; var name = this.dataset.name;
                    Swal.fire({
                        title: '確認核准上架',
                        html: '確定要核准商品<br><strong>「' + name + '」</strong>上架嗎？',
                        icon: 'question', showCancelButton: true,
                        confirmButtonColor: '#1abb9c', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認核准', cancelButtonText: '取消'
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        try {
                            const res = await apiPost(urlApprove, { id: parseInt(id) });
                            if (res.success) {
                                removeRow(id);
                                var gotoUrl = urlProductIndex + '?keyword=' + encodeURIComponent(name) + '&sort=review_desc';
                                Swal.fire({
                                    title: '核准成功！',
                                    html: res.message + '<br><a href="' + gotoUrl,
                                    icon: 'success', confirmButtonColor: '#1abb9c', timer: 4000, timerProgressBar: true
                                });
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            });

            document.querySelectorAll('.btn-reject').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = this.dataset.id; var name = this.dataset.name;
                    Swal.fire({
                        title: '退回商品審核',
                        html: '商品：<strong>「' + name + '」</strong>',
                        input: 'textarea', inputLabel: '退回原因（必填）',
                        inputPlaceholder: '請填寫退回原因...',
                        inputAttributes: { rows: 3 },
                        icon: 'warning', showCancelButton: true,
                        confirmButtonColor: '#e53e3e', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認退回', cancelButtonText: '取消',
                        inputValidator: function(value) { if (!value || !value.trim()) return '退回原因為必填欄位'; }
                    }).then(async function (result) {
                        if (!result.isConfirmed) return;
                        try {
                            const res = await apiPost(urlReject, { id: parseInt(id), reason: result.value.trim() });
                            if (res.success) {
                                removeRow(id);
                                var gotoUrl = urlProductIndex + '?keyword=' + encodeURIComponent(name) + '&sort=review_desc';
                                Swal.fire({
                                    title: '已退回！',
                                    html: res.message + '<br><a href="' + gotoUrl,
                                    icon: 'success', confirmButtonColor: '#1abb9c', timer: 4000, timerProgressBar: true
                                })
                                .then(() => { window.location.hash = '#rejectedTab'; window.location.reload(); });
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    });
                });
            });

            // ── 重新申請審核：核准 ──
            document.querySelectorAll('.btn-approve-forced').forEach(function (btn) {
                btn.addEventListener('click', async function (e) {
                    e.stopPropagation();
                    var id   = parseInt(btn.dataset.id);
                    var name = btn.dataset.name;
                    var result = await Swal.fire({
                        title: '核准重新上架',
                        html: '確定要核准商品「<strong>' + name + '</strong>」重新上架？',
                        icon: 'question', showCancelButton: true,
                        confirmButtonColor: '#38a169', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認核准', cancelButtonText: '取消'
                    });
                    if (!result.isConfirmed) return;
                    try {
                        const res = await apiPost(urlApproveForcedProduct, { id: id });
                        if (res.success) {
                            Swal.fire({ title: '已核准！', text: res.message, icon: 'success', timer: 1800, timerProgressBar: true, confirmButtonColor: '#1abb9c' })
                                .then(() => location.reload());
                        } else {
                            Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                        }
                    } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                });
            });

            // ── 重新申請審核：駁回 ──
            document.querySelectorAll('.btn-reject-forced').forEach(function (btn) {
                btn.addEventListener('click', async function (e) {
                    e.stopPropagation();
                    var id   = parseInt(btn.dataset.id);
                    var name = btn.dataset.name;
                    var result = await Swal.fire({
                        title: '駁回重新申請',
                        html: '請填寫駁回原因（賣家將看到此說明）：',
                        input: 'textarea', inputPlaceholder: '請填寫駁回原因...',
                        inputValidator: function(v) { if (!v || v.trim().length < 5) return '請填寫至少 5 字的駁回原因'; },
                        icon: 'warning', showCancelButton: true,
                        confirmButtonColor: '#dc2626', cancelButtonColor: '#a0aec0',
                        confirmButtonText: '確認駁回', cancelButtonText: '取消'
                    });
                    if (!result.isConfirmed) return;
                    try {
                        const res = await apiPost(urlRejectForcedProduct, { id: id, reason: result.value.trim() });
                        if (res.success) {
                            Swal.fire({ title: '已駁回', text: res.message, icon: 'success', timer: 1800, timerProgressBar: true, confirmButtonColor: '#1abb9c' })
                                .then(() => location.reload());
                        } else {
                            Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                        }
                    } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                });
            });

            // ══════════════════════════════════════════════════════
            //  面板底部操作按鈕（事件委派）
            // ══════════════════════════════════════════════════════

            // 彈出退回 Modal（含快捷原因 chips）
            function showPanelRejectModal(name, onConfirm) {
                var chips = ['商品描述不實', '圖片不清晰', '價格異常', '分類錯誤', '其他'];
                Swal.fire({
                    title: '退回商品審核',
                    html: '<p style="font-size:0.9rem;text-align:left;margin-bottom:10px;">商品：<strong>「' + name + '」</strong></p>' +
                          '<p style="font-size:0.82rem;font-weight:600;color:#6b7280;text-align:left;margin-bottom:6px;">快捷原因</p>' +
                          '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;">' +
                          chips.map(function(c) {
                              return '<button type="button" class="swal-panel-chip" data-val="' + c + '" ' +
                                     'style="background:#f3f4f6;color:#374151;border:1px solid #d1d5db;border-radius:16px;padding:4px 12px;font-size:0.82rem;cursor:pointer;transition:all 0.15s;">' + c + '</button>';
                          }).join('') +
                          '</div>' +
                          '<label style="font-size:0.85rem;font-weight:600;color:#374151;display:block;margin-bottom:4px;">退回原因（必填）</label>' +
                          '<textarea id="swalPanelRejectTa" class="swal2-textarea" placeholder="請填寫退回原因..." style="height:90px;width:100%;box-sizing:border-box;margin:0;"></textarea>',
                    showCancelButton: true,
                    confirmButtonColor: '#e53e3e', cancelButtonColor: '#a0aec0',
                    confirmButtonText: '確認退回', cancelButtonText: '取消',
                    didOpen: function() {
                        document.querySelectorAll('.swal-panel-chip').forEach(function(chip) {
                            chip.addEventListener('click', function() {
                                document.querySelectorAll('.swal-panel-chip').forEach(function(c) {
                                    c.style.background = '#f3f4f6';
                                    c.style.borderColor = '#d1d5db';
                                    c.style.color = '#374151';
                                });
                                this.style.background = '#dc2626';
                                this.style.borderColor = '#dc2626';
                                this.style.color = '#fff';
                                var ta = document.getElementById('swalPanelRejectTa');
                                if (ta) ta.value = this.dataset.val;
                            });
                        });
                    },
                    preConfirm: function() {
                        var ta = document.getElementById('swalPanelRejectTa');
                        var val = ta ? ta.value.trim() : '';
                        if (!val) { Swal.showValidationMessage('退回原因為必填欄位'); return false; }
                        return val;
                    }
                }).then(function(result) {
                    if (result.isConfirmed && onConfirm) onConfirm(result.value);
                });
            }

            // 事件委派：監聽面板底部按鈕（非同步箭頭函式）
            var panelEl = document.getElementById('productDetailPanel');
            if (panelEl) {
                panelEl.addEventListener('click', async function(e) {
                    var btn = e.target.closest('.btn-panel-approve, .btn-panel-reject, .btn-panel-approve-forced, .btn-panel-reject-forced');
                    if (!btn) return;
                    var id   = parseInt(btn.dataset.id);
                    var name = btn.dataset.name;

                    // ── 核准上架（待審核）──
                    if (btn.classList.contains('btn-panel-approve')) {
                        var r = await Swal.fire({
                            title: '確認核准上架',
                            html: '確定要核准商品<br><strong>「' + name + '」</strong>上架嗎？',
                            icon: 'question', showCancelButton: true,
                            confirmButtonColor: '#1abb9c', cancelButtonColor: '#a0aec0',
                            confirmButtonText: '確認核准', cancelButtonText: '取消'
                        });
                        if (!r.isConfirmed) return;
                        try {
                            const res = await apiPost(urlApprove, { id: id });
                            if (res.success) {
                                removeRow(id);
                                Swal.fire({ title: '核准成功！', text: res.message, icon: 'success',
                                            confirmButtonColor: '#1abb9c', timer: 3000, timerProgressBar: true });
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }

                    // ── 退回（待審核）──
                    } else if (btn.classList.contains('btn-panel-reject')) {
                        showPanelRejectModal(name, async function(reason) {
                            try {
                                const res = await apiPost(urlReject, { id: id, reason: reason });
                                if (res.success) {
                                    removeRow(id);
                                    Swal.fire({ title: '已退回！', text: res.message, icon: 'success',
                                                confirmButtonColor: '#1abb9c', timer: 3000, timerProgressBar: true })
                                        .then(function() { window.location.hash = '#rejectedTab'; window.location.reload(); });
                                } else {
                                    Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                                }
                            } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                        });

                    // ── 核准重新上架（重新申請審核）──
                    } else if (btn.classList.contains('btn-panel-approve-forced')) {
                        var r2 = await Swal.fire({
                            title: '核准重新上架',
                            html: '確定要核准商品「<strong>' + name + '</strong>」重新上架？',
                            icon: 'question', showCancelButton: true,
                            confirmButtonColor: '#38a169', cancelButtonColor: '#a0aec0',
                            confirmButtonText: '確認核准', cancelButtonText: '取消'
                        });
                        if (!r2.isConfirmed) return;
                        try {
                            const res = await apiPost(urlApproveForcedProduct, { id: id });
                            if (res.success) {
                                Swal.fire({ title: '已核准！', text: res.message, icon: 'success',
                                            timer: 1800, timerProgressBar: true, confirmButtonColor: '#1abb9c' })
                                    .then(function() { location.reload(); });
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }

                    // ── 再次駁回（重新申請審核）──
                    } else if (btn.classList.contains('btn-panel-reject-forced')) {
                        var r3 = await Swal.fire({
                            title: '駁回重新申請',
                            html: '請填寫駁回原因（賣家將看到此說明）：',
                            input: 'textarea', inputPlaceholder: '請填寫駁回原因...',
                            inputValidator: function(v) { if (!v || v.trim().length < 5) return '請填寫至少 5 字的駁回原因'; },
                            icon: 'warning', showCancelButton: true,
                            confirmButtonColor: '#dc2626', cancelButtonColor: '#a0aec0',
                            confirmButtonText: '確認駁回', cancelButtonText: '取消'
                        });
                        if (!r3.isConfirmed) return;
                        try {
                            const res = await apiPost(urlRejectForcedProduct, { id: id, reason: r3.value.trim() });
                            if (res.success) {
                                Swal.fire({ title: '已駁回', text: res.message, icon: 'success',
                                            timer: 1800, timerProgressBar: true, confirmButtonColor: '#1abb9c' })
                                    .then(function() { location.reload(); });
                            } else {
                                Swal.fire({ title: '操作失敗', text: res.message, icon: 'error', confirmButtonColor: '#e53e3e' });
                            }
                        } catch { Swal.fire({ title: '連線錯誤', text: '請稍後再試。', icon: 'error' }); }
                    }
                });
            }

        })();
    </script>

    <script>
        // ── 即時倒數計時 + 自動觸發軟刪除並淡出 ──────────────────────
        (function () {
            var urlCleanup = '@Url.Action("ForceCleanupExpiredProducts", "Products", new { area = "Admin" })';

            function updateCountdowns() {
                // :not(.is-processing) 防止重複觸發同一列
                document.querySelectorAll('.live-countdown:not(.is-processing)').forEach(function (el) {
                    var expire      = new Date(el.dataset.expire);
                    var secondsLeft = Math.floor((expire - Date.now()) / 1000);

                    if (secondsLeft > 0) {
                        el.className  = 'live-countdown badge bg-warning text-dark';
                        el.textContent = '⏳ 剩餘 ' + secondsLeft + ' 秒';
                    } else {
                        // 標記為處理中，避免 setInterval 下一輪重複呼叫
                        el.classList.add('is-processing');
                        el.classList.remove('bg-warning', 'text-dark');
                        el.classList.add('bg-secondary');
                        el.textContent = '🗑️ 清除中...';

                        var $row      = $(el).closest('tr');
                        var removedId = parseInt($row.data('id'), 10); // 在 AJAX 前捕捉，避免 DOM 移除後失效
                        $.post(urlCleanup, { expirationSeconds: 60 })
                            .done(function (res) {
                                if (res.success) {
                                    $row.fadeOut(800, function () {
                                        $(this).remove();
                                        // ① 同步頁籤總數標籤
                                        var $badge = $('#rejected-count-badge');
                                        var current = parseInt($badge.text(), 10) || 0;
                                        if (current > 0) $badge.text(current - 1);
                                        // ② 若右側面板正在展示此商品，立即關閉面板
                                        if (_activeProductRowId === removedId &&
                                            typeof closeProductDetailPanel === 'function') {
                                            closeProductDetailPanel();
                                        }
                                    });
                                } else {
                                    // 後端回傳失敗（例如已被清除）：直接移除列
                                    $row.fadeOut(400, function () {
                                        $(this).remove();
                                        // ① 同步頁籤總數標籤
                                        var $badge = $('#rejected-count-badge');
                                        var current = parseInt($badge.text(), 10) || 0;
                                        if (current > 0) $badge.text(current - 1);
                                        // ② 若右側面板正在展示此商品，立即關閉面板
                                        if (_activeProductRowId === removedId &&
                                            typeof closeProductDetailPanel === 'function') {
                                            closeProductDetailPanel();
                                        }
                                    });
                                }
                            })
                            .fail(function () {
                                // 網路錯誤：還原 badge，讓使用者可重試
                                el.classList.remove('is-processing', 'bg-secondary');
                                el.classList.add('bg-danger');
                                el.textContent = '可立即清理';
                            });
                    }
                });
            }

            updateCountdowns();                    // 頁面載入立即執行一次，避免短暫顯示「計算中...」
            setInterval(updateCountdowns, 1000);   // 每秒更新
        })();
    </script>

    <script>
        // ── 商品詳情 Push-Pull 側邊面板 ──
        var urlGetProductDetailsPartial = '@Url.Action("GetProductDetailsPartial", "Products")';
        var _activeProductRowId = null;

        function _reviewSwitchMode(toOpen, callback) {
            var tbl    = document.getElementById('reviewTabsContent');
            var panel  = document.getElementById('productDetailPanel');
            var layout = document.getElementById('reviewLayout');
            if (tbl) tbl.style.opacity = '0';
            setTimeout(function () {
                if (toOpen) {
                    if (panel  && !panel.classList.contains('open'))        panel.classList.add('open');
                    if (layout && !layout.classList.contains('panel-open')) layout.classList.add('panel-open');
                } else {
                    if (panel)  panel.classList.remove('open');
                    if (layout) layout.classList.remove('panel-open');
                }
                if (tbl) tbl.style.opacity = '1';
                if (callback) callback();
            }, 180);
        }

        window.openProductOffcanvas = function (id, name) {
            var body    = document.getElementById('productDetailPanelBody');
            var titleEl = document.getElementById('productDetailPanelLabel');

            // 高亮選中列
            if (_activeProductRowId !== null) {
                var prevRow = document.querySelector('tr[data-id="' + _activeProductRowId + '"]');
                if (prevRow) prevRow.classList.remove('row-active');
            }
            _activeProductRowId = id;
            var activeRow = document.querySelector('tr[data-id="' + id + '"]');
            if (activeRow) activeRow.classList.add('row-active');

            if (titleEl) { titleEl.textContent = name || '商品詳情'; titleEl.title = name || '商品詳情'; }
            if (body) body.innerHTML = '<div class="text-center py-5 text-muted"><i class="bx bx-loader-alt bx-spin fs-1 d-block mb-2"></i>載入中…</div>';

            var alreadyOpen = document.getElementById('productDetailPanel').classList.contains('open');
            if (!alreadyOpen) _reviewSwitchMode(true, null);

            fetch(urlGetProductDetailsPartial + '?id=' + id)
                .then(function (res) {
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    return res.text();
                })
                .then(function (html) { if (body) body.innerHTML = html; })
                .catch(function () {
                    if (body) body.innerHTML = '<div class="text-center py-5 text-danger"><i class="bx bx-error-circle fs-1 d-block mb-2"></i>載入失敗，請稍後再試。</div>';
                });
        };

        window.closeProductDetailPanel = function () {
            if (_activeProductRowId !== null) {
                var row = document.querySelector('tr[data-id="' + _activeProductRowId + '"]');
                if (row) row.classList.remove('row-active');
                _activeProductRowId = null;
            }
            _reviewSwitchMode(false, null);
        };

        // Way 1：ESC 鍵關閉面板
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                var panel = document.getElementById('productDetailPanel');
                if (panel && panel.classList.contains('open')) {
                    console.log('[PanelClose] ESC key');
                    closeProductDetailPanel();
                }
            }
        });
        console.log('[Panel] ESC listener bound ✓');

        // Way 3a：點擊兩卡片間的 gap 區域關閉面板
        document.getElementById('reviewLayout').addEventListener('click', function (e) {
            if (e.target === this) {
                var panel = document.getElementById('productDetailPanel');
                if (panel && panel.classList.contains('open')) {
                    console.log('[PanelClose] gap click');
                    closeProductDetailPanel();
                }
            }
        });

        // Way 3b：點擊列表內空白區域（非列、非互動元素）關閉面板
        document.getElementById('reviewListCol').addEventListener('click', function (e) {
            var panel = document.getElementById('productDetailPanel');
            if (!panel || !panel.classList.contains('open')) return;
            if (e.target.closest('tr, button, a, input, select, label, .filter-card, .back-to-list-btn')) return;
            console.log('[PanelClose] list col empty area click');
            closeProductDetailPanel();
        });

        // ── 點擊整行開啟面板（封裝為可重呼叫函式，供 AJAX 分頁後重綁）──
        function _reviewBindPendingRows() {
            document.querySelectorAll('#pendingPanel tbody tr[data-id]').forEach(function (tr) {
                tr.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input')) return;
                    openProductOffcanvas(parseInt(this.dataset.id), this.dataset.name);
                });
            });
        }
        _reviewBindPendingRows();
        document.querySelectorAll('#rejectedPanel tbody tr[data-id], #approvedPanel tbody tr[data-id], #reApplyPanel tbody tr[data-id]').forEach(function (tr) {
            tr.addEventListener('click', function (e) {
                if (e.target.closest('a, button, input')) return;
                openProductOffcanvas(parseInt(this.dataset.id), this.dataset.name);
            });
        });
    </script>
    <script>
    // ── AJAX 分頁：面板展開時換頁不重整（待審核 Tab）──
    (function () {
        function ajaxLoadReviewPage(href) {
            var tabContent = document.getElementById('reviewTabsContent');
            var listCol    = document.getElementById('reviewListCol');
            if (tabContent) tabContent.style.opacity = '0.4';
            fetch(href)
                .then(function (res) { if (!res.ok) throw new Error(); return res.text(); })
                .then(function (html) {
                    var doc = new DOMParser().parseFromString(html, 'text/html');
                    // 更新待審核表格 tbody
                    var newTbody = doc.querySelector('#pendingPanel .table-custom tbody');
                    var tbody    = document.querySelector('#pendingPanel .table-custom tbody');
                    if (tbody && newTbody) tbody.innerHTML = newTbody.innerHTML;
                    // 更新待審核分頁導航
                    var newNav = doc.querySelector('#pendingPanel nav');
                    var curNav = document.querySelector('#pendingPanel nav');
                    if (curNav && newNav) curNav.outerHTML = newNav.outerHTML;
                    // 重綁行點擊
                    _reviewBindPendingRows();
                    // 滾回頂部
                    if (listCol) listCol.scrollTop = 0;
                    // 恢復透明度
                    if (tabContent) tabContent.style.opacity = '1';
                    // 自動開啟第一筆
                    _activeProductRowId = null;
                    var firstRow = document.querySelector('#pendingPanel tbody tr[data-id]');
                    if (firstRow) {
                        openProductOffcanvas(parseInt(firstRow.dataset.id), firstRow.dataset.name || '商品詳情');
                    }
                    // 同步網址列
                    history.pushState(null, '', href);
                })
                .catch(function () { window.location.href = href; });
        }

        // 事件委派：攔截 #reviewListCol 內待審核 Tab 的分頁點擊（面板已開啟時）
        document.getElementById('reviewListCol').addEventListener('click', function (e) {
            var panel = document.getElementById('productDetailPanel');
            if (!panel || !panel.classList.contains('open')) return;
            if (!e.target.closest('#pendingPanel')) return;
            var link = e.target.closest('.page-link');
            if (!link) return;
            var pageItem = link.closest('.page-item');
            if (!pageItem || pageItem.classList.contains('disabled') || pageItem.classList.contains('active')) return;
            var href = link.getAttribute('href');
            if (!href || href === '#') return;
            e.preventDefault();
            ajaxLoadReviewPage(href);
        });
    })();
    </script>
