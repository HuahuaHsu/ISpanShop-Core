<script>
    // ══════════════════════════════════════════════════════
    //  待審核狀態 badge 點擊事件：跳轉到商品審核中心
    // ══════════════════════════════════════════════════════
    function navigateToPendingReview(event) {
        event.preventDefault();
        event.stopPropagation();
        console.log('待審核 badge 被點擊，準備跳轉到商品審核中心');
        
        // 設定 sessionStorage，確保左側選單「商品審核」項目會被標記為 active
        sessionStorage.setItem('openMenuKey', 'products');
        sessionStorage.setItem('pageTitle', '商品審核中心 - ISpanShop 後台管理系統');
        
        // 跳轉到商品審核中心頁面
        window.location.href = '@Url.Action("PendingReview", "Products", new { area = "Admin" })';
    }
</script>
