@model ISpanShop.Models.EfModels.Role

@{
    ViewData["Title"] = "編輯角色";
    Layout = "_SneatLayout";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- 頁面標題 -->
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Role" asp-action="Index">角色管理</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">編輯角色</li>
            </ol>
        </nav>
        <h4 class="fw-bold mb-1">
            <i class="bx bx-edit text-primary me-2"></i>編輯角色
        </h4>
        <p class="text-muted mb-0">修改現有角色資訊</p>
    </div>

    <!-- 表單卡片 -->
    <div class="row">
        <div class="col-xl-8 col-lg-10">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bx bx-edit-alt me-2"></i>角色資訊
                    </h5>
                    <span class="badge bg-label-primary">
                        ID: @Model.Id
                    </span>
                </div>
                <div class="card-body">
                    <form asp-area="Admin" asp-controller="Role" asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        @* 隱藏欄位傳遞 ID *@
                        <input type="hidden" asp-for="Id" />

                        <!-- 角色名稱 -->
                        <div class="mb-3">
                            <label asp-for="RoleName" class="form-label required">
                                <i class="bx bx-shield me-1"></i>角色名稱
                            </label>
                            <input asp-for="RoleName" 
                                   class="form-control" 
                                   placeholder="請輸入角色名稱" 
                                   maxlength="50"
                                   required />
                            <span asp-validation-for="RoleName" class="text-danger small"></span>
                            <div class="form-text">
                                <i class="bx bx-info-circle me-1"></i>角色名稱用於系統權限識別
                            </div>
                        </div>

                        <!-- 描述 -->
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label">
                                <i class="bx bx-detail me-1"></i>描述
                            </label>
                            <textarea asp-for="Description" 
                                      class="form-control" 
                                      rows="4" 
                                      placeholder="請輸入角色的詳細描述"
                                      maxlength="500"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <div class="form-text">
                                <i class="bx bx-info-circle me-1"></i>說明此角色的用途與權限範圍
                            </div>
                        </div>

                        <!-- 按鈕群組 -->
                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-area="Admin" asp-controller="Role" asp-action="Index" 
                               class="btn btn-label-secondary">
                                <i class="bx bx-arrow-back me-1"></i>取消返回
                            </a>
                            <div class="d-flex gap-2">
                                <a asp-area="Admin" asp-controller="Role" asp-action="Details" asp-route-id="@Model.Id"
                                   class="btn btn-label-info">
                                    <i class="bx bx-show me-1"></i>查看詳細
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bx bx-save me-1"></i>更新角色
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- 警告提示卡片 -->
            <div class="alert alert-warning d-flex align-items-center mt-3" role="alert">
                <i class="bx bx-error-circle fs-4 me-3"></i>
                <div>
                    <h6 class="alert-heading mb-1">注意事項</h6>
                    <p class="mb-0">
                        修改角色名稱可能會影響系統權限判斷邏輯，請謹慎操作。如有使用者正在使用此角色，變更後可能需要重新登入。
                    </p>
                </div>
            </div>

            <!-- 使用者統計卡片 -->
            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bx bx-group text-info me-2"></i>角色使用情況
                    </h6>
                    <div class="d-flex align-items-center">
                        <div class="avatar avatar-sm me-3" style="width: 40px; height: 40px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                            <i class="bx bx-user text-white" style="font-size: 1.2rem;"></i>
                        </div>
                        <div>
                            <p class="mb-0 text-muted small">目前使用此角色的使用者</p>
                            <h5 class="mb-0">@Model.Users?.Count ?? 0 位</h5>
                        </div>
                    </div>
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        <div class="mt-3 pt-3 border-top">
                            <small class="text-muted">
                                <i class="bx bx-info-circle me-1"></i>
                                此角色目前有使用者使用中，刪除前請先將使用者調整至其他角色
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // 表單驗證與提交處理
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            const roleNameInput = document.querySelector('input[name="RoleName"]');
            const originalRoleName = roleNameInput.value;
            
            // 角色名稱變更警告
            roleNameInput.addEventListener('change', function() {
                if (this.value !== originalRoleName) {
                    const confirmChange = confirm('變更角色名稱可能會影響系統權限判斷，確定要變更嗎？');
                    if (!confirmChange) {
                        this.value = originalRoleName;
                    }
                }
            });

            // 表單提交確認
            form.addEventListener('submit', function(e) {
                if (!form.checkValidity()) {
                    e.preventDefault();
                    e.stopPropagation();
                }
                form.classList.add('was-validated');
            });
        });
    </script>

    <style>
        .required::after {
            content: " *";
            color: #ff4d4f;
        }
        
        .form-control:focus {
            border-color: #696cff;
            box-shadow: 0 0 0 0.2rem rgba(105, 108, 255, 0.25);
        }
    </style>
}
