@model IEnumerable<ISpanShop.Models.EfModels.Role>

@{
    ViewData["Title"] = "管理員權限列表";
    Layout = "_SneatLayout";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- 頁面標題 -->
    <div class="mb-4">
        <h4 class="fw-bold mb-1">
            <i class="bx bx-key text-primary me-2"></i>管理員權限列表
        </h4>
        <p class="text-muted mb-0">系統管理員及權限</p>
    </div>

    <!-- 功能按鈕列 -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <span class="badge bg-label-info">
                <i class="bx bx-list-ul me-1"></i>共 @Model.Count() 個角色
            </span>
        </div>
        @* 只有 SuperAdmin 可以看到新增角色按鈕 *@
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <div>
                <a asp-area="Admin" asp-controller="Role" asp-action="Create" class="btn btn-primary">
                    <i class="bx bx-plus me-1"></i>新增角色
                </a>
            </div>
        }
    </div>

    <!-- 角色管理卡片 -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bx bx-shield-quarter me-2"></i>角色與權限管理
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%;" class="text-center">#</th>
                            <th style="width: 20%;">角色名稱</th>
                            <th style="width: 15%;" class="text-center">角色標識</th>
                            <th style="width: 25%;">權限配置</th>
                            <th style="width: 10%;" class="text-center">操作</th>
                            <th style="width: 15%;">描述</th>
                            <th style="width: 10%;" class="text-center">詳細</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int rowIndex = 1;
                            foreach (var role in Model)
                            {
                                <tr>
                                    <!-- 序號 -->
                                    <td class="text-center">
                                        <span class="text-muted fw-semibold">@rowIndex</span>
                                    </td>

                                    <!-- 角色名稱 -->
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar avatar-sm me-2" style="width: 32px; height: 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bx bx-user-circle text-white" style="font-size: 1.2rem;"></i>
                                            </div>
                                            <div>
                                                <span class="fw-semibold d-block">@role.RoleName</span>
                                                <small class="text-muted">Role ID: @role.Id</small>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- 角色標識 (Badge) -->
                                    <td class="text-center">
                                        @{
                                            var badgeClass = role.RoleName?.ToLower() switch
                                            {
                                                var r when r.Contains("admin") => "bg-label-danger",
                                                var r when r.Contains("manager") => "bg-label-warning",
                                                var r when r.Contains("user") => "bg-label-info",
                                                _ => "bg-label-primary"
                                            };
                                        }
                                        <span class="badge @badgeClass">
                                            <i class="bx bx-shield me-1"></i>@role.RoleName
                                        </span>
                                    </td>

                                    <!-- 權限配置 (下拉選單) -->
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <select class="form-select form-select-sm d-inline-block" 
                                                    style="width: 180px;"
                                                    id="permission-@role.Id"
                                                    onchange="updatePermission(@role.Id, this.value)">
                                                <option value="">-- 選擇權限 --</option>
                                                <option value="read">讀取權限</option>
                                                <option value="write">寫入權限</option>
                                                <option value="delete">刪除權限</option>
                                                <option value="full">完整權限</option>
                                            </select>
                                            <button type="button" 
                                                    class="btn btn-primary btn-sm"
                                                    onclick="applyPermission(@role.Id)">
                                                <i class="bx bx-check me-1"></i>更新
                                            </button>
                                        </div>
                                    </td>

                                    <!-- 操作按鈕 -->
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            @* 編輯按鈕 - 使用 Tag Helpers *@
                                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                            {
                                                <a asp-area="Admin" 
                                                   asp-controller="Role" 
                                                   asp-action="Edit" 
                                                   asp-route-id="@role.Id"
                                                   class="btn btn-sm btn-icon btn-outline-primary"
                                                   title="編輯">
                                                    <i class="bx bx-edit"></i>
                                                </a>
                                            }

                                            @* 刪除按鈕 - 先導向刪除確認頁 *@
                                            @if (User.IsInRole("SuperAdmin"))
                                            {
                                                <a asp-area="Admin" 
                                                   asp-controller="Role" 
                                                   asp-action="Delete" 
                                                   asp-route-id="@role.Id"
                                                   class="btn btn-sm btn-icon btn-outline-danger"
                                                   title="刪除">
                                                    <i class="bx bx-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>

                                    <!-- 描述 -->
                                    <td>
                                        @if (!string.IsNullOrEmpty(role.Description))
                                        {
                                            <small class="text-muted">@role.Description</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted fst-italic">無描述</small>
                                        }
                                    </td>

                                    <!-- 詳細連結 -->
                                    <td class="text-center">
                                        <a asp-area="Admin" 
                                           asp-controller="Role" 
                                           asp-action="Details" 
                                           asp-route-id="@role.Id"
                                           class="btn btn-link text-primary p-0">
                                            <i class="bx bx-show me-1"></i>詳細
                                        </a>
                                    </td>
                                </tr>
                                rowIndex++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bx bx-info-circle fs-1 mb-2 d-block"></i>
                                        <p class="mb-0">目前沒有任何角色資料</p>
                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                        {
                                            <a asp-area="Admin" 
                                               asp-controller="Role" 
                                               asp-action="Create"
                                               class="btn btn-sm btn-primary mt-3">
                                                <i class="bx bx-plus me-1"></i>立即新增第一個角色
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="card-footer bg-light border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        <i class="bx bx-time-five me-1"></i>最後更新：@DateTime.Now.ToString("yyyy/MM/dd HH:mm")
                    </small>
                    <small class="text-muted">
                        共 @Model.Count() 個角色
                    </small>
                </div>
            </div>
        }
    </div>

    <!-- 權限說明卡片 -->
    <div class="card mt-4">
        <div class="card-body">
            <h6 class="card-title">
                <i class="bx bx-info-circle text-info me-2"></i>權限等級說明
            </h6>
            <div class="row mt-3">
                <div class="col-md-3">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-label-info me-2">讀取</span>
                        <small class="text-muted">可查看資料</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-label-warning me-2">寫入</span>
                        <small class="text-muted">可新增/修改資料</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-label-danger me-2">刪除</span>
                        <small class="text-muted">可刪除資料</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-label-success me-2">完整</span>
                        <small class="text-muted">擁有所有權限</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 更新權限配置
        function updatePermission(roleId, permission) {
            if (!permission) {
                return;
            }
            console.log('角色 ID: ' + roleId + ', 選擇的權限: ' + permission);
        }

        // 應用權限變更
        function applyPermission(roleId) {
            var selectElement = document.getElementById('permission-' + roleId);
            var selectedPermission = selectElement.value;
            
            if (!selectedPermission) {
                showAlert('請先選擇一個權限選項');
                return;
            }

            // 這裡可以發送 AJAX 請求到後端 API
            showAlert('正在更新角色 ' + roleId + ' 的權限為: ' + selectedPermission + '\n\n此功能需要後端 API 支援。');
            
            // 範例 AJAX 請求（需要後端 API 配合）
            /*
            fetch('/Admin/Role/UpdatePermission', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({
                    roleId: roleId,
                    permission: selectedPermission
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showAlert('權限更新成功！');
                    location.reload();
                } else {
                    showAlert('權限更新失敗：' + data.message);
                }
            })
            .catch(error => {
                showAlert('發生錯誤：' + error);
            });
            */
        }

        // 表格列 hover 效果
        document.querySelectorAll('.table-hover tbody tr').forEach(function(row) {
            if (row.querySelector('td[colspan]')) return; // 跳過空資料列
            row.style.cursor = 'default';
        });
    </script>
}
