@model IEnumerable<ISpanShop.Models.EfModels.PaymentLog>

@{
    ViewData["Title"] = "金流管理中心";
    Layout = "_SneatLayout";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- 頁面標題 -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bx bx-dollar-circle text-primary me-2"></i>金流管理中心 (Payment Logs)
        </h4>
        <div>
            <form asp-action="SyncPaymentLogs" method="post" class="d-inline">
                <button type="submit" class="btn btn-primary shadow-sm">
                    <i class="bx bx-refresh me-1"></i>同步/生成缺失紀錄
                </button>
            </form>
            <span class="badge bg-label-info ms-2">
                <i class="bx bx-list-ul me-1"></i>共 @Model.Count() 筆紀錄
            </span>
        </div>
    </div>

    <!-- 金流紀錄卡片 -->
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center bg-white">
            <h5 class="mb-0 text-dark fw-bold">
                <i class="bx bx-credit-card me-2 text-primary"></i>所有交易流水帳
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 10%;">訂單編號</th>
                            <th style="width: 18%;">綠界交易序號 (TradeNo)</th>
                            <th class="text-center" style="width: 12%;">付款方式</th>
                            <th class="text-end" style="width: 12%;">交易金額</th>
                            <th class="text-center" style="width: 12%;">交易狀態</th>
                            <th class="text-center" style="width: 15%;">付款時間</th>
                            <th class="text-center" style="width: 15%;">紀錄建立時間</th>
                            <th class="text-center" style="width: 6%;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var log in Model)
                            {
                                var order = log.Order;
                                
                                // 判斷付款狀態 (RtnCode == 1 為成功)
                                string statusBadgeClass = "bg-label-warning";
                                string statusText = log.RtnMsg switch {
                                    "Succeeded" or "付款成功" => "付款成功",
                                    "Pending Payment" or "等待付款中" => "等待付款中",
                                    "Order Cancelled" or "訂單已取消" => "訂單已取消",
                                    _ => log.RtnMsg ?? "處理中"
                                };
                                
                                if (log.RtnCode == 1)
                                {
                                    statusBadgeClass = "bg-label-success";
                                }
                                else if (log.RtnCode == 1022 || (order != null && order.Status == 4))
                                {
                                    statusBadgeClass = "bg-label-danger";
                                }

                                <tr>
                                    <!-- 訂單編號 -->
                                    <td class="text-center">
                                        @if (order != null)
                                        {
                                            <span class="fw-semibold text-primary">
                                                #@order.OrderNumber
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">未知訂單</span>
                                        }
                                    </td>

                                    <!-- 綠界交易序號 -->
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.TradeNo))
                                        {
                                            <small class="text-dark fw-bold d-block">
                                                <i class="bx bx-barcode me-1"></i>@log.TradeNo
                                            </small>
                                            <small class="text-muted d-block mt-1">
                                                商店單號: @log.MerchantTradeNo
                                            </small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">待付款/未生成序號</small>
                                            <small class="text-muted d-block mt-1">
                                                商店單號: @log.MerchantTradeNo
                                            </small>
                                        }
                                    </td>

                                    <!-- 付款方式 -->
                                    <td class="text-center">
                                        @{
                                            var pType = log.PaymentType ?? "None";
                                            var paymentIcon = pType switch
                                            {
                                                "Credit" or "信用卡" => "bx-credit-card",
                                                "ATM" or "ATM轉帳" => "bx-bank",
                                                "CVS" or "超商代碼" => "bx-store",
                                                _ => "bx-wallet"
                                            };
                                            var paymentLabel = pType switch
                                            {
                                                "Credit" => "信用卡",
                                                "ATM" => "ATM轉帳",
                                                "CVS" => "超商代碼",
                                                "None" => "尚未選擇",
                                                _ => pType
                                            };
                                        }
                                        <i class="bx @paymentIcon me-1"></i>
                                        <span>@paymentLabel</span>
                                    </td>

                                    <!-- 交易金額 -->
                                    <td class="text-end">
                                        <span class="fw-bold text-dark">
                                            $ @(log.TradeAmt?.ToString("N0") ?? "0")
                                        </span>
                                    </td>

                                    <!-- 交易狀態 -->
                                    <td class="text-center">
                                        <span class="badge @statusBadgeClass">
                                            @statusText
                                        </span>
                                        @if (log.RtnCode != 1 && !string.IsNullOrEmpty(log.RtnMsg) && log.RtnMsg != "Succeeded")
                                        {
                                            <br />
                                            <small class="text-muted" style="font-size: 0.75rem;">
                                                Code: @log.RtnCode
                                            </small>
                                        }
                                    </td>

                                    <!-- 付款時間 -->
                                    <td class="text-center">
                                        @if (log.PaymentDate.HasValue)
                                        {
                                            <span>@log.PaymentDate.Value.ToString("yyyy/MM/dd")</span>
                                            <br />
                                            <small class="text-muted">@log.PaymentDate.Value.ToString("HH:mm:ss")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- 紀錄建立時間 -->
                                    <td class="text-center">
                                        <span>@log.CreatedAt?.ToString("yyyy/MM/dd")</span>
                                        <br />
                                        <small class="text-muted">@log.CreatedAt?.ToString("HH:mm:ss")</small>
                                    </td>

                                    <!-- 操作 -->
                                    <td class="text-center">
                                        <div class="dropdown">
                                            <button type="button" class="btn btn-sm btn-icon btn-text-secondary rounded-pill dropdown-toggle hide-arrow" 
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bx bx-dots-vertical-rounded"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                @if (order != null)
                                                {
                                                    <li>
                                                        <a class="dropdown-item" href="@Url.Action("Details", "Orders", new { area = "Admin", id = order.Id })">
                                                            <i class="bx bx-show me-2"></i>查看關聯訂單
                                                        </a>
                                                    </li>
                                                }
                                                <li>
                                                    <a class="dropdown-item" href="javascript:void(0);" 
                                                       onclick="showRawLog(@log.Id)">
                                                        <i class="bx bx-code-alt me-2"></i>查看原始紀錄
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bx bx-info-circle fs-1 mb-2 d-block text-light"></i>
                                        <p class="mb-0">目前沒有任何金流紀錄資料</p>
                                        <small>請點擊上方按鈕從訂單資料同步生成</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showRawLog(logId) {
            alert('交易紀錄 ID: ' + logId + '\n\n此處未來可實作 AJAX 抓取資料庫中的完整回傳欄位 (JSON)。');
        }
    </script>
}
