@model ISpanShop.MVC.Areas.Admin.Models.Admins.LoginHistoryIndexVm
@using System.Linq

@{
    ViewData["Title"] = "系統登入紀錄";
    Layout = "_SneatLayout";
    var criteria = Model.SearchCriteria;
    var pagination = Model.PaginationInfo;
}

<div class="container-xxl flex-grow-1 container-p-y">
    <!-- 頁面標題 -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">
                <i class="bx bx-shield-lock text-primary me-2"></i>系統登入紀錄
            </h4>
            <p class="text-muted mb-0">查看系統所有使用者的登入記錄</p>
        </div>
        <div>
            <span class="badge bg-primary rounded-pill px-3 py-2" style="font-size: 0.875rem;">
                <i class="bx bx-list-ul me-1"></i>總筆數: @pagination.TotalCount
            </span>
        </div>
    </div>

    @* 成功/錯誤訊息 *@
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bx bx-info-circle me-2"></i>@Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- 查詢條件卡片 -->
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bx bx-search-alt me-2"></i>查詢條件
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" id="searchForm">
                <div class="row g-3">
                    <!-- 關鍵字 -->
                    <div class="col-md-4">
                        <label for="keyword" class="form-label">
                            <i class="bx bx-search me-1"></i>關鍵字 (帳號或 IP)
                        </label>
                        <input type="text" 
                               name="keyword" 
                               id="keyword" 
                               class="form-control" 
                               placeholder="搜尋帳號或 IP 位址..." 
                               value="@criteria.Keyword">
                    </div>

                    <!-- 登入狀態 -->
                    <div class="col-md-3">
                        <label for="isSuccessful" class="form-label">
                            <i class="bx bx-check-circle me-1"></i>登入狀態
                        </label>
                        <select name="isSuccessful" id="isSuccessful" class="form-select">
                            <option value="all" selected="@(criteria.IsSuccessfulFilter == "all")">全部</option>
                            <option value="success" selected="@(criteria.IsSuccessfulFilter == "success")">登入成功</option>
                            <option value="failure" selected="@(criteria.IsSuccessfulFilter == "failure")">登入失敗</option>
                        </select>
                    </div>

                    <!-- 每頁筆數 -->
                    <div class="col-md-2">
                        <label for="pageSize" class="form-label">
                            <i class="bx bx-list-ol me-1"></i>每頁筆數
                        </label>
                        <select name="pageSize" id="pageSize" class="form-select" onchange="this.form.submit()">
                            <option value="10" selected="@(criteria.PageSize == 10)">10</option>
                            <option value="20" selected="@(criteria.PageSize == 20)">20</option>
                            <option value="50" selected="@(criteria.PageSize == 50)">50</option>
                            <option value="100" selected="@(criteria.PageSize == 100)">100</option>
                        </select>
                    </div>

                    <!-- 按鈕群組 -->
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bx bx-search me-1"></i>搜尋
                        </button>
                        <a asp-action="Index" class="btn btn-label-secondary">
                            <i class="bx bx-reset me-1"></i>重置
                        </a>
                    </div>
                </div>

                @* 隱藏欄位保持排序狀態 *@
                <input type="hidden" name="sortColumn" value="@criteria.SortColumn" />
                <input type="hidden" name="sortDirection" value="@criteria.SortDirection" />
            </form>
        </div>
    </div>

    <!-- 登入紀錄列表卡片 -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 8%;">
                                <a asp-action="Index"
                                   asp-route-sortColumn="Id"
                                   asp-route-sortDirection="@(criteria.SortColumn == "Id" && criteria.SortDirection == "asc" ? "desc" : "asc")"
                                   asp-route-keyword="@criteria.Keyword"
                                   asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                   asp-route-pageSize="@criteria.PageSize"
                                   class="text-decoration-none text-dark d-flex align-items-center justify-content-center">
                                    ID
                                    @if (criteria.SortColumn == "Id")
                                    {
                                        <i class="bx bx-sort-@(criteria.SortDirection == "asc" ? "up" : "down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                            <th style="width: 25%;">
                                <a asp-action="Index"
                                   asp-route-sortColumn="UserAccount"
                                   asp-route-sortDirection="@(criteria.SortColumn == "UserAccount" && criteria.SortDirection == "asc" ? "desc" : "asc")"
                                   asp-route-keyword="@criteria.Keyword"
                                   asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                   asp-route-pageSize="@criteria.PageSize"
                                   class="text-decoration-none text-dark d-flex align-items-center">
                                    使用者帳號
                                    @if (criteria.SortColumn == "UserAccount")
                                    {
                                        <i class="bx bx-sort-@(criteria.SortDirection == "asc" ? "up" : "down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                            <th style="width: 20%;">
                                <a asp-action="Index"
                                   asp-route-sortColumn="IpAddress"
                                   asp-route-sortDirection="@(criteria.SortColumn == "IpAddress" && criteria.SortDirection == "asc" ? "desc" : "asc")"
                                   asp-route-keyword="@criteria.Keyword"
                                   asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                   asp-route-pageSize="@criteria.PageSize"
                                   class="text-decoration-none text-dark d-flex align-items-center">
                                    IP 位址
                                    @if (criteria.SortColumn == "IpAddress")
                                    {
                                        <i class="bx bx-sort-@(criteria.SortDirection == "asc" ? "up" : "down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                            <th style="width: 25%;">
                                <a asp-action="Index"
                                   asp-route-sortColumn="LoginTime"
                                   asp-route-sortDirection="@(criteria.SortColumn == "LoginTime" && criteria.SortDirection == "asc" ? "desc" : "asc")"
                                   asp-route-keyword="@criteria.Keyword"
                                   asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                   asp-route-pageSize="@criteria.PageSize"
                                   class="text-decoration-none text-dark d-flex align-items-center">
                                    登入時間
                                    @if (criteria.SortColumn == "LoginTime")
                                    {
                                        <i class="bx bx-sort-@(criteria.SortDirection == "asc" ? "up" : "down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                            <th class="text-center" style="width: 12%;">
                                <a asp-action="Index"
                                   asp-route-sortColumn="IsSuccessful"
                                   asp-route-sortDirection="@(criteria.SortColumn == "IsSuccessful" && criteria.SortDirection == "asc" ? "desc" : "asc")"
                                   asp-route-keyword="@criteria.Keyword"
                                   asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                   asp-route-pageSize="@criteria.PageSize"
                                   class="text-decoration-none text-dark d-flex align-items-center justify-content-center">
                                    狀態
                                    @if (criteria.SortColumn == "IsSuccessful")
                                    {
                                        <i class="bx bx-sort-@(criteria.SortDirection == "asc" ? "up" : "down") ms-1 text-primary"></i>
                                    }
                                </a>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.LoginHistories != null && Model.LoginHistories.Count > 0)
                        {
                            foreach (var item in Model.LoginHistories)
                            {
                                <tr>
                                    <!-- ID -->
                                    <td class="text-center">
                                        <span class="text-muted fw-semibold">#@item.Id</span>
                                    </td>

                                    <!-- 使用者帳號 -->
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar avatar-sm me-2" style="width: 32px; height: 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                <span class="text-white fw-bold" style="font-size: 0.7rem;">
                                                    @(item.UserAccount?.Substring(0, Math.Min(2, item.UserAccount.Length)).ToUpper() ?? "?")
                                                </span>
                                            </div>
                                            <span class="fw-semibold">@item.UserAccount</span>
                                        </div>
                                    </td>

                                    <!-- IP 位址 -->
                                    <td>
                                        <span class="badge bg-label-secondary font-monospace">
                                            <i class="bx bx-world me-1"></i>@item.IpAddress
                                        </span>
                                    </td>

                                    <!-- 登入時間 -->
                                    <td>
                                        <span class="text-muted">
                                            <i class="bx bx-time me-1"></i>@item.LoginTimeFormatted
                                        </span>
                                    </td>

                                    <!-- 狀態 -->
                                    <td class="text-center">
                                        @if (item.IsSuccessful == true)
                                        {
                                            <span class="badge bg-label-success">
                                                <i class="bx bx-check-circle me-1"></i>@item.StatusText
                                            </span>
                                        }
                                        else if (item.IsSuccessful == false)
                                        {
                                            <span class="badge bg-label-danger">
                                                <i class="bx bx-x-circle me-1"></i>@item.StatusText
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-label-secondary">
                                                <i class="bx bx-help-circle me-1"></i>@item.StatusText
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bx bx-search fs-1 mb-2 d-block"></i>
                                        <p class="mb-0">目前查無符合條件的登入紀錄</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* 分頁控制項 *@
        @if (pagination.TotalPages > 0)
        {
            <div class="card-footer bg-light border-top">
                <div class="row align-items-center">
                    <!-- 左側：顯示筆數資訊 -->
                    <div class="col-sm-6 text-center text-sm-start mb-3 mb-sm-0">
                        <small class="text-muted">
                            顯示第 <span class="fw-semibold">@(((pagination.CurrentPageNumber - 1) * pagination.PageSize) + 1)</span>
                            至 <span class="fw-semibold">@(Math.Min(pagination.CurrentPageNumber * pagination.PageSize, pagination.TotalCount))</span>
                            筆，共 <span class="fw-semibold">@pagination.TotalCount</span> 筆
                        </small>
                    </div>

                    <!-- 右側：分頁按鈕 -->
                    <div class="col-sm-6">
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-sm justify-content-center justify-content-sm-end mb-0">
                                <!-- 第一頁 -->
                                <li class="page-item @(pagination.CurrentPageNumber == 1 ? "disabled" : "")">
                                    <a class="page-link" 
                                       asp-action="Index" 
                                       asp-route-pageNumber="1"
                                       asp-route-keyword="@criteria.Keyword" 
                                       asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                       asp-route-sortColumn="@criteria.SortColumn" 
                                       asp-route-sortDirection="@criteria.SortDirection"
                                       asp-route-pageSize="@criteria.PageSize">
                                        <i class="bx bx-chevrons-left"></i>
                                    </a>
                                </li>

                                <!-- 上一頁 -->
                                <li class="page-item @(!pagination.HasPreviousPage ? "disabled" : "")">
                                    <a class="page-link" 
                                       asp-action="Index" 
                                       asp-route-pageNumber="@(pagination.CurrentPageNumber - 1)"
                                       asp-route-keyword="@criteria.Keyword" 
                                       asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                       asp-route-sortColumn="@criteria.SortColumn" 
                                       asp-route-sortDirection="@criteria.SortDirection"
                                       asp-route-pageSize="@criteria.PageSize">
                                        <i class="bx bx-chevron-left"></i>
                                    </a>
                                </li>

                                <!-- 頁碼 -->
                                @foreach (var pageNum in pagination.PageNumbers)
                                {
                                    <li class="page-item @(pageNum == pagination.CurrentPageNumber ? "active" : "")">
                                        <a class="page-link" 
                                           asp-action="Index" 
                                           asp-route-pageNumber="@pageNum"
                                           asp-route-keyword="@criteria.Keyword" 
                                           asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                           asp-route-sortColumn="@criteria.SortColumn" 
                                           asp-route-sortDirection="@criteria.SortDirection"
                                           asp-route-pageSize="@criteria.PageSize">
                                            @pageNum
                                        </a>
                                    </li>
                                }

                                <!-- 下一頁 -->
                                <li class="page-item @(!pagination.HasNextPage ? "disabled" : "")">
                                    <a class="page-link" 
                                       asp-action="Index" 
                                       asp-route-pageNumber="@(pagination.CurrentPageNumber + 1)"
                                       asp-route-keyword="@criteria.Keyword" 
                                       asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                       asp-route-sortColumn="@criteria.SortColumn" 
                                       asp-route-sortDirection="@criteria.SortDirection"
                                       asp-route-pageSize="@criteria.PageSize">
                                        <i class="bx bx-chevron-right"></i>
                                    </a>
                                </li>

                                <!-- 最後一頁 -->
                                <li class="page-item @(pagination.CurrentPageNumber == pagination.TotalPages ? "disabled" : "")">
                                    <a class="page-link" 
                                       asp-action="Index" 
                                       asp-route-pageNumber="@pagination.TotalPages"
                                       asp-route-keyword="@criteria.Keyword" 
                                       asp-route-isSuccessful="@criteria.IsSuccessfulFilter"
                                       asp-route-sortColumn="@criteria.SortColumn" 
                                       asp-route-sortDirection="@criteria.SortDirection"
                                       asp-route-pageSize="@criteria.PageSize">
                                        <i class="bx bx-chevrons-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // 表格列 hover 效果
        document.querySelectorAll('.table tbody tr').forEach(function(row) {
            if (!row.querySelector('td[colspan]')) {
                row.style.cursor = 'default';
            }
        });
    </script>
}
