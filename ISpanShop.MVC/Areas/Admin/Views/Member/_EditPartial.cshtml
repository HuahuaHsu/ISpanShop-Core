@model ISpanShop.MVC.Areas.Admin.Models.Members.MemberEditVm

@{
    Layout = null;

    // ── 1. 補上與 Index 完全相同的粉彩 Google 色盤 ──
    var avatarColors = new[] {
        "#e57373", "#f06292", "#ba68c8", "#9575cd",
        "#7986cb", "#64b5f6", "#29b6f6", "#26c6da",
        "#4db6ac", "#81c784", "#9ccc65", "#ffa726",
        "#ff8a65", "#a1887f", "#90a4ae"
    };

    // ── 2. 【完美同步解法】直接使用 UserId 計算專屬顏色與首字 ──
    string bgColor = avatarColors[Math.Abs(Model.UserId) % avatarColors.Length];
    string initial = !string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName.Substring(0, 1).ToUpper() : "?";

    var levelBadgeClass = Model.LevelName switch
    {
        "金牌會員" => "bg-warning text-dark",
        "銀牌會員" => "bg-info text-white",
        "銅牌會員" => "bg-secondary text-white",
        _ => "bg-dark text-white"
    };
    var levelIcon = Model.LevelName switch
    {
        "金牌會員" => "bx-medal",
        "銀牌會員" => "bx-award",
        "銅牌會員" => "bx-trophy",
        _ => "bx-star"
    };
}

<style>
    /* 這裡也要補上頭像所需的 CSS，確保 AJAX 載入後樣式正確 */
    .member-avatar-container {
        position: relative;
        border-radius: 50%;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #e2e8f0;
        flex-shrink: 0;
    }

    .member-avatar-initial {
        color: #ffffff;
        font-weight: 600;
        user-select: none;
    }

    .member-avatar-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .drawer-edit-avatar {
        width: 72px;
        height: 72px;
    }

    .drawer-form-section {
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 1.25rem;
        margin-bottom: 1.25rem;
    }

        .drawer-form-section:last-of-type {
            border-bottom: none;
        }

    .blacklist-box {
        background: #fff5f5;
        border: 1px solid #feb2b2;
        border-radius: 0.5rem;
        padding: 1rem 1.25rem;
    }

        .blacklist-box .form-check-input:checked {
            background-color: #ea5455;
            border-color: #ea5455;
        }

    .readonly-field {
        background-color: #f8f9fa !important;
        cursor: not-allowed !important;
        pointer-events: none;
    }
</style>

<form id="drawerEditForm"
      action="/Admin/Members/Edit/@Model.UserId"
      method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="UserId" value="@Model.UserId" />
    <input type="hidden" name="AvatarUrl" value="@Model.AvatarUrl" id="hiddenAvatarUrl" />

    <input type="hidden" name="City" value="@Model.City" />
    <input type="hidden" name="Region" value="@Model.Region" />

    @* ── 會員資訊頭部 ── *@
    <div class="d-flex align-items-center gap-3 p-4 border-bottom bg-light">

        <div class="member-avatar-container drawer-edit-avatar" style="background-color: @bgColor;">
            <span class="member-avatar-initial fs-3">@initial</span>
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="@Model.AvatarUrl"
                     alt="@Model.FullName"
                     class="member-avatar-img"
                     id="drawerAvatarPreview"
                     onerror="this.style.display='none'" />
            }
        </div>

        <div>
            <div class="fw-bold fs-5" style="color:#1e2d3d;">@Model.FullName</div>
            <div class="text-muted small">@@@Model.Account</div>
            <span class="badge @levelBadgeClass mt-1 px-2 py-1">
                <i class="bx @levelIcon me-1"></i>@Model.LevelName
            </span>
        </div>
        <div class="ms-auto text-end">
            <div class="text-muted small">累計消費 / 點數</div>
            <div class="fw-bold" style="color:#2c3e50; font-size:0.95rem;">
                <i class="bx bx-wallet"></i> NT$ @Model.TotalSpending.ToString("N0")
            </div>
            <div class="fw-bold" style="color:#ff9f43; font-size:1.1rem;">
                <i class="bx bx-coin"></i> P @Model.PointBalance.ToString("N0")
            </div>
        </div>
    </div>

    @* ── 表單主體 ── *@
    <div class="p-4">

        @* 基本資料 (全改為唯讀，移除必填星號與 required) *@
        <div class="drawer-form-section">
            <h6 class="fw-bold mb-3" style="color:#1e2d3d;">
                <i class="bx bx-user-circle me-2" style="color:#3182ce;"></i>基本資料 (僅供檢視)
            </h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">帳號</label>
                    <input type="text" class="form-control form-control-sm readonly-field"
                           value="@Model.Account" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">姓名</label>
                    <input type="text" name="FullName" value="@Model.FullName"
                           class="form-control form-control-sm readonly-field" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">電子信箱</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light"><i class="bx bx-envelope"></i></span>
                        <input type="email" name="Email" value="@Model.Email"
                               class="form-control readonly-field" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">聯絡電話</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light"><i class="bx bx-phone"></i></span>
                        <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber"
                               class="form-control readonly-field" readonly />
                    </div>
                </div>
            </div>
        </div>

        @* 通訊地址 (改為 disabled 與唯讀) *@
        <div class="drawer-form-section">
            <h6 class="fw-bold mb-3" style="color:#1e2d3d;">
                <i class="bx bx-map me-2" style="color:#3182ce;"></i>通訊地址 (僅供檢視)
            </h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">縣市</label>
                    <select id="drawerCitySelect" class="form-select form-select-sm readonly-field" disabled>
                        @foreach (var opt in Model.CityOptions)
                        {
                            <option value="@opt.Value" selected="@(opt.Value == Model.City ? "selected" : null)">@opt.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">區域</label>
                    <select id="drawerRegionSelect" class="form-select form-select-sm readonly-field" disabled>
                        @foreach (var opt in Model.RegionOptions)
                        {
                            <option value="@opt.Value" selected="@(opt.Value == Model.Region ? "selected" : null)">@opt.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">街道地址</label>
                    <input type="text" name="Street" value="@Model.Street"
                           class="form-control form-control-sm readonly-field" readonly />
                </div>
            </div>
        </div>

        @* 黑名單設定 (唯一可編輯) *@
        <div class="drawer-form-section">
            <h6 class="fw-bold mb-3" style="color:#1e2d3d;">
                <i class="bx bx-cog me-2" style="color:#3182ce;"></i>帳號設定
            </h6>
            <div class="blacklist-box">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-bold mb-1" style="color:#ea5455;">
                            <i class="bx bx-block me-2"></i>黑名單狀態
                        </div>
                        <small class="text-danger">開啟後，該會員將無法登入與下單</small>
                    </div>
                    <div class="form-check form-switch ms-3">
                        <input type="checkbox"
                               name="IsBlacklisted"
                               id="drawerBlacklistSwitch"
                               class="form-check-input"
                               role="switch"
                               value="true"
                               @(Model.IsBlacklisted ? "checked" : "") />
                    </div>
                </div>
            </div>

            @* 賣家資格（僅供檢視）*@
            <div class="mt-3 p-3 rounded" style="background:#f8f9fa; border:1px solid #e2e8f0;">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input readonly-field" id="drawerSellerCheck"
                           @(Model.IsSeller ? "checked" : "") disabled />
                    <label class="form-check-label fw-semibold" for="drawerSellerCheck">
                        <i class="bx bx-store-alt me-1"></i>賣家資格（僅供檢視）
                    </label>
                </div>
            </div>
        </div>

        @* 操作按鈕 *@
        <div class="d-flex justify-content-end gap-3 pt-2">
            <button type="button" onclick="closeDrawer()" class="btn btn-label-secondary px-4">
                <i class="bx bx-x me-1"></i>取消
            </button>
            <button type="submit" id="drawerSaveBtn" class="btn btn-primary px-4">
                <i class="bx bx-save me-1"></i>儲存變更
            </button>
        </div>

    </div>
</form>