@model ISpanShop.MVC.Areas.Admin.Models.Members.MemberIndexVm

@{
    Layout = "~/Views/Shared/_SneatLayout.cshtml";
    ViewData["Title"] = "會員列表";
    var totalPages = (int)Math.Ceiling((double)Model.PagedResult.TotalCount / Model.PagedResult.PageSize);
}

<style>
    .font-noto {
        font-family: 'Noto Sans TC', sans-serif;
    }
    .tracking-tight {
        letter-spacing: -0.025em;
    }
    .member-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #f8f9fa;
    }
    .member-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .member-name {
        font-weight: 600;
        color: #1e2d3d;
        margin-bottom: 2px;
        font-size: 0.938rem;
    }
    .member-account {
        font-size: 0.813rem;
        color: #a1acb8;
    }
    .member-email {
        font-size: 0.813rem;
        color: #718096;
    }
    .point-balance {
        color: #ff9f43;
        font-weight: 600;
        font-size: 0.938rem;
    }
    .badge-soft {
        padding: 0.375rem 0.75rem;
        border-radius: 0.5rem;
        font-weight: 500;
        font-size: 0.813rem;
    }
    .bg-label-buyer {
        background-color: #e3f2fd;
        color: #1976d2;
    }
    .bg-label-seller {
        background-color: #e8f5e9;
        color: #388e3c;
    }
    .act-group {
        display: flex;
        gap: 0.5rem;
    }
    .act-icon {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.375rem;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        cursor: pointer;
        transition: all 0.2s;
    }
    .act-icon:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #3182ce;
    }
    .act-view:hover {
        background: #eff6ff;
        border-color: #3b82f6;
        color: #3b82f6;
    }
    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }
</style>

<div class="container-fluid py-4 font-noto">
    
    @* ── 頁首 ── *@
    <div class="mb-4 d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h2 class="fw-bold tracking-tight mb-1" style="color:#1e2d3d;">
                <i class="bx bx-user me-2" style="color:#3182ce;"></i>會員列表
            </h2>
            <p class="mb-0 fs-7 text-muted">管理所有會員資料，查看會員狀態與基本資訊</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <form method="get" asp-action="Index" class="d-flex gap-2">
                <div class="input-group" style="max-width: 320px;">
                    <input type="text" 
                           name="keyword" 
                           value="@Model.Keyword" 
                           class="form-control" 
                           placeholder="搜尋姓名、電話或帳號..." 
                           style="border-radius: 0.375rem 0 0 0.375rem;" />
                    <button type="submit" class="btn btn-primary" style="border-radius: 0 0.375rem 0.375rem 0;">
                        <i class="bx bx-search me-1"></i>搜尋
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Keyword))
                {
                    <a href="@Url.Action("Index")" class="btn btn-label-secondary">
                        <i class="bx bx-x me-1"></i>清除
                    </a>
                }
            </form>
        </div>
    </div>

    @* ── 統計卡片 ── *@
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-4">
                            <div>
                                <span class="text-muted fs-7">總會員數</span>
                                <h4 class="mb-0 fw-bold" style="color:#1e2d3d;">@Model.PagedResult.TotalCount</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── 主表格 ── *@
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color:#f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <tr>
                        <th style="color:#64748b; font-weight:600; font-size:0.813rem; text-transform:uppercase; letter-spacing:0.05em;">
                            MEMBER PROFILE
                        </th>
                        <th style="color:#64748b; font-weight:600; font-size:0.813rem; text-transform:uppercase; letter-spacing:0.05em;">
                            身分 ROLE
                        </th>
                        <th style="color:#64748b; font-weight:600; font-size:0.813rem; text-transform:uppercase; letter-spacing:0.05em;">
                            等級 LEVEL
                        </th>
                        <th style="color:#64748b; font-weight:600; font-size:0.813rem; text-transform:uppercase; letter-spacing:0.05em;">
                            點數 BALANCE
                        </th>
                        <th style="color:#64748b; font-weight:600; font-size:0.813rem; text-transform:uppercase; letter-spacing:0.05em;">
                            狀態 STATUS
                        </th>
                        <th class="text-end" style="color:#64748b; font-weight:600; font-size:0.813rem; text-transform:uppercase; letter-spacing:0.05em;">
                            操作
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.PagedResult.Data.Any())
                    {
                        @foreach (var member in Model.PagedResult.Data)
                        {
                            <tr>
                                <!-- 會員資料 (頭像 + 姓名 + 帳號 + Email) -->
                                <td>
                                    <div class="member-info">
                                        <img src="@member.AvatarUrl" 
                                             alt="@member.FullName" 
                                             class="member-avatar" 
                                             onerror="this.src='https://via.placeholder.com/48'" />
                                        <div>
                                            <div class="member-name">@member.FullName</div>
                                            <div class="member-account">@@@member.Account</div>
                                            <div class="member-email">@member.Email</div>
                                        </div>
                                    </div>
                                </td>

                                <!-- 身分 (買家/賣家) -->
                                <td>
                                    <span class="badge badge-soft bg-label-buyer">
                                        <i class="bx bx-shopping-bag me-1"></i>買家
                                    </span>
                                    @if (member.IsSeller)
                                    {
                                        <span class="badge badge-soft bg-label-seller ms-1">
                                            <i class="bx bx-store-alt me-1"></i>賣家
                                        </span>
                                    }
                                </td>

                                <!-- 等級 -->
                                <td>
                                    <span style="color:#64748b; font-weight:500;">
                                        @{
                                            var levelIcon = member.LevelName switch
                                            {
                                                "金牌會員" => "bx-medal",
                                                "銀牌會員" => "bx-award",
                                                "銅牌會員" => "bx-trophy",
                                                _ => "bx-star"
                                            };
                                        }
                                        <i class="bx @levelIcon me-1"></i>@member.LevelName
                                    </span>
                                </td>

                                <!-- 點數 -->
                                <td>
                                    <span class="point-balance">
                                        <i class="bx bx-coin me-1"></i>P @member.PointBalance.ToString("N0")
                                    </span>
                                </td>

                                <!-- 狀態 -->
                                <td>
                                    @if (member.IsBlacklisted)
                                    {
                                        <span class="badge bg-label-danger">
                                            <i class="bx bx-block me-1"></i>停權
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-success">
                                            <i class="bx bx-check-circle me-1"></i>正常
                                        </span>
                                    }
                                </td>

                                <!-- 操作 -->
                                <td>
                                    <div class="act-group justify-content-end">
                                        <a href="@Url.Action("Edit", new { id = member.UserId })" 
                                           class="act-icon act-view" 
                                           data-bs-toggle="tooltip" 
                                           title="編輯會員">
                                            <i class="bx bx-edit"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="mb-2" style="color:#a0aec0;font-size:2.5rem;">
                                    <i class="bx bx-user-x"></i>
                                </div>
                                <h5 class="fw-normal" style="color:#718096;">找不到符合條件的會員</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 分頁控制 -->
        @if (Model.PagedResult.TotalCount > Model.PagedResult.PageSize)
        {
            <div class="card-footer bg-white border-top">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="text-muted mb-0 fs-7">
                            顯示第 @((Model.PagedResult.CurrentPage - 1) * Model.PagedResult.PageSize + 1) 
                            到 @Math.Min(Model.PagedResult.CurrentPage * Model.PagedResult.PageSize, Model.PagedResult.TotalCount) 
                            筆，共 @Model.PagedResult.TotalCount 筆
                        </p>
                    </div>
                    <div class="col-md-6">
                        <nav aria-label="會員列表分頁">
                            <ul class="pagination justify-content-end mb-0">
                                <!-- 上一頁 -->
                                <li class="page-item @(Model.PagedResult.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link" 
                                       href="@Url.Action("Index", new { keyword = Model.Keyword, page = Model.PagedResult.CurrentPage - 1, pageSize = Model.PagedResult.PageSize })">
                                        <i class="bx bx-chevron-left"></i>
                                    </a>
                                </li>

                                @{
                                    var startPage = Math.Max(1, Model.PagedResult.CurrentPage - 2);
                                    var endPage = Math.Min(totalPages, Model.PagedResult.CurrentPage + 2);
                                }

                                <!-- 第一頁 -->
                                @if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" 
                                           href="@Url.Action("Index", new { keyword = Model.Keyword, page = 1, pageSize = Model.PagedResult.PageSize })">
                                            1
                                        </a>
                                    </li>
                                    @if (startPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }

                                <!-- 頁碼 -->
                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == Model.PagedResult.CurrentPage ? "active" : "")">
                                        <a class="page-link" 
                                           href="@Url.Action("Index", new { keyword = Model.Keyword, page = i, pageSize = Model.PagedResult.PageSize })">
                                            @i
                                        </a>
                                    </li>
                                }

                                <!-- 最後一頁 -->
                                @if (endPage < totalPages)
                                {
                                    @if (endPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link" 
                                           href="@Url.Action("Index", new { keyword = Model.Keyword, page = totalPages, pageSize = Model.PagedResult.PageSize })">
                                            @totalPages
                                        </a>
                                    </li>
                                }

                                <!-- 下一頁 -->
                                <li class="page-item @(Model.PagedResult.CurrentPage >= totalPages ? "disabled" : "")">
                                    <a class="page-link" 
                                       href="@Url.Action("Index", new { keyword = Model.Keyword, page = Model.PagedResult.CurrentPage + 1, pageSize = Model.PagedResult.PageSize })">
                                        <i class="bx bx-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // 初始化 Bootstrap Tooltips
        document.addEventListener('DOMContentLoaded', function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        // 顯示成功訊息
        @if (TempData["Success"] != null)
        {
            <text>
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'success',
                    title: '成功',
                    text: @Html.Raw(Json.Serialize(TempData["Success"])),
                    timer: 2500,
                    showConfirmButton: false
                });
            } else {
                alert(@Html.Raw(Json.Serialize(TempData["Success"])));
            }
            </text>
        }
    </script>
}
