@model ISpanShop.MVC.Areas.Admin.Models.Categories.CategorySpecEditVm
@{
    ViewData["Title"] = "編輯分類屬性";
}

<style>
    /* ── 卡片 ── */
    .form-card {
        max-width: 700px;
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }

    /* ── Label ── */
    .form-label {
        font-size: 0.9rem;
        font-weight: 600;
    }

    /* ── Input / Select ── */
    .form-control,
    .form-select {
        font-size: 0.95rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
    }

    /* ── 按鈕 ── */
    .btn { border-radius: 8px; font-size: 0.85rem; }

    /* ── 選項區塊 ── */
    .section-title { font-size: 0.95rem; font-weight: 600; color: #495057; margin-bottom: 0.75rem; }
    .option-row { display: flex; gap: 8px; align-items: center; margin-bottom: 8px; }
    .option-row input { flex: 1; }
    .options-box {
        background: #f8f9fa;
        border: 1px dashed #ced4da;
        border-radius: 8px;
        padding: 1rem;
        margin-top: 0.5rem;
    }

    /* ── 其他 ── */
    .hint-text { font-size: 0.8rem; color: #6c757d; margin-top: 4px; }
    .required-mark { color: #dc3545; }
    .edit-id-badge {
        display: inline-block;
        background: #e9ecef;
        color: #6c757d;
        font-size: 0.78rem;
        padding: 2px 8px;
        border-radius: 10px;
        margin-left: 8px;
    }
</style>

<div class="d-flex align-items-center mb-3">
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm me-3">← 返回列表</a>
    <h4 class="mb-0 fw-bold">
        編輯分類屬性
        <span class="edit-id-badge">ID: @Model.Id</span>
    </h4>
</div>

<div class="card form-card">
    <div class="card-body p-4">
        <form method="post" action="@Url.Action("Edit")">
            @Html.AntiForgeryToken()

            @* ── 必要隱藏欄位 ── *@
            <input type="hidden" name="Id" value="@Model.Id" />

            @* ── 規格名稱 ── *@
            <div class="mb-3">
                <label class="form-label">規格名稱 <span class="required-mark">*</span></label>
                <input type="text" name="Name" class="form-control"
                       placeholder="例如：顏色、尺寸、容量"
                       value="@Model.Name" required />
                @Html.ValidationMessage("Name", new { @class = "text-danger small" })
            </div>

            @* ── 輸入方式 ── *@
            <div class="mb-3">
                <label class="form-label">輸入方式 <span class="required-mark">*</span></label>
                <select name="InputType" id="InputType" class="form-select">
                    <option value="text"     @@(Model.InputType == "text"     ? "selected" : "")>文字輸入（text）</option>
                    <option value="select"   @@(Model.InputType == "select"   ? "selected" : "")>下拉選單（select）</option>
                    <option value="checkbox" @@(Model.InputType == "checkbox" ? "selected" : "")>多選框（checkbox）</option>
                    <option value="radio"    @@(Model.InputType == "radio"    ? "selected" : "")>單選框（radio）</option>
                </select>
                <div class="hint-text" id="inputTypeHint"></div>
            </div>

            @* ── 是否必填 ── *@
            <div class="mb-3">
                <label class="form-label">是否必填</label>
                <div class="form-check">
                    <input type="checkbox" name="IsRequired" value="true"
                           class="form-check-input" id="IsRequired"
                           @(Model.IsRequired ? "checked" : "") />
                    <label class="form-check-label" for="IsRequired">此規格為商品必填項目</label>
                </div>
                <input type="hidden" name="IsRequired" value="false" />
            </div>

            @* ── 排序順序 ── *@
            <div class="mb-4">
                <label class="form-label">排序順序</label>
                <input type="number" name="SortOrder" class="form-control"
                       value="@Model.SortOrder" min="0" style="width:120px;" />
                <div class="hint-text">數字越小排越前面</div>
            </div>

            @* ── 選項管理（select / checkbox / radio 才顯示）── *@
            <div id="optionsSection" style="display:none;">
                <hr />
                <div class="section-title">選項管理</div>
                <div class="options-box">
                    <div id="optionsList"></div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2" id="addOptionBtn">
                        + 新增選項
                    </button>
                    <div class="hint-text mt-2">儲存後將以此清單取代現有所有選項</div>
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">更新</button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">取消</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const inputTypeSelect = document.getElementById('InputType');
    const optionsSection  = document.getElementById('optionsSection');
    const optionsList     = document.getElementById('optionsList');
    const addOptionBtn    = document.getElementById('addOptionBtn');
    const inputTypeHint   = document.getElementById('inputTypeHint');

    // 從 Razor 序列化現有選項為 JS 陣列，實現 List<string> 預填
    const existingOptions = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(Model.Options)
    );

    const hintMap = {
        text:     '商品上架時，賣家需自行輸入文字值',
        select:   '商品上架時，賣家從下拉選單中選擇一個值',
        checkbox: '商品上架時，賣家可勾選多個值',
        radio:    '商品上架時，賣家只能選擇一個值'
    };

    const needsOptions = (val) => ['select', 'checkbox', 'radio'].includes(val);

    function updateUI() {
        const val = inputTypeSelect.value;
        optionsSection.style.display = needsOptions(val) ? 'block' : 'none';
        inputTypeHint.textContent = hintMap[val] || '';
    }

    // name="Options" → ASP.NET Core 自動 bind 成 List<string>
    function createOptionRow(value) {
        const row = document.createElement('div');
        row.className = 'option-row';
        row.innerHTML =
            '<input type="text" name="Options" class="form-control form-control-sm" placeholder="輸入選項名稱" />' +
            '<button type="button" class="btn btn-outline-danger btn-sm remove-btn">✕</button>';
        if (value) row.querySelector('input').value = value;
        row.querySelector('.remove-btn').addEventListener('click', () => row.remove());
        return row;
    }

    // 預載現有選項
    existingOptions.forEach(opt => optionsList.appendChild(createOptionRow(opt)));

    addOptionBtn.addEventListener('click', () => {
        optionsList.appendChild(createOptionRow(''));
        optionsList.lastElementChild.querySelector('input').focus();
    });

    inputTypeSelect.addEventListener('change', updateUI);
    updateUI();
})();
</script>
}
