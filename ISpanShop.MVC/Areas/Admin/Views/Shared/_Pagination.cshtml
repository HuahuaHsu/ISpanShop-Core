@using ISpanShop.MVC.Areas.Admin.Models.Common
@model PaginationVm

@if (Model != null && Model.TotalPages > 1)
{
    var shadowCls = Model.ShadowLinks ? " shadow-sm" : "";

    <nav class="@Model.NavClass">
        <ul class="pagination justify-content-center gap-2">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link@(shadowCls) rounded-pill px-3"
                   href="@Model.UrlForPage(Model.CurrentPage - 1)">
                    <i class="bx bx-chevron-left@(Model.ShadowLinks ? " me-1" : "")"></i> 上一頁
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link@(shadowCls) rounded-circle fw-bold"
                           style="width:@(Model.CircleSize)px;height:@(Model.CircleSize)px;display:flex;align-items:center;justify-content:center;"
                           href="@Model.UrlForPage(i)">@i</a>
                    </li>
                }
                else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                {
                    <li class="page-item disabled">
                        <span class="page-link border-0 bg-transparent@(Model.ShadowLinks ? " fw-bold" : "")"
                              @(Model.ShadowLinks ? "style=\"color:#a0aec0;\"" : "")>…</span>
                    </li>
                }
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link@(shadowCls) rounded-pill px-3"
                   href="@Model.UrlForPage(Model.CurrentPage + 1)">
                    下一頁 <i class="bx bx-chevron-right@(Model.ShadowLinks ? " ms-1" : "")"></i>
                </a>
            </li>
        </ul>
    </nav>
}
