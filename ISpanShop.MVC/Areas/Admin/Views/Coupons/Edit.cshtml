@model ISpanShop.MVC.Models.Coupons.CouponFormVm
@{
    ViewData["Title"] = "編輯優惠券";
    Layout = "~/Views/Shared/_SneatLayout.cshtml";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">優惠券管理 /</span> 編輯優惠券
    </h4>

    <div class="row">
        <div class="col-md-12">
            <div class="card mb-4">
                <h5 class="card-header">優惠券資訊</h5>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="row">
                            <div class="mb-3 col-md-6">
                                <label class="form-label">商家</label>
                                <input class="form-control" value="--- 全站通用 ---" readonly disabled />
                                <input type="hidden" asp-for="StoreId" value="0" />
                                <span asp-validation-for="StoreId" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-6">
                                <label asp-for="Title" class="form-label">標題</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-6">
                                <label asp-for="CouponCode" class="form-label">優惠碼</label>
                                <input asp-for="CouponCode" class="form-control" />
                                <span asp-validation-for="CouponCode" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-3">
                                <label asp-for="DistributionType" class="form-label">發放方式</label>
                                <select asp-for="DistributionType" class="form-select">
                                    <option value="1">公開領取</option>
                                    <option value="2">序號兌換</option>
                                    <option value="3">系統派發</option>
                                </select>
                                <span asp-validation-for="DistributionType" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-3">
                                <label asp-for="CouponType" class="form-label">折扣類型</label>
                                <select asp-for="CouponType" class="form-select">
                                    <option value="1">固定金額</option>
                                    <option value="2">百分比 (例如打 8 折請填 20)</option>
                                </select>
                                <span asp-validation-for="CouponType" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-4">
                                <label asp-for="DiscountValue" class="form-label">折扣值</label>
                                <input asp-for="DiscountValue" class="form-control" />
                                <span asp-validation-for="DiscountValue" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-4">
                                <label asp-for="MinimumSpend" class="form-label">最低消費</label>
                                <input asp-for="MinimumSpend" class="form-control" />
                                <span asp-validation-for="MinimumSpend" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-4">
                                <label asp-for="MaximumDiscount" class="form-label">最高折抵 (百分比時適用)</label>
                                <input asp-for="MaximumDiscount" class="form-control" />
                                <span asp-validation-for="MaximumDiscount" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-6">
                                <label asp-for="StartTime" class="form-label">開始時間</label>
                                <input asp-for="StartTime" class="form-control" type="datetime-local" />
                                <span asp-validation-for="StartTime" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-6">
                                <label asp-for="EndTime" class="form-label">結束時間</label>
                                <input asp-for="EndTime" class="form-control" type="datetime-local" />
                                <span asp-validation-for="EndTime" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-4">
                                <label asp-for="TotalQuantity" class="form-label">發行總數</label>
                                <input asp-for="TotalQuantity" class="form-control" />
                                <span asp-validation-for="TotalQuantity" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-4">
                                <label asp-for="PerUserLimit" class="form-label">每人領取上限</label>
                                <input asp-for="PerUserLimit" class="form-control" />
                                <span asp-validation-for="PerUserLimit" class="text-danger"></span>
                            </div>
                            <div class="mb-3 col-md-4 d-flex align-items-end">
                                <input type="hidden" asp-for="ApplyToAll" value="true" />
                            </div>
                        </div>
                        
                        <div class="mt-2">
                            <button type="submit" class="btn btn-primary me-2">儲存修改</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
