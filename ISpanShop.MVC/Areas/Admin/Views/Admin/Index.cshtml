@model ISpanShop.MVC.Areas.Admin.Models.Admins.AdminIndexVm

@{
    ViewData["Title"] = "管理員管理";
    var currentUserId = User.FindFirst("userid")?.Value ?? User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;

    // 優先讀取 URL 的 activeTab 參數
    var queryTab = Context.Request.Query["activeTab"].ToString();
    var activeTab = !string.IsNullOrEmpty(queryTab) ? queryTab : (Model.ActiveTab ?? "tab1");
}

<style>
    /* ── 捲動時固定標題與 Tab ── */
    .sticky-top-section {
        position: sticky;
        top: 54px; /* 配合 Sneat 導覽列高度 */
        z-index: 1020;
        background: #f5f5f9; /* 配合背景色 */
        padding-top: 1rem;
        padding-bottom: 0rem;
    }

    /* 確保固定區塊在容器內水平撐滿 */
    .sticky-top-section {
        margin-left: -1.5rem;
        margin-right: -1.5rem;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }

    .sticky-search-section {
        position: sticky;
        top: 175px; /* 標題 + Tabs 的高度 */
        z-index: 1010;
        background: #f5f5f9;
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        margin-left: -1.5rem;
        margin-right: -1.5rem;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }

    .sticky-search-section .card {
        margin-bottom: 0.5rem !important;
    }

    /* ── 表格標題列固定 ── */
    .table thead th {
        position: sticky;
        top: 250px; /* 標題 + Tabs + 搜尋列高度 */
        z-index: 1005;
        background-color: #f8fafc !important;
        box-shadow: inset 0 -2px 0 #e2e8f0;
    }

    .table-responsive {
        overflow: visible !important;
    }
</style>

<div class="container-xxl flex-grow-1 container-p-y">
    
    <div class="sticky-top-section">
        <h4 class="fw-bold py-3 mb-4">
            <span class="text-muted fw-light">帳號管理 /</span> 管理員管理
        </h4>

        <!-- ── 小標籤區塊 (nav-align-top) ── -->
        <div class="nav-align-top mb-0">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button type="button" class="nav-link @(activeTab == "tab1" ? "active" : "")" role="tab" data-bs-toggle="tab" data-bs-target="#tab1" aria-controls="tab1" aria-selected="@(activeTab == "tab1" ? "true" : "false")">
                        管理員帳號
                    </button>
                </li>
                <li class="nav-item">
                    <button type="button" class="nav-link @(activeTab == "tab2" ? "active" : "")" role="tab" data-bs-toggle="tab" data-bs-target="#tab2" aria-controls="tab2" aria-selected="@(activeTab == "tab2" ? "true" : "false")">
                        身分與權限
                    </button>
                </li>
            </ul>
        </div>
    </div>

    @* 操作結果提示訊息 *@
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert @(Model.Message.Contains("成功") ? "alert-success" : "alert-danger") alert-dismissible mt-3" role="alert">
            @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="tab-content bg-transparent shadow-none border-0 p-0">

        @* ── Tab1：管理員帳號列表 ── *@
        <div class="tab-pane fade @(activeTab == "tab1" ? "show active" : "")" id="tab1" role="tabpanel">
            
            <div class="sticky-search-section">
                <div class="card mb-4 mt-3">
                    <div class="card-body">
                        <form method="get" asp-action="Index" class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label small text-muted">帳號或電子信箱</label>
                                <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="搜尋..." />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">狀態</label>
                                <select name="status" class="form-select">
                                    <option value="all" selected="@(Model.Status == "all")">所有狀態</option>
                                    <option value="active" selected="@(Model.Status == "active")">啟用中</option>
                                    <option value="blocked" selected="@(Model.Status == "blocked")">已停用</option>
                                    <option value="firstLogin" selected="@(Model.Status == "firstLogin")">待首次登入修改</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-muted">身分等級</label>
                                <select name="adminLevelId" class="form-select">
                                    <option value="">所有等級</option>
                                    @foreach (var level in Model.AdminLevels)
                                    {
                                        <option value="@level.AdminLevelId" selected="@(Model.SelectedAdminLevelId == level.AdminLevelId)">@level.LevelName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary flex-fill">
                                    <i class="bx bx-search me-1"></i>搜尋
                                </button>
                                <a href="@Url.Action("Index")" class="btn btn-label-secondary">
                                    <i class="bx bx-reset me-1"></i>重置
                                </a>
                            </div>
                            <input type="hidden" name="sortColumn" value="@Model.SortColumn" />
                            <input type="hidden" name="sortDirection" value="@Model.SortDirection" />
                            <input type="hidden" name="activeTab" value="tab1" />
                        </form>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mb-3">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
                        <i class="bx bx-plus me-1"></i> 新增管理員
                    </button>
                </div>

                <div class="card">
                    <div class="table-responsive text-nowrap">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>
                                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.Status, adminLevelId = Model.SelectedAdminLevelId, sortColumn = "Account", sortDirection = (Model.SortColumn == "Account" && Model.SortDirection == "asc" ? "desc" : "asc") })" class="text-dark">
                                            帳號
                                            @if (Model.SortColumn == "Account") { <i class="bx bx-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i> }
                                        </a>
                                    </th>
                                    <th>
                                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.Status, adminLevelId = Model.SelectedAdminLevelId, sortColumn = "Email", sortDirection = (Model.SortColumn == "Email" && Model.SortDirection == "asc" ? "desc" : "asc") })" class="text-dark">
                                            電子信箱
                                            @if (Model.SortColumn == "Email") { <i class="bx bx-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i> }
                                        </a>
                                    </th>
                                    <th>
                                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.Status, adminLevelId = Model.SelectedAdminLevelId, sortColumn = "AdminLevelName", sortDirection = (Model.SortColumn == "AdminLevelName" && Model.SortDirection == "asc" ? "desc" : "asc") })" class="text-dark">
                                            身分等級
                                            @if (Model.SortColumn == "AdminLevelName") { <i class="bx bx-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i> }
                                        </a>
                                    </th>
                                    <th>實際權限</th>
                                    <th>
                                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.Status, adminLevelId = Model.SelectedAdminLevelId, sortColumn = "IsBlacklisted", sortDirection = (Model.SortColumn == "IsBlacklisted" && Model.SortDirection == "asc" ? "desc" : "asc") })" class="text-dark">
                                            狀態
                                            @if (Model.SortColumn == "IsBlacklisted") { <i class="bx bx-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i> }
                                        </a>
                                    </th>
                                    <th>
                                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, status = Model.Status, adminLevelId = Model.SelectedAdminLevelId, sortColumn = "CreatedAt", sortDirection = (Model.SortColumn == "CreatedAt" && Model.SortDirection == "asc" ? "desc" : "asc") })" class="text-dark">
                                            建立時間
                                            @if (Model.SortColumn == "CreatedAt") { <i class="bx bx-sort-@(Model.SortDirection == "asc" ? "up" : "down")"></i> }
                                        </a>
                                    </th>
                                    <th class="text-end">操作</th>
                                </tr>
                            </thead>
                            <tbody class="table-border-bottom-0">
                                @if (Model.Admins != null && Model.Admins.Count > 0)
                                {
                                    @foreach (var admin in Model.Admins)
                                    {
                                        <tr class="@(admin.IsBlacklisted ? "bg-lighter text-muted" : "")">
                                            <td>
                                                <span class="fw-medium">@admin.Account</span>
                                                @if (admin.IsBlacklisted)
                                                {
                                                    <small class="text-danger ms-1">[已停用]</small>
                                                }
                                            </td>
                                            <td>@admin.Email</td>
                                            <td>
                                                @(string.IsNullOrEmpty(admin.AdminLevelName) ? "-" : admin.AdminLevelName)
                                            </td>
                                            <td>
                                                <div class="d-flex flex-wrap gap-1">
                                                    @if (admin.ActualPermissions != null && admin.ActualPermissions.Count > 0)
                                                    {
                                                        @foreach (var perm in admin.ActualPermissions)
                                                        {
                                                            <span class="badge bg-label-primary">@perm.DisplayName</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                @if (admin.IsBlacklisted)
                                                {
                                                    <span class="badge bg-label-danger">停用中</span>
                                                }
                                                else if (admin.IsFirstLogin)
                                                {
                                                    <span class="badge bg-label-warning">首次登入</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-label-success">啟用</span>
                                                }
                                            </td>
                                            <td>@admin.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td class="text-end">
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        onclick="openEditAdminOffcanvas({
                                                            userId: @admin.UserId,
                                                            account: '@admin.Account',
                                                            email: '@admin.Email',
                                                            adminLevelId: @(admin.AdminLevelId ?? 0),
                                                            isBlacklisted: @(admin.IsBlacklisted ? "true" : "false"),
                                                            isSuperAdmin: @(admin.AdminLevelId == 1 ? "true" : "false"),
                                                            isSelf: @(admin.UserId.ToString() == currentUserId ? "true" : "false")
                                                        })">
                                                    編輯
                                                </button>

                                                @if (!admin.IsBlacklisted && admin.UserId.ToString() != currentUserId && admin.AdminLevelId != 1)
                                                {
                                                    <form method="post" asp-action="DeactivateAdmin" class="d-inline" onsubmit="return confirm('確認要停用此管理員嗎？');">
                                                        <input type="hidden" name="userId" value="@admin.UserId" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">停用</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <button disabled class="btn btn-sm btn-outline-secondary">停用</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">沒有管理員資料</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            @* ── Tab2：身分與權限設定 ── *@
            <div class="tab-pane fade @(activeTab == "tab2" ? "show active" : "")" id="tab2" role="tabpanel">
                <div class="d-flex justify-content-end mb-3 mt-3">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createLevelModal">
                        <i class="bx bx-plus me-1"></i> 新增身分
                    </button>
                </div>

                <div class="row g-4">
                    @if (Model.AdminLevels != null && Model.AdminLevels.Count > 0)
                    {
                        @foreach (var level in Model.AdminLevels)
                        {
                            var isSuperAdmin = level.AdminLevelId == 1;
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title d-flex align-items-center gap-2 mb-2">
                                            @level.LevelName
                                            @if (isSuperAdmin)
                                            {
                                                <span class="badge bg-label-info" style="font-size: 0.7rem;">系統預設</span>
                                            }
                                        </h5>
                                        <p class="card-text text-muted small mb-3 flex-grow-1">
                                            @(string.IsNullOrEmpty(level.Description) ? "未提供說明" : level.Description)
                                        </p>
                                        <div class="mb-3 border-top pt-3">
                                            <p class="small fw-semibold mb-2">預設權限：</p>
                                            <div class="d-flex flex-wrap gap-1">
                                                @if (level.DefaultPermissions != null && level.DefaultPermissions.Count > 0)
                                                {
                                                    @foreach (var perm in level.DefaultPermissions)
                                                    {
                                                        <span class="badge bg-label-secondary">@perm.DisplayName</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">尚未設定權限</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end gap-2 mt-auto">
                                            @if (!isSuperAdmin)
                                            {
                                                var permIds = string.Join(",", level.DefaultPermissions?.Select(p => p.PermissionId) ?? new List<int>());
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        onclick="openEditLevelModal(@level.AdminLevelId, '@level.LevelName', '@level.Description', [@permIds])">
                                                    編輯
                                                </button>
                                                <form method="post" asp-action="DeleteAdminLevel" class="d-inline" onsubmit="return confirm('確認刪除此身分？若有管理員綁定將無法刪除。');">
                                                    <input type="hidden" name="adminLevelId" value="@level.AdminLevelId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button disabled class="btn btn-sm btn-outline-secondary">編輯</button>
                                                <button disabled class="btn btn-sm btn-outline-secondary">刪除</button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="card text-center text-muted py-5 border-0 shadow-sm">
                                尚未建立任何身分
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@* ── 新增管理員 Modal ── *@
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom pb-3">
                <h5 class="modal-title fw-bold">新增管理員</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="CreateAdmin">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">登入帳號</label>
                        <input type="text" value="@Model.NextAccount" class="form-control" readonly />
                        <div class="form-text">帳號由系統自動生成，不可修改</div>
                    </div>
                    <div class="mb-3">
                        <label for="adminLevelId" class="form-label">管理員身分 <span class="text-danger">*</span></label>
                        <select name="adminLevelId" id="adminLevelId" class="form-select" required>
                            <option value="">-- 請選擇 --</option>
                            @if (Model.CreateForm?.AdminLevelOptions != null)
                            {
                                @foreach (var level in Model.CreateForm.AdminLevelOptions)
                                {
                                    <option value="@level.AdminLevelId">@level.LevelName</option>
                                }
                            }
                        </select>
                        <div class="form-text">*不含超級管理員</div>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">初始密碼 <span class="text-danger">*</span></label>
                        <input type="password" name="password" id="password" class="form-control" placeholder="至少 8 個字元，含英文與數字" required minlength="8" />
                    </div>
                </div>
                <div class="modal-footer border-top pt-3">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">新增</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── 新增身分 Modal ── *@
<div class="modal fade" id="createLevelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom pb-3">
                <h5 class="modal-title fw-bold">新增身分</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="CreateAdminLevel">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">身分名稱 <span class="text-danger">*</span></label>
                        <input type="text" name="LevelName" class="form-control" placeholder="例：訂單管理員" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">說明</label>
                        <input type="text" name="Description" class="form-control" placeholder="選填" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">權限設定</label>
                        <div class="border rounded p-3 bg-lighter" style="max-height: 200px; overflow-y: auto;">
                            <div class="row g-2">
                                @if (Model.AllPermissions != null)
                                {
                                    @foreach (var perm in Model.AllPermissions)
                                    {
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="PermissionIds" value="@perm.PermissionId" id="perm_@perm.PermissionId" />
                                                <label class="form-check-label" for="perm_@perm.PermissionId">
                                                    @perm.DisplayName
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top pt-3">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">新增</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ── 編輯身分 Modal ── *@
<div class="modal fade" id="editLevelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom pb-3">
                <h5 class="modal-title fw-bold">編輯身分</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="UpdateAdminLevel">
                <input type="hidden" name="AdminLevelId" id="editLevelId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">身分名稱 <span class="text-danger">*</span></label>
                        <input type="text" name="LevelName" id="editLevelName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">說明</label>
                        <input type="text" name="Description" id="editLevelDescription" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">權限設定</label>
                        <div class="border rounded p-3 bg-lighter" style="max-height: 200px; overflow-y: auto;">
                            <div class="row g-2">
                                @if (Model.AllPermissions != null)
                                {
                                    @foreach (var perm in Model.AllPermissions)
                                    {
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input edit-perm-checkbox" type="checkbox" name="PermissionIds" value="@perm.PermissionId" id="edit_perm_@perm.PermissionId" data-permid="@perm.PermissionId" />
                                                <label class="form-check-label" for="edit_perm_@perm.PermissionId">
                                                    @perm.DisplayName
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top pt-3">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">儲存</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 監聽 Bootstrap Tab 切換，同步 URL 參數與左側選單狀態
        var triggerTabList = [].slice.call(document.querySelectorAll('button[data-bs-toggle="tab"]'))
        triggerTabList.forEach(function (tabEl) {
            tabEl.addEventListener('shown.bs.tab', function (event) {
                var targetId = event.target.getAttribute('data-bs-target').replace('#', '');

                // 1. 同步 URL，確保重新整理不跑版
                var url = new URL(window.location);
                url.searchParams.set('activeTab', targetId);
                window.history.replaceState({}, '', url);

                // 2. 同步左側選單狀態
                var menuTab1 = document.getElementById('menu-admin-tab1');
                var menuTab2 = document.getElementById('menu-admin-tab2');

                if (menuTab1 && menuTab2) {
                    if (targetId === 'tab1') {
                        menuTab1.classList.add('active');
                        menuTab2.classList.remove('active');
                    } else if (targetId === 'tab2') {
                        menuTab1.classList.remove('active');
                        menuTab2.classList.add('active');
                    }
                }
            })
        });

        // 開啟編輯 Modal 並綁定現有資料
        function openEditLevelModal(id, name, description, permIds) {
            document.getElementById('editLevelId').value = id;
            document.getElementById('editLevelName').value = name;
            document.getElementById('editLevelDescription').value = description || '';

            // 勾選對應的權限 Checkbox
            document.querySelectorAll('.edit-perm-checkbox').forEach(cb => {
                cb.checked = permIds.includes(parseInt(cb.dataset.permid));
            });

            // 觸發 Bootstrap Modal 顯示
            var editModal = new bootstrap.Modal(document.getElementById('editLevelModal'));
            editModal.show();
        }
    </script>
    <script>
        function openEditAdminOffcanvas(data) {
            document.getElementById('editAdminUserId').value = data.userId;
            document.getElementById('editAdminResetUserId').value = data.userId;
            document.getElementById('editAdminAccount').value = data.account;
            document.getElementById('editAdminEmail').value = data.email;
            document.getElementById('editAdminLevelId').value = data.adminLevelId || "";
            document.getElementById('editAdminIsBlacklisted').checked = data.isBlacklisted;

            // 超級管理員不可修改身分和狀態
            const isSuperAdmin = data.isSuperAdmin;
            const isSelf = data.isSelf;

            document.getElementById('editAdminLevelId').disabled = isSuperAdmin;
            document.getElementById('editAdminIsBlacklisted').disabled = isSuperAdmin || isSelf;
            document.getElementById('editAdminSubmitBtn').disabled = isSuperAdmin && !isSelf; // 如果是超管且不是自己，其實也不應該改，但這裡主要限制身分和狀態

            var offcanvas = new bootstrap.Offcanvas(document.getElementById('editAdminOffcanvas'));
            offcanvas.show();
        }
    </script>
}

@* ── 編輯管理員側拉 Panel (Offcanvas) ── *@
<div class="offcanvas offcanvas-end" tabindex="-1" id="editAdminOffcanvas" aria-labelledby="editAdminOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
        <h5 id="editAdminOffcanvasLabel" class="offcanvas-title fw-bold">編輯管理員資料</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form method="post" asp-action="UpdateAdmin">
            <input type="hidden" name="UserId" id="editAdminUserId" />
            <div class="mb-3">
                <label class="form-label">帳號</label>
                <input type="text" id="editAdminAccount" class="form-control" readonly disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">電子信箱</label>
                <input type="text" id="editAdminEmail" class="form-control" readonly disabled />
            </div>
            <div class="mb-3">
                <label for="editAdminLevelId" class="form-label">身分等級</label>
                <select name="AdminLevelId" id="editAdminLevelId" class="form-select">
                    @if (Model.CreateForm?.AdminLevelOptions != null)
                    {
                        @foreach (var level in Model.CreateForm.AdminLevelOptions)
                        {
                            <option value="@level.AdminLevelId">@level.LevelName</option>
                        }
                    }
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label">帳號狀態</label>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="IsBlacklisted" id="editAdminIsBlacklisted" value="true" />
                    <label class="form-check-label" for="editAdminIsBlacklisted">停權 (黑名單)</label>
                </div>
            </div>
            <button type="submit" id="editAdminSubmitBtn" class="btn btn-primary w-100 mb-3">儲存變更</button>
        </form>

        <hr class="my-4" />

        <div class="password-reset-section">
            <h6 class="fw-bold mb-3">重設臨時密碼</h6>
            <p class="text-muted small mb-3">重設後，該管理員下次登入時將被要求強制修改密碼。</p>
            <form method="post" asp-action="ResetPassword" onsubmit="return confirm('確認要重設密碼嗎？');">
                <input type="hidden" name="UserId" id="editAdminResetUserId" />
                <div class="mb-3">
                    <input type="password" name="NewPassword" class="form-control" placeholder="輸入新的臨時密碼" required minlength="8" />
                </div>
                <button type="submit" class="btn btn-outline-warning w-100">送出臨時密碼</button>
            </form>
        </div>
    </div>
</div>