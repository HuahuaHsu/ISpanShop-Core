                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">儲存</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Bootstrap Tooltips 初始化 ──
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el, { trigger: 'hover' });
            });
        });

        // ── 從列的 data-* 屬性讀取，再呼叫 openAdminDrawer ──
        function openAdminDrawerFromRow(row) {
            openAdminDrawer({
                userId:       parseInt(row.dataset.adminId),
                account:      row.dataset.account,
                email:        row.dataset.email,
                adminLevelId: parseInt(row.dataset.levelId),
                isBlacklisted: row.dataset.isBlacklisted === 'true',
                isSuperAdmin:  row.dataset.isSuper === 'true',
                isSelf:        row.dataset.isSelf === 'true'
            });
        }

        // Tab 切換
        document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(function(tabEl) {
            tabEl.addEventListener('shown.bs.tab', function(event) {
                var targetId = event.target.getAttribute('data-bs-target').replace('#', '');
                var url = new URL(window.location);
                url.searchParams.set('activeTab', targetId);
                window.history.replaceState({}, '', url);
                closeAdminDrawer();
                var m1 = document.getElementById('menu-admin-tab1');
                var m2 = document.getElementById('menu-admin-tab2');
                if (m1 && m2) {
                    m1.classList.toggle('active', targetId === 'tab1');
                    m2.classList.toggle('active', targetId === 'tab2');
                }
            });
        });

        // 身分編輯 Modal
        function openEditLevelModal(id, name, description, permIds) {
            document.getElementById('editLevelId').value = id;
            document.getElementById('editLevelName').value = name;
            document.getElementById('editLevelDescription').value = description || '';
            document.querySelectorAll('.edit-perm-checkbox').forEach(cb => {
                cb.checked = permIds.includes(parseInt(cb.dataset.permid));
            });
            new bootstrap.Modal(document.getElementById('editLevelModal')).show();
        }

        // 管理員編輯 Drawer
        function openAdminDrawer(data) {
            document.getElementById('drawerUserId').value      = data.userId;
            document.getElementById('drawerResetUserId').value = data.userId;
            document.getElementById('drawerAccount').value     = data.account;
            document.getElementById('drawerEmail').value       = data.email;
            document.getElementById('drawerLevelId').value     = data.adminLevelId || '';

            var toggle = document.getElementById('drawerIsBlacklisted');
            toggle.checked = data.isBlacklisted;
            document.getElementById('drawerIsBlacklistedHidden').value = data.isBlacklisted ? 'true' : 'false';

            document.getElementById('drawerLevelId').disabled  = data.isSuperAdmin;
            toggle.disabled                                     = data.isSuperAdmin || data.isSelf;
            document.getElementById('drawerSaveBtn').disabled  = data.isSuperAdmin;

            document.getElementById('drawerNewPassword').value = '';

            document.querySelectorAll('#adminTableBody tr').forEach(r => r.classList.remove('active-edit-row'));
            var row = document.querySelector('tr[data-admin-id="' + data.userId + '"]');
            if (row) row.classList.add('active-edit-row');

            document.getElementById('adminPageLayout').classList.add('is-open');
        }

        function closeAdminDrawer() {
            document.getElementById('adminPageLayout').classList.remove('is-open');
            document.querySelectorAll('#adminTableBody tr').forEach(r => r.classList.remove('active-edit-row'));
        }

        // Toggle → 同步隱藏欄位
        document.getElementById('drawerIsBlacklisted').addEventListener('change', function() {
            document.getElementById('drawerIsBlacklistedHidden').value = this.checked ? 'true' : 'false';
        });

        // 點擊 Drawer 與 Table 以外區域自動關閉
        document.addEventListener('mousedown', function (e) {
            var layout = document.getElementById('adminPageLayout');
            if (!layout.classList.contains('is-open')) return;

            var drawer   = document.getElementById('adminDrawer');
            var tbody    = document.getElementById('adminTableBody');
            var modals   = document.querySelector('.modal.show');

            if (modals) return; // 有 Modal 開著就不關 Drawer

            var insideDrawer = drawer.contains(e.target);
            var insideTable  = tbody  && tbody.contains(e.target);

            if (!insideDrawer && !insideTable) {
                closeAdminDrawer();
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeAdminDrawer();
        });

        document.addEventListener('submit', function(e) {
            // 1. 刪除身分確認
            if (e.target.classList.contains('delete-level-form')) {
                e.preventDefault();
                showConfirm('確認刪除此身分？若有管理員綁定將無法刪除。', () => {
                    e.target.submit();
                });
            }

            // 2. 重設密碼確認 (Drawer 內)
            if (e.target.getAttribute('action') === '/Admin/Admin/ResetPassword') {
                e.preventDefault();
                showConfirm('確認要重設密碼嗎？', () => {
                    e.target.submit();
                });
            }
        });

        // 密碼顯示切換
        function togglePwd(inputId, btn) {
            var input = document.getElementById(inputId);
            var icon  = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bx-hide', 'bx-show');
            } else {
                input.type = 'password';
                icon.classList.replace('bx-show', 'bx-hide');
            }
        }

        // Toast
        function showAdminToast(type, msg) {
            Swal.fire({
                icon: type,
                title: msg,
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        }

        @if (!string.IsNullOrEmpty(Model.Message))
        {
                var jsType = Model.Message.Contains("成功") ? "success" : "error";
                <text>
                document.addEventListener('DOMContentLoaded', function() {
                    showAdminToast('@jsType', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Message)));
                });
                </text>
        }
    </script>
}
