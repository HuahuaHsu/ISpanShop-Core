@model ISpanShop.MVC.Areas.Admin.Models.Admins.AdminIndexVm

@{
    ViewData["Title"] = "管理員管理";
    var currentUserId = User.FindFirst("userid")?.Value ?? User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value;
}

<div class="p-6">
    <div class="mb-6 flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">管理員管理</h2>
            <p class="text-sm text-gray-600 mt-1">管理系統管理員帳號</p>
        </div>
        <button type="button" onclick="openCreateModal()" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg transition-colors">
            + 新增管理員
        </button>
    </div>

    @* 操作結果提示訊息 *@
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="mb-6 p-4 rounded-lg @(Model.Message.Contains("成功") ? "bg-green-50 border border-green-200" : "bg-red-50 border border-red-200")">
            <p class="@(Model.Message.Contains("成功") ? "text-green-800" : "text-red-800")">
                @Model.Message
            </p>
            @if (!string.IsNullOrEmpty(Model.GeneratedAccount))
            {
                <p class="text-green-700 mt-2 font-semibold">新增帳號：<span class="font-mono">@Model.GeneratedAccount</span></p>
            }
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider">
                    <th class="p-4 font-medium">帳號</th>
                    <th class="p-4 font-medium">電子信箱</th>
                    <th class="p-4 font-medium">角色</th>
                    <th class="p-4 font-medium">管理員等級</th>
                    <th class="p-4 font-medium">狀態</th>
                    <th class="p-4 font-medium">建立時間</th>
                    <th class="p-4 font-medium text-right">操作</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Admins != null && Model.Admins.Count > 0)
                {
                    @foreach (var admin in Model.Admins)
                    {
                        <tr class="@(admin.IsBlacklisted ? "bg-gray-100 opacity-60" : "hover:bg-gray-50") transition-colors">
                            <td class="p-4 font-medium text-gray-900">
                                @admin.Account
                                @if (admin.IsBlacklisted)
                                {
                                    <span class="text-xs text-gray-500 ml-2">[已停用]</span>
                                }
                            </td>
                            <td class="p-4 text-gray-700">
                                @admin.Email
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(admin.RoleName == "SuperAdmin" ? "bg-purple-100 text-purple-800" : "bg-blue-100 text-blue-800")">
                                    @admin.RoleName
                                </span>
                            </td>
                            <td class="p-4">
                                <span class="text-sm text-gray-700">
                                    @if (!string.IsNullOrEmpty(admin.AdminLevelName))
                                    {
                                        @admin.AdminLevelName
                                    }
                                    else
                                    {
                                        <span class="text-gray-400">-</span>
                                    }
                                </span>
                            </td>
                            <td class="p-4">
                                @if (admin.IsBlacklisted)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        停用中
                                    </span>
                                }
                                else if (admin.IsFirstLogin)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                        首次登入
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        啟用
                                    </span>
                                }
                            </td>
                            <td class="p-4 text-gray-600 text-sm">
                                @admin.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </td>
                            <td class="p-4 text-right">
                                <div class="flex justify-end space-x-2">
                                    @if (!admin.IsBlacklisted && admin.UserId.ToString() != currentUserId)
                                    {
                                        <form method="post" asp-action="DeactivateAdmin" style="display:inline;">
                                            <input type="hidden" name="userId" value="@admin.UserId" />
                                            <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium" onclick="return confirm('確認要停用此管理員嗎？');">
                                                停用
                                            </button>
                                        </form>
                                    }
                                    @if (admin.IsBlacklisted || admin.UserId.ToString() == currentUserId)
                                    {
                                        <button disabled class="text-gray-300 text-sm font-medium cursor-not-allowed">
                                            停用
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="p-8 text-center text-gray-500">
                            沒有管理員資料
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- 新增管理員 Modal -->
<div id="createModal" class="fixed inset-0 bg-black bg-opacity-50 hidden flex items-center justify-center z-50" onclick="closeCreateModal(event)">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4" onclick="event.stopPropagation()">
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-bold text-gray-800">新增管理員</h3>
            <button type="button" onclick="closeCreateModal()" class="text-gray-400 hover:text-gray-600">
                <span class="text-2xl">&times;</span>
            </button>
        </div>

        <form method="post" asp-action="CreateAdmin" class="p-6">
            <div class="space-y-4">
                <!-- 管理員等級選擇 -->
                <div>
                    <label for="adminLevelId" class="block text-sm font-medium text-gray-700 mb-2">
                        管理員等級 <span class="text-red-500">*</span>
                    </label>
                    <select name="adminLevelId" id="adminLevelId" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                        <option value="">-- 請選擇 --</option>
                        @foreach (var level in Model.CreateForm.AdminLevelOptions)
                        {
                            <option value="@level.AdminLevelId">@level.LevelName</option>
                        }
                    </select>
                    <p class="text-xs text-gray-500 mt-1">*不含超級管理員</p>
                </div>

                <!-- 初始密碼輸入 -->
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
                        初始密碼 <span class="text-red-500">*</span>
                    </label>
                    <input type="password" name="password" id="password" placeholder="至少 8 個字元，含英文與數字"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                           required minlength="8" />
                    <p class="text-xs text-gray-500 mt-1">帳號與 Email 由系統自動生成</p>
                </div>
            </div>

            <div class="mt-6 flex space-x-3">
                <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors font-medium">
                    新增
                </button>
                <button type="button" onclick="closeCreateModal()" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded-lg transition-colors font-medium">
                    取消
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openCreateModal() {
        document.getElementById('createModal').classList.remove('hidden');
    }

    function closeCreateModal(event) {
        if (event && event.target.id !== 'createModal') return;
        document.getElementById('createModal').classList.add('hidden');
    }
</script>

<style>
    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>
