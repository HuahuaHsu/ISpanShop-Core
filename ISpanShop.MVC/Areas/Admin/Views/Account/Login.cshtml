@model ISpanShop.MVC.Areas.Admin.Models.Account.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "後台登入 - ISpanShop";
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon-shop.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/sneat/assets/vendor/fonts/boxicons.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            margin: 0; padding: 0; height: 100%;
            font-family: 'Public Sans', sans-serif;
        }

        /* ── 整體佈局 ── */
        .login-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ══════════ 左側品牌區 ══════════ */
        .brand-side {
            flex: 0 0 58%;
            background: linear-gradient(145deg, #0d1b2a 0%, #1a2332 40%, #2a3042 100%);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            padding: 2.5rem 3rem;
        }

        /* ── 幾何裝飾共用 ── */
        .geo { position: absolute; }

        /* 實心圓 */
        .gc { border-radius: 50%; }
        /* 空心圓環 */
        .gr { border-radius: 50%; background: transparent !important; }
        /* 三角形（用 clip-path） */
        .gt { clip-path: polygon(50% 0%, 0% 100%, 100% 100%); border: none !important; }
        /* 六邊形 */
        .gh { clip-path: polygon(25% 0%,75% 0%,100% 50%,75% 100%,25% 100%,0% 50%); border: none !important; }

        /* ── 大型背景圓（blur 景深） ── */
        .g1 {
            width: 380px; height: 380px;
            top: -110px; right: -90px;
            background: rgba(16,185,129,0.10);
            border: 1.5px solid rgba(16,185,129,0.18);
            filter: blur(1px);
            animation: gFloat1 32s ease-in-out infinite;
        }
        .g2 {
            width: 280px; height: 280px;
            bottom: 60px; left: -70px;
            background: rgba(16,185,129,0.09);
            border: 1.5px solid rgba(16,185,129,0.15);
            filter: blur(0.5px);
            animation: gFloat2 38s ease-in-out infinite reverse;
        }
        .g3 {
            width: 200px; height: 200px;
            top: 38%; left: 32%;
            background: rgba(245,158,11,0.08);
            border: 1px solid rgba(245,158,11,0.14);
            filter: blur(2px);
            animation: gFloat3 28s ease-in-out infinite;
        }
        /* 空心圓環 */
        .g4 {
            width: 150px; height: 150px;
            top: 12%; left: 8%;
            border: 2px solid rgba(16,185,129,0.20);
            animation: gSpin1 40s linear infinite;
        }
        .g5 {
            width: 90px; height: 90px;
            bottom: 20%; right: 12%;
            border: 2px solid rgba(255,255,255,0.13);
            animation: gSpin1 25s linear infinite reverse;
        }
        .g6 {
            width: 55px; height: 55px;
            top: 55%; right: 8%;
            border: 1.5px solid rgba(16,185,129,0.22);
            animation: gSpin1 20s linear infinite;
        }
        /* 方塊 */
        .g7 {
            width: 80px; height: 80px;
            top: 20%; right: 22%;
            background: rgba(16,185,129,0.10);
            border: 1.5px solid rgba(16,185,129,0.20);
            animation: gSquare1 30s ease-in-out infinite;
        }
        .g8 {
            width: 50px; height: 50px;
            bottom: 28%; right: 32%;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.14);
            animation: gSquare1 22s ease-in-out infinite reverse;
        }
        .g9 {
            width: 110px; height: 110px;
            top: 62%; left: 6%;
            background: transparent;
            border: 1.5px solid rgba(245,158,11,0.14);
            animation: gSquare2 35s ease-in-out infinite;
        }
        /* 三角形 */
        .g10 {
            width: 70px; height: 60px;
            top: 30%; left: 24%;
            background: rgba(16,185,129,0.12);
            animation: gFloat3 24s ease-in-out infinite 3s;
        }
        .g11 {
            width: 45px; height: 39px;
            bottom: 38%; left: 42%;
            background: rgba(255,255,255,0.09);
            animation: gFloat1 28s ease-in-out infinite 6s;
        }
        /* 六邊形 */
        .g12 {
            width: 65px; height: 65px;
            top: 75%; right: 25%;
            background: rgba(16,185,129,0.11);
            animation: gFloat2 26s ease-in-out infinite 2s;
        }

        /* ── 粒子（小光點） ── */
        .dot { position: absolute; border-radius: 50%; }
        .d1  { width:5px;  height:5px;  top:18%; left:18%;  background:rgba(16,185,129,0.65);  animation: dFloat 11s ease-in-out infinite; }
        .d2  { width:3px;  height:3px;  top:65%; left:52%;  background:rgba(16,185,129,0.55);  animation: dFloat 14s ease-in-out infinite 2s; }
        .d3  { width:6px;  height:6px;  top:42%; right:22%; background:rgba(255,255,255,0.45);  animation: dFloat  9s ease-in-out infinite 1s; }
        .d4  { width:4px;  height:4px;  bottom:32%; left:33%; background:rgba(245,158,11,0.60); animation: dFloat 13s ease-in-out infinite 3s; }
        .d5  { width:3px;  height:3px;  top:78%; right:18%; background:rgba(16,185,129,0.50);  animation: dFloat 12s ease-in-out infinite 0.5s; }
        .d6  { width:2px;  height:2px;  top:14%; right:38%; background:rgba(255,255,255,0.55);  animation: dFloat 16s ease-in-out infinite 4s; }
        .d7  { width:5px;  height:5px;  top:50%; left:14%;  background:rgba(16,185,129,0.45);  animation: dFloat 10s ease-in-out infinite 5s; }
        .d8  { width:4px;  height:4px;  bottom:15%; left:58%; background:rgba(255,255,255,0.40); animation: dFloat 18s ease-in-out infinite 1.5s; }
        .d9  { width:3px;  height:3px;  top:88%; right:42%; background:rgba(245,158,11,0.55);  animation: dFloat  8s ease-in-out infinite 7s; }
        .d10 { width:6px;  height:6px;  top:6%;  left:48%;  background:rgba(16,185,129,0.35);  animation: dFloat 20s ease-in-out infinite 2.5s; }

        /* 圓形漂浮 */
        @@keyframes gFloat1 {
            0%,100% { transform: translate(0,0) scale(1); }
            30%      { transform: translate(18px,-22px) scale(1.04); }
            70%      { transform: translate(-12px,14px) scale(0.97); }
        }
        @@keyframes gFloat2 {
            0%,100% { transform: translate(0,0) scale(1); }
            40%      { transform: translate(-20px,18px) scale(1.05); }
            80%      { transform: translate(14px,-10px) scale(0.96); }
        }
        @@keyframes gFloat3 {
            0%,100% { transform: translate(0,0) rotate(0deg); }
            50%      { transform: translate(10px,-18px) rotate(8deg); }
        }
        /* 方塊旋轉浮動 */
        @@keyframes gSquare1 {
            0%,100% { transform: rotate(25deg) scale(1); }
            50%      { transform: rotate(65deg) scale(1.06) translateY(-14px); }
        }
        @@keyframes gSquare2 {
            0%,100% { transform: rotate(12deg) translateY(0); }
            50%      { transform: rotate(32deg) translateY(-18px); }
        }
        /* 圓環自轉 */
        @@keyframes gSpin1 {
            from { transform: rotate(0deg); }
            to   { transform: rotate(360deg); }
        }
        /* 粒子漂浮 */
        @@keyframes dFloat {
            0%,100% { transform: translate(0,0) scale(1);   opacity: 0.6; }
            25%      { transform: translate(10px,-14px) scale(1.4); opacity: 1; }
            60%      { transform: translate(-8px,10px) scale(0.7);  opacity: 0.5; }
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @@keyframes slideInRight {
            from { opacity: 0; transform: translateX(40px); }
            to   { opacity: 1; transform: translateX(0); }
        }
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Logo */
        .brand-logo {
            display: flex;
            align-items: center;
            gap: .75rem;
            position: relative; z-index: 2;
            animation: fadeInUp .6s ease both;
        }
        .brand-logo-icon {
            width: 42px; height: 42px;
            border-radius: 10px;
            background: linear-gradient(135deg, #F59E0B, #FBBF24);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 14px rgba(245,158,11,.35);
        }
        .brand-logo-icon i { font-size: 1.5rem; color: #fff; }
        .brand-logo-text {
            font-size: 1.35rem; font-weight: 700; color: #fff;
            letter-spacing: -.5px;
        }
        .brand-logo-badge {
            font-size: .65rem; font-weight: 600; color: #10b981;
            background: rgba(16,185,129,.15);
            border: 1px solid rgba(16,185,129,.3);
            border-radius: 4px; padding: 1px 6px;
            margin-left: .25rem;
        }

        /* 品牌主內容 */
        .brand-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative; z-index: 2;
            padding: 2rem 0;
        }
        .brand-tagline {
            font-size: .85rem;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #10b981;
            margin-bottom: 1.25rem;
            animation: fadeInUp .6s ease .2s both;
        }
        .brand-title {
            font-size: 2.8rem;
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 1rem;
            animation: fadeInUp .6s ease .35s both;
        }
        .brand-title span {
            background: linear-gradient(90deg, #10b981, #34d399);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .brand-subtitle {
            color: #8da8c0;
            font-size: 1rem;
            line-height: 1.7;
            max-width: 380px;
            margin-bottom: 2.5rem;
            animation: fadeInUp .6s ease .5s both;
        }

        /* 功能特色列表 */
        .feature-list {
            display: flex;
            flex-direction: column;
            gap: .9rem;
            animation: fadeInUp .6s ease .65s both;
        }
        .feature-item {
            display: flex;
            align-items: center;
            gap: .9rem;
        }
        .feature-icon {
            width: 38px; height: 38px;
            border-radius: 9px;
            background: rgba(16,185,129,.12);
            border: 1px solid rgba(16,185,129,.2);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .feature-icon i { color: #10b981; font-size: 1.1rem; }
        .feature-text { font-size: .88rem; color: #a9c1d8; line-height: 1.5; }
        .feature-text strong { color: #d1e8f5; font-weight: 600; }

        /* 底部版權 */
        .brand-footer {
            position: relative; z-index: 2;
            color: #4a6a85;
            font-size: .78rem;
            animation: fadeInUp .6s ease .8s both;
        }

        /* ══════════ 右側表單區 ══════════ */
        .form-side {
            flex: 1;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            animation: slideInRight .55s ease .1s both;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 400px;
        }

        .form-header {
            margin-bottom: 2.25rem;
        }
        .form-header h2 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1e293b;
            margin: 0 0 .4rem;
        }
        .form-header p {
            color: #64748b;
            font-size: .93rem;
            margin: 0;
        }

        /* 錯誤訊息框 */
        .login-error-box {
            display: flex;
            align-items: flex-start;
            gap: .6rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: .85rem 1rem;
            margin-bottom: 1.5rem;
            color: #dc2626;
            font-size: .88rem;
            line-height: 1.5;
            animation: fadeInUp .3s ease both;
        }
        .login-error-box i { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }

        /* 輸入框組 */
        .input-group-wrap {
            margin-bottom: 1.25rem;
        }
        .input-group-wrap label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: .45rem;
        }
        .input-field-wrap {
            position: relative;
        }
        .input-field-wrap .input-icon {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 1.1rem;
            pointer-events: none;
            transition: color .25s;
        }
        .input-field-wrap input {
            width: 100%;
            padding: .72rem 1rem .72rem 2.8rem;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: .93rem;
            font-family: inherit;
            color: #1e293b;
            background: #f9fafb;
            transition: border-color .25s, box-shadow .25s, background .25s;
            outline: none;
        }
        .input-field-wrap input:focus {
            border-color: #10b981;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(16,185,129,.12);
        }
        .input-field-wrap input:focus + .focus-line { opacity: 1; }
        .input-field-wrap input:focus ~ .input-icon { color: #10b981; }
        .input-field-wrap:focus-within .input-icon { color: #10b981; }

        /* 密碼顯示/隱藏按鈕 */
        .pwd-toggle {
            position: absolute;
            right: 12px; top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #9ca3af;
            font-size: 1.1rem;
            padding: 4px;
            display: flex;
            transition: color .2s;
        }
        .pwd-toggle:hover { color: #10b981; }

        /* 記住我 + 忘記密碼 */
        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.75rem;
        }
        .checkbox-wrap {
            display: flex;
            align-items: center;
            gap: .5rem;
            cursor: pointer;
        }
        .checkbox-wrap input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: #10b981;
            cursor: pointer;
        }
        .checkbox-wrap span {
            font-size: .875rem;
            color: #4b5563;
            user-select: none;
        }
        .forgot-link {
            font-size: .875rem;
            color: #10b981;
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }
        .forgot-link:hover { color: #059669; text-decoration: underline; }

        /* 登入按鈕 */
        .btn-login {
            width: 100%;
            padding: .82rem 1.5rem;
            background: linear-gradient(135deg, #10b981, #059669);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: transform .2s ease, box-shadow .2s ease;
            box-shadow: 0 4px 14px rgba(16,185,129,.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            position: relative;
            overflow: hidden;
        }
        .btn-login:hover {
            transform: scale(1.02);
            box-shadow: 0 6px 20px rgba(16,185,129,.45);
        }
        .btn-login:active {
            transform: scale(0.99);
        }
        .btn-login:disabled {
            opacity: .75;
            cursor: not-allowed;
            transform: none;
        }

        /* Loading Spinner */
        .btn-spinner {
            display: none;
            width: 18px; height: 18px;
            border: 2.5px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
        }
        .btn-login.loading .btn-text { display: none; }
        .btn-login.loading .btn-spinner { display: block; }

        /* 快速填入測試帳號按鈕 */
        .btn-quick-fill {
            width: 100%;
            margin-top: .75rem;
            padding: .6rem 1rem;
            background: transparent;
            color: #9ca3af;
            border: 1.5px dashed #d1d5db;
            border-radius: 10px;
            font-size: .82rem;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            transition: border-color .2s, color .2s, background .2s;
        }
        .btn-quick-fill:hover {
            border-color: #10b981;
            color: #10b981;
            background: rgba(16,185,129,.04);
        }
        .btn-quick-fill i { font-size: .9rem; }

        /* 底部小字 */
        .form-footer {
            text-align: center;
            margin-top: 1.75rem;
            color: #9ca3af;
            font-size: .8rem;
        }

        /* ══════════ RWD ══════════ */
        @@media (max-width: 900px) {
            .brand-side { display: none; }
            .form-side {
                background: linear-gradient(160deg, #f0fdf8 0%, #ecfdf5 100%);
                animation: fadeInUp .5s ease both;
            }
            .login-form-wrap {
                max-width: 420px;
            }
        }

        @@media (max-width: 480px) {
            .form-side { padding: 2rem 1.25rem; }
            .form-header h2 { font-size: 1.5rem; }
            .brand-title { font-size: 2.2rem; }
        }
    </style>
</head>
<body>
<div class="login-wrapper">
    <!-- ══ 左側品牌區 ══ -->
    <div class="brand-side">
        <!-- 幾何裝飾：圓形 -->
        <div class="geo gc g1"></div>
        <div class="geo gc g2"></div>
        <div class="geo gc g3"></div>
        <!-- 圓環 -->
        <div class="geo gc gr g4"></div>
        <div class="geo gc gr g5"></div>
        <div class="geo gc gr g6"></div>
        <!-- 方塊 -->
        <div class="geo g7"></div>
        <div class="geo g8"></div>
        <div class="geo g9"></div>
        <!-- 三角形 -->
        <div class="geo gt g10"></div>
        <div class="geo gt g11"></div>
        <!-- 六邊形 -->
        <div class="geo gh g12"></div>
        <!-- 粒子光點 -->
        <div class="dot d1"></div>
        <div class="dot d2"></div>
        <div class="dot d3"></div>
        <div class="dot d4"></div>
        <div class="dot d5"></div>
        <div class="dot d6"></div>
        <div class="dot d7"></div>
        <div class="dot d8"></div>
        <div class="dot d9"></div>
        <div class="dot d10"></div>

        <!-- Logo -->
        <div class="brand-logo">
            <div class="brand-logo-icon">
                <i class="bx bx-store-alt"></i>
            </div>
            <span class="brand-logo-text">ISpanShop</span>
            <span class="brand-logo-badge">Admin</span>
        </div>

        <!-- 主要內容 -->
        <div class="brand-content">
            <div class="brand-tagline">Management System</div>
            <h1 class="brand-title">
                歡迎回來<br />
                <span>後台管理中心</span>
            </h1>
            <p class="brand-subtitle">
                高效率的電商後台管理平台，整合商品審核、庫存監控、訂單追蹤等核心功能，讓您隨時掌握店鋪動態。
            </p>

            <div class="feature-list">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bx bx-store"></i>
                    </div>
                    <div class="feature-text">
                        <strong>商品管理</strong><br />全站商品審核與上下架管理
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bx bx-package"></i>
                    </div>
                    <div class="feature-text">
                        <strong>庫存監控</strong><br />即時追蹤庫存數量與低庫存警示
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bx bx-receipt"></i>
                    </div>
                    <div class="feature-text">
                        <strong>訂單追蹤</strong><br />訂單狀態管理與出貨排程
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="bx bx-category"></i>
                    </div>
                    <div class="feature-text">
                        <strong>分類管理</strong><br />商品分類與屬性規格配置
                    </div>
                </div>
            </div>
        </div>

        <!-- 版權 -->
        <div class="brand-footer">
            &copy; 2026 ISpanShop. All rights reserved.
        </div>
    </div>

    <!-- ══ 右側登入表單區 ══ -->
    <div class="form-side">
        <div class="login-form-wrap">
            <!-- 表頭 -->
            <div class="form-header">
                <h2>登入後台</h2>
                <p>請輸入您的帳號及密碼以繼續</p>
            </div>

            <!-- 錯誤訊息 -->
            @if (!ViewData.ModelState.IsValid)
            {
                var errors = ViewData.ModelState.Values
                    .SelectMany(v => v.Errors)
                    .Select(e => e.ErrorMessage)
                    .ToList();
                if (errors.Any())
                {
                    <div class="login-error-box">
                        <i class="bx bx-error-circle"></i>
                        <div>@string.Join(" ", errors)</div>
                    </div>
                }
            }

            <!-- 表單 -->
            <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post" id="loginForm">
                @Html.AntiForgeryToken()
                @if (ViewData["ReturnUrl"] != null)
                {
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                }

                <!-- 帳號 -->
                <div class="input-group-wrap">
                    <label asp-for="Account">帳號</label>
                    <div class="input-field-wrap">
                        <i class="bx bx-user input-icon"></i>
                        <input asp-for="Account"
                               type="text"
                               placeholder="請輸入管理員帳號"
                               autocomplete="username" />
                    </div>
                </div>

                <!-- 密碼 -->
                <div class="input-group-wrap">
                    <label asp-for="Password">密碼</label>
                    <div class="input-field-wrap">
                        <i class="bx bx-lock-alt input-icon"></i>
                        <input asp-for="Password"
                               id="passwordInput"
                               type="password"
                               placeholder="請輸入密碼"
                               autocomplete="current-password" />
                        <button type="button" class="pwd-toggle" id="pwdToggleBtn" tabindex="-1" title="顯示/隱藏密碼">
                            <i class="bx bx-hide" id="pwdToggleIcon"></i>
                        </button>
                    </div>
                </div>

                <!-- 記住我 + 忘記密碼 -->
                <div class="form-options">
                    <label class="checkbox-wrap">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>記住我</span>
                    </label>
                    <a href="#" class="forgot-link">忘記密碼？</a>
                </div>

                <!-- 登入按鈕 -->
                <button type="submit" class="btn-login" id="loginBtn">
                    <span class="btn-text">
                        <i class="bx bx-log-in-circle"></i>
                        登入後台
                    </span>
                    <span class="btn-spinner"></span>
                </button>

                <!-- 快速填入測試帳號 -->
                <button type="button" class="btn-quick-fill" id="quickFillBtn">
                    <i class="bx bx-fill"></i>
                    快速填入測試帳號
                </button>
            </form>

            <div class="form-footer">
                © 2026 ISpanShop 後台管理系統
            </div>
        </div>
    </div>
</div>

<script>
    // 密碼顯示 / 隱藏
    (function () {
        var input = document.getElementById('passwordInput');
        var btn   = document.getElementById('pwdToggleBtn');
        var icon  = document.getElementById('pwdToggleIcon');
        if (!btn) return;
        btn.addEventListener('click', function () {
            var isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            icon.className = isHidden ? 'bx bx-show' : 'bx bx-hide';
        });
    })();

    // 快速填入測試帳號
    (function () {
        var btn = document.getElementById('quickFillBtn');
        if (!btn) return;
        btn.addEventListener('click', function () {
            document.querySelector('input[name="Account"]').value = 'admin';
            document.getElementById('passwordInput').value = 'Admin@1234';
        });
    })();

    // 前端驗證 + Loading 狀態
    (function () {
        var form      = document.getElementById('loginForm');
        var loginBtn  = document.getElementById('loginBtn');
        var accountEl = document.querySelector('input[name="Account"]');
        var passwordEl = document.getElementById('passwordInput');

        form.addEventListener('submit', function (e) {
            var account  = (accountEl.value || '').trim();
            var password = (passwordEl.value || '').trim();

            // 移除舊錯誤
            var existingErr = document.querySelector('.login-error-box.js-err');
            if (existingErr) existingErr.remove();

            if (!account || !password) {
                e.preventDefault();
                var errBox = document.createElement('div');
                errBox.className = 'login-error-box js-err';
                errBox.innerHTML =
                    '<i class="bx bx-error-circle"></i>' +
                    '<div>' + (!account ? '請輸入帳號' : '請輸入密碼') + '</div>';
                form.insertBefore(errBox, form.firstChild);
                (!account ? accountEl : passwordEl).focus();
                return;
            }

            loginBtn.classList.add('loading');
            loginBtn.disabled = true;
        });
    })();
</script>
</body>
</html>
