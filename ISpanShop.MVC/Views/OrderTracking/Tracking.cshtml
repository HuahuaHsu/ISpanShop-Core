@model ISpanShop.Models.DTOs.Orders.OrderFullDto
@using ISpanShop.Common.Enums

@{
    ViewData["Title"] = "訂單追蹤 - " + Model.OrderNumber;
    
    // 計算進度條百分比
    int progress = Model.Status switch {
        OrderStatus.Pending => 10,
        OrderStatus.Processing => 40,
        OrderStatus.Shipped => 70,
        OrderStatus.Completed => 100,
        OrderStatus.Returning => 100,
        OrderStatus.Refunded => 100,
        _ => 0
    };
}

@section Styles {
    <style>
        .step-indicator { display: flex; justify-content: space-between; position: relative; margin-bottom: 3rem; }
        .step-indicator::before { content: ""; position: absolute; top: 15px; left: 0; right: 0; height: 4px; background: #e9ecef; z-index: 0; }
        .step-progress-bar { position: absolute; top: 15px; left: 0; height: 4px; background: #696cff; z-index: 1; transition: width 0.5s ease; }
        .step-item { position: relative; z-index: 2; text-align: center; width: 80px; }
        .step-icon { width: 34px; height: 34px; border-radius: 50%; background: #fff; border: 4px solid #e9ecef; margin: 0 auto 8px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
        .step-item.active .step-icon { border-color: #696cff; background: #696cff; color: white; }
        .step-label { font-size: 0.75rem; font-weight: 600; color: #a1acb8; }
        .step-item.active .step-label { color: #566a7f; }
    </style>
}

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="bx bx-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="card-header bg-primary text-white p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold"><i class="bx bx-package me-2"></i>訂單進度追蹤</h4>
                        <span class="badge bg-white text-primary rounded-pill px-3 py-2">@Model.Status.GetDisplayName()</span>
                    </div>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <!-- 進度條 -->
                    <div class="step-indicator">
                        <div class="step-progress-bar" style="width: @progress%"></div>
                        <div class="step-item @(progress >= 10 ? "active" : "")">
                            <div class="step-icon"><i class='bx bx-wallet'></i></div>
                            <div class="step-label">待付款</div>
                        </div>
                        <div class="step-item @(progress >= 40 ? "active" : "")">
                            <div class="step-icon"><i class='bx bx-package'></i></div>
                            <div class="step-label">待出貨</div>
                        </div>
                        <div class="step-item @(progress >= 70 ? "active" : "")">
                            <div class="step-icon"><i class='bx bx-truck'></i></div>
                            <div class="step-label">運送中</div>
                        </div>
                        <div class="step-item @(progress >= 100 ? "active" : "")">
                            <div class="step-icon"><i class='bx bx-check-double'></i></div>
                            <div class="step-label">已完成</div>
                        </div>
                    </div>

                    <div class="row mt-5">
                        <!-- 訂單資訊 -->
                        <div class="col-md-7">
                            <h5 class="fw-bold mb-4 border-bottom pb-2">商品清單</h5>
                            @foreach (var item in Model.Details)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <div class="flex-shrink-0">
                                        <img src="@(string.IsNullOrEmpty(item.CoverImage) ? "/sneat/assets/img/elements/1.jpg" : item.CoverImage)" class="rounded" width="60" height="60" style="object-fit: cover;">
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <h6 class="mb-0 fw-bold">@item.ProductName</h6>
                                        <small class="text-muted">規格: @item.VariantName | 數量: x @item.Quantity</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold">@item.SubTotal.ToString("C0")</div>
                                    </div>
                                </div>
                            }
                            <hr>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">商品小計</span>
                                <span class="fw-bold">@Model.TotalAmount.ToString("C0")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">運費</span>
                                <span class="fw-bold">@((Model.ShippingFee ?? 0).ToString("C0"))</span>
                            </div>
                            <div class="d-flex justify-content-between h5 mt-3 fw-black text-danger">
                                <span>應付總額</span>
                                <span>@Model.FinalAmount.ToString("C0")</span>
                            </div>
                        </div>

                        <!-- 側邊資訊與操作 -->
                        <div class="col-md-5 ps-md-5 mt-4 mt-md-0 border-start">
                            <div class="mb-4">
                                <label class="text-muted small text-uppercase fw-bold d-block mb-1">訂單編號</label>
                                <p class="h6 fw-bold">#@Model.OrderNumber</p>
                            </div>
                            <div class="mb-4">
                                <label class="text-muted small text-uppercase fw-bold d-block mb-1">收件資訊</label>
                                <p class="mb-1 fw-medium">@Model.RecipientName (@Model.RecipientPhone)</p>
                                <p class="small text-muted mb-0">@Model.RecipientAddress</p>
                            </div>

                            @if (Model.Status == OrderStatus.Completed)
                            {
                                <div class="bg-label-warning p-3 rounded-3 border-start border-warning border-4 mb-3">
                                    <p class="small text-dark mb-0">商品有問題嗎？您可以在確認收貨後 7 天內申請退貨。</p>
                                </div>
                                <button type="button" class="btn btn-outline-danger w-100 rounded-pill" data-bs-toggle="modal" data-bs-target="#returnModal">
                                    <i class="bx bx-undo me-1"></i> 申請退貨/退款
                                </button>
                            }
                            else if (Model.Status == OrderStatus.Returning)
                            {
                                <div class="alert alert-warning border-0">
                                    <h6 class="alert-heading fw-bold"><i class='bx bx-loader-circle bx-spin me-1'></i>退貨審核中</h6>
                                    <p class="small mb-0">我們已收到您的申請，管理員將於 48 小時內進行處理。</p>
                                </div>
                            }
                            else if (Model.Status == OrderStatus.Refunded)
                            {
                                <div class="alert alert-success border-0 text-center">
                                    <h6 class="alert-heading fw-bold mb-1"><i class='bx bx-check-shield me-1'></i>已成功退款</h6>
                                    <p class="small mb-0">退款金額已依原付款方式退回。</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 退貨申請 Modal -->
<div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-controller="OrderTracking" asp-action="ApplyReturn" method="post" enctype="multipart/form-data" class="modal-content">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="modal-header">
                <h5 class="modal-title fw-bold">申請退貨退款</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3 text-center">
                    <p class="text-muted">請填寫退貨原因，這能幫助我們更快為您處理。</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">退貨原因 <span class="text-danger">*</span></label>
                    <textarea name="reason" class="form-control" rows="3" placeholder="例如：商品損壞、規格不符..." required></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">上傳憑證圖片</label>
                    <input type="file" name="evidence" class="form-control" accept="image/*">
                    <small class="text-muted">建議上傳清楚的商品狀況照片。</small>
                </div>
                <div class="bg-label-info p-3 rounded small">
                    <i class="bx bx-info-circle me-1"></i> 溫馨提醒：審核通過後預計 3-5 個工作天會完成撥款。
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="submit" class="btn btn-danger px-4">確認送出申請</button>
            </div>
        </form>
    </div>
</div>
