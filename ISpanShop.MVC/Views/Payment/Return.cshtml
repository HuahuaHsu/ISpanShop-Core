@{
    Layout = null;
    var merchantTradeNo = ViewBag.MerchantTradeNo;
    var amount = ViewBag.Amount;
    var tradeDate = ViewBag.TradeDate;
    var paymentType = ViewBag.PaymentType;
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>交易成功 - HowBuy 購物</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif; }
        .success-card {
            max-width: 500px;
            margin: 50px auto;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .card-header-custom {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            padding: 40px 20px;
            text-align: center;
        }
        .success-icon { font-size: 4rem; margin-bottom: 10px; }
        .receipt-body { padding: 30px; background: white; }
        .receipt-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            border-bottom: 1px dashed #eee;
            padding-bottom: 10px;
        }
        .receipt-label { color: #6c757d; font-size: 0.9rem; }
        .receipt-value { font-weight: 600; color: #343a40; }
        .amount-highlight { color: #ee4d2d; font-size: 1.25rem; font-weight: bold; }
        .action-area { padding: 20px 30px 40px; text-align: center; background: white; }
        .btn-home {
            background-color: #ee4d2d;
            border: none;
            padding: 12px 40px;
            border-radius: 25px;
            font-weight: bold;
            transition: transform 0.2s;
        }
        .btn-home:hover {
            background-color: #d73211;
            transform: scale(1.05);
        }
    </style>
</head>
<body>

<div class="container">
    <div class="card success-card">
        <div class="card-header-custom">
            <div class="success-icon">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <h2 class="mb-0">交易成功</h2>
            <p class="mt-2 opacity-75">感謝您的購買，您的訂單已生效！</p>
        </div>
        
        <div class="receipt-body">
            <h5 class="mb-4 text-center">訂單明細</h5>
            
            <div class="receipt-item">
                <span class="receipt-label">交易編號</span>
                <span class="receipt-value">@merchantTradeNo</span>
            </div>
            
            <div class="receipt-item">
                <span class="receipt-label">付款方式</span>
                <span class="receipt-value">@paymentType</span>
            </div>
            
            <div class="receipt-item">
                <span class="receipt-label">交易時間</span>
                <span class="receipt-value">@tradeDate</span>
            </div>
            
            <div class="receipt-item mt-4 border-bottom-0">
                <span class="receipt-label text-dark fw-bold">付款總額</span>
                <span class="receipt-value amount-highlight">NT$ @string.Format("{0:N0}", amount)</span>
            </div>
        </div>

        <div class="action-area">
            <p class="text-muted small mb-4">我們將儘快為您處理出貨事宜</p>
            <!-- 導向 Vue 前台的訂單頁面 -->
            <a href="http://localhost:5173/member/orders" class="btn btn-primary btn-home">
                查看我的訂單
            </a>
            <div class="mt-3">
                <a href="http://localhost:5173/" class="text-decoration-none text-muted small">回到首頁</a>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
