@model ISpanShop.MVC.Models.ViewModels.SensitiveWordVm

@{
    ViewData["Title"] = "新增敏感字";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">新增敏感字</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        @* 顯示模型驗證錯誤摘要 *@
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Word" class="form-label">敏感字內容</label>
                            <input asp-for="Word" class="form-control" placeholder="輸入要過濾的字詞" />
                            <span asp-validation-for="Word" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">分類</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">-- 請選擇分類 --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input class="form-check-input" asp-for="IsActive" checked />
                            <label class="form-check-label" asp-for="IsActive">立即啟用</label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">返回列表</a>
                            <button type="submit" class="btn btn-primary">確認儲存</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}