@model ISpanShop.MVC.Models.Admins.AdminIndexVm

@{
    ViewData["Title"] = "管理員權限列表";
}

<div class="p-6">
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-800">管理員權限列表</h2>
        <p class="text-sm text-gray-600 mt-1">系統管理員及權限</p>
    </div>

    @* 操作結果提示訊息 *@
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="mb-6 p-4 rounded-lg @(Model.Message.Contains("成功") ? "bg-green-50 border border-green-200" : "bg-red-50 border border-red-200")">
            <p class="@(Model.Message.Contains("成功") ? "text-green-800" : "text-red-800")">
                @Model.Message
            </p>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider">
                    <th class="p-4 font-medium">帳號</th>
                    <th class="p-4 font-medium">電子信箱</th>
                    <th class="p-4 font-medium">角色</th>
                    <th class="p-4 font-medium">權限</th>
                    <th class="p-4 font-medium">建立時間</th>
                    <th class="p-4 font-medium text-right">操作</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Admins != null && Model.Admins.Count > 0)
                {
                    @foreach (var admin in Model.Admins)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="p-4 font-medium text-gray-900">
                                @admin.Account
                            </td>
                            <td class="p-4 text-gray-700">
                                @admin.Email
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    @admin.RoleName
                                </span>
                            </td>
                            <td class="p-4">
                                <form method="post" asp-action="UpdateRole" class="flex space-x-2">
                                    <input type="hidden" name="adminId" value="@admin.AdminId" />

                                    <select name="permissionId" class="border border-gray-300 rounded px-3 py-1 text-sm">
                                        <option value="">-- 選擇權限 --</option>
                                        @foreach (var p in Model.PermissionOptions)
                                        {
                                            <option value="@p.PermissionId">@p.Description</option>
                                        }
                                    </select>

                                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-1 rounded text-sm transition-colors">
                                        更新
                                    </button>
                                </form>
                            </td>
                            <td class="p-4 text-gray-600 text-sm">
                                @(admin.CreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                            </td>
                            <td class="p-4 text-right">
                                <div class="flex justify-end space-x-2">
                                    <a href="@Url.Action("Details", "Admins", new { id = admin.AdminId })" 
                                       class="text-blue-600 hover:text-blue-800 text-sm">
                                        詳細
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="p-8 text-center text-gray-500">
                            沒有管理員資料
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    select:disabled {
        background-color: #f3f4f6;
        cursor: not-allowed;
    }
</style>
