@model IEnumerable<ISpanShop.Models.DTOs.MemberDto>
﻿@{
    ViewData["Title"] = "會員管理列表";
}

<div class="p-6">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">會員列表</h2>

        <form method="get" asp-action="Index" class="flex space-x-2">
            <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="搜尋姓名、電話或帳號..." class="border rounded px-2 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500">

            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded transition-colors shadow-sm">
                搜尋
            </button>
        </form>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wider">
                    <th class="p-4 font-medium">MEMBER PROFILE</th>
                    <th class="p-4 font-medium">身分 (ROLE)</th>
                    <th class="p-4 font-medium">等級 (LEVEL)</th>
                    <th class="p-4 font-medium">點數 (BALANCE)</th>
                    <th class="p-4 font-medium">狀態 (STATUS)</th>
                    <th class="p-4 font-medium text-right">操作</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="p-4">
                            <div class="flex items-center space-x-3">
                                <img src="@item.AvatarUrl" alt="Avatar" class="w-10 h-10 rounded-full bg-gray-200 object-cover">
                                <div>
                                    <div class="font-medium text-gray-900">@item.FullName <span class="text-gray-400 text-xs">(@item.Account)</span></div>
                                    <div class="text-xs text-gray-500">@item.Email</div>
                                </div>
                            </div>
                        </td>

                        <td class="p-4">
                            @if (item.IsSeller)
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                                    <i data-lucide="store" class="w-3 h-3 mr-1"></i> 賣家
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">
                                    <i data-lucide="user" class="w-3 h-3 mr-1"></i> 買家
                                </span>
                            }
                        </td>

                        <td class="p-4 text-sm text-gray-600">
                            @item.LevelName
                        </td>

                        <td class="p-4 font-medium text-orange-500">
                            P @item.PointBalance.ToString("N0")
                        </td>

                        <td class="p-4">
                            @if (item.IsBlacklisted)
                            {
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-50 text-red-600 border border-red-100">
                                    <i data-lucide="x-circle" class="w-3 h-3 mr-1"></i> 停權
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-50 text-green-600 border border-green-100">
                                    <i data-lucide="check" class="w-3 h-3 mr-1"></i> 正常
                                </span>
                            }
                        </td>

                        <td class="p-4 text-right">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors inline-flex items-center">
                                <i data-lucide="edit-3" class="w-3 h-3 mr-1"></i> 編輯/查看
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="p-10 text-center text-gray-500">
                <i data-lucide="search-x" class="w-10 h-10 mx-auto mb-2 text-gray-300"></i>
                <p>找不到符合條件的會員</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        lucide.createIcons();
    </script>
}