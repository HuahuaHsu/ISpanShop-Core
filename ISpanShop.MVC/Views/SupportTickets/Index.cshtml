@model IEnumerable<ISpanShop.MVC.Models.ViewModels.SupportTicketVm>

@{
    ViewData["Title"] = "客服工單管理";
}

<div class="container mt-4">
    <h2 class="text-center">客服工單管理</h2>
    <hr />

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>單號</th>
                <th>主旨</th>
                <th>分類</th>
                <th>建立時間</th>
                <th>狀態</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.Subject</td>
                        <td>
                            <span class="badge border border-secondary text-secondary">@item.CategoryName</span>
                        </td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @* 根據狀態顯示不同顏色的標籤 *@
                            @if (item.Status == 0)
                            {
                                <span class="badge bg-warning text-dark">待處理</span>
                            }
                            else if (item.Status == 1)
                            {
                                <span class="badge bg-primary">處理中</span>
                            }
                            else if (item.Status == 2)
                            {
                                <span class="badge bg-success">已結案</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">未知狀態</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Reply" asp-route-id="@item.Id">處理</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">目前沒有任何客服工單。</td>
                </tr>
            }
        </tbody>
    </table>
</div>