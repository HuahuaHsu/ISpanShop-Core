@model ISpanShop.MVC.Models.ViewModels.ProductCreateVm
@{
    Layout = "_SneatLayout";
    ViewData["Title"] = "新增商品";
    var allCategories = ViewBag.AllCategories as IEnumerable<ISpanShop.Models.DTOs.CategoryDto> ?? Enumerable.Empty<ISpanShop.Models.DTOs.CategoryDto>();
    var stores = ViewBag.Stores as IEnumerable<(int Id, string Name)> ?? Enumerable.Empty<(int, string)>();
    var brands = ViewBag.Brands as IEnumerable<(int Id, string Name)> ?? Enumerable.Empty<(int, string)>();
    var parentCategories = allCategories.Where(c => c.ParentId == null).ToList();
    var subCategories = allCategories.Where(c => c.ParentId != null).ToList();
}

<div class="container-fluid py-4 font-noto" style="max-width:900px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-circle p-2 lh-1" style="width:38px;height:38px;">
            <i class="bx bx-arrow-back"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0" style="color:#1e2d3d;">新增商品</h2>
            <p class="mb-0 fs-7 text-muted">由管理員建立的商品將直接上架，略過審核流程</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="StoreId" class="form-label fw-bold text-uppercase fs-7 text-muted">所屬店家 <span class="text-danger">*</span></label>
                        <select asp-for="StoreId" class="form-select">
                            <option value="0">-- 請選擇店家 --</option>
                            @foreach (var s in stores)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        <span asp-validation-for="StoreId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold text-uppercase fs-7 text-muted">商品名稱 <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="輸入商品名稱" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold text-uppercase fs-7 text-muted">主分類</label>
                        <select id="parentCatCreate" class="form-select">
                            <option value="">-- 請選擇主分類 --</option>
                            @foreach (var pc in parentCategories)
                            {
                                <option value="@pc.Id">@pc.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-bold text-uppercase fs-7 text-muted">子分類 <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" id="subCatCreate" class="form-select">
                            <option value="0">-- 請先選主分類 --</option>
                            @foreach (var sc in subCategories)
                            {
                                <option value="@sc.Id" data-parent="@sc.ParentId">@sc.Name</option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BrandId" class="form-label fw-bold text-uppercase fs-7 text-muted">品牌</label>
                        <select asp-for="BrandId" class="form-select">
                            <option value="">-- 不指定品牌 --</option>
                            @foreach (var b in brands)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-bold text-uppercase fs-7 text-muted">基礎售價 <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">NT$</span>
                            <input asp-for="Price" class="form-control" type="number" min="1" step="1" placeholder="0"
                                   oninvalid="this.setCustomValidity('售價必須為大於 0 的整數')"
                                   oninput="this.setCustomValidity('')" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-bold text-uppercase fs-7 text-muted">商品描述</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="輸入商品詳細描述..."></textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-bold text-uppercase fs-7 text-muted">主圖</label>
                        <div class="d-flex gap-3 align-items-start">
                            <div class="flex-grow-1">
                                @* URL 輸入 *@
                                <input asp-for="MainImageUrl" id="mainImgUrl" class="form-control" placeholder="https://（貼入外部圖片網址）" />
                                <span asp-validation-for="MainImageUrl" class="text-danger small"></span>

                                @* 分隔 *@
                                <div class="d-flex align-items-center gap-2 my-2">
                                    <hr class="flex-grow-1 m-0" />
                                    <span class="text-muted" style="font-size:.8rem;white-space:nowrap;">或</span>
                                    <hr class="flex-grow-1 m-0" />
                                </div>

                                @* 檔案上傳 *@
                                <div>
                                    <label for="imageFileInput" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                        <i class="bx bx-upload me-1"></i>選擇檔案上傳
                                    </label>
                                    <input type="file" id="imageFileInput" name="ImageFile" accept=".jpg,.jpeg,.png,.webp" class="d-none" />
                                    <span id="fileNameLabel" class="text-muted ms-2" style="font-size:.82rem;"></span>
                                    <span asp-validation-for="ImageFile" class="text-danger small d-block mt-1"></span>
                                    <div id="fileError" class="text-danger small mt-1"></div>
                                    <div class="form-text">上傳優先於網址；支援 jpg / jpeg / png / webp，最大 5 MB</div>
                                </div>
                            </div>

                            @* 預覽框 *@
                            <div class="rounded-3 border d-flex align-items-center justify-content-center overflow-hidden flex-shrink-0"
                                 style="width:100px;height:100px;background:#f8fafc;">
                                <img id="imgPreview" src="" alt="預覽" class="w-100 h-100 object-fit-cover d-none" />
                                <i id="imgPreviewIcon" class="bx bx-image text-muted fs-2"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-pill px-4">取消</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">
                        <i class="bx bx-check me-1"></i> 新增商品
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .font-noto { font-family: 'Noto Sans TC', sans-serif; }
    .fs-7 { font-size: 0.85rem; }
    .card { border-radius: 16px !important; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('parentCatCreate').addEventListener('change', function () {
            var pid = this.value;
            var subSel = document.getElementById('subCatCreate');
            subSel.innerHTML = '<option value="0">-- 請選擇子分類 --</option>';
            if (!pid) return;
            fetch('@Url.Action("GetSubCategories", "Products")?parentId=' + pid)
                .then(r => r.json())
                .then(function (subs) {
                    subs.forEach(function (s) {
                        var opt = document.createElement('option');
                        opt.value = s.id; opt.textContent = s.name;
                        subSel.appendChild(opt);
                    });
                });
        });

        // URL 即時預覽
        document.getElementById('mainImgUrl').addEventListener('input', function () {
            if (document.getElementById('imageFileInput').files.length > 0) return; // 檔案優先
            showUrlPreview(this.value.trim());
        });

        function showUrlPreview(url) {
            var img = document.getElementById('imgPreview');
            var icon = document.getElementById('imgPreviewIcon');
            if (url) {
                img.src = url;
                img.classList.remove('d-none');
                icon.classList.add('d-none');
                img.onerror = function () { img.classList.add('d-none'); icon.classList.remove('d-none'); };
            } else {
                img.classList.add('d-none');
                icon.classList.remove('d-none');
            }
        }

        // 檔案上傳：驗證 + 預覽
        document.getElementById('imageFileInput').addEventListener('change', function () {
            var errEl = document.getElementById('fileError');
            var label = document.getElementById('fileNameLabel');
            errEl.textContent = '';
            if (!this.files || !this.files[0]) { label.textContent = ''; return; }

            var file = this.files[0];
            var allowed = ['image/jpeg', 'image/png', 'image/webp'];
            if (!allowed.includes(file.type)) {
                errEl.textContent = '僅支援 jpg、jpeg、png、webp 格式。';
                this.value = ''; label.textContent = '';
                return;
            }
            if (file.size > 5 * 1024 * 1024) {
                errEl.textContent = '檔案大小不可超過 5 MB。';
                this.value = ''; label.textContent = '';
                return;
            }

            label.textContent = file.name;
            var reader = new FileReader();
            reader.onload = function (e) {
                var img = document.getElementById('imgPreview');
                var icon = document.getElementById('imgPreviewIcon');
                img.src = e.target.result;
                img.classList.remove('d-none');
                icon.classList.add('d-none');
            };
            reader.readAsDataURL(file);
        });
    </script>
}
