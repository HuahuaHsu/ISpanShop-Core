@model IEnumerable<ISpanShop.Models.DTOs.UserDto>

@{
    ViewData["Title"] = "使用者列表";
    // 刪除 Layout = null; 讓它自動套用預設 Layout
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>使用者管理</h1>
    <p>
        <a asp-action="Create" class="btn btn-primary">＋ 新增使用者</a>
    </p>
</div>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Account)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>狀態</th>
            <th>@Html.DisplayNameFor(model => model.IsSeller)</th>
            <th>@Html.DisplayNameFor(model => model.RoleName)</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@Html.DisplayFor(modelItem => item.Account)</strong></td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>

                @* 優化狀態欄位：直接顯示漂亮的 Badge *@
                <td>
                    @if (item.IsBlacklisted == true)
                    {
                        <span class="badge bg-danger">黑名單</span>
                    }
                    else
                    {
                        <span class="badge bg-success">正常</span>
                    }
                </td>

                @* 修正賣家欄位邏輯 *@
                <td>
                    @if (item.IsSeller)
                    {
                        <span class="badge bg-primary">賣家</span>
                    }
                </td>

                <td>@Html.DisplayFor(modelItem => item.RoleName)</td>

                <td>
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">編輯</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">詳情</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">刪除</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>